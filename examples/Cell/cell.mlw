module MAIN
  use prelude.Prelude
  use State
end

module Main
  use prelude.Prelude
  use State
  use MAIN
  use CELL
  
  let main (s : state) (x : int) : int
    requires { s.pool = emptyRgn }
    requires { x >= 0 }
    writes { s.alloct, s.pool, s.rep, s.value }
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {}`rep] (wr_frame_rep (old s) s emptyRgn) }
    
    ensures { [@expl:wr {}`value] (wr_frame_value (old s) s emptyRgn) }
  = label INIT in
      let result = ref 0 in
      let x = ref x in
      let c = ref null in
      assert { hasCellType s (! c) };
      (c := ([@expl:c := new Cell] (s.mk_Cell)));
      (let k = ref 0 in
       (k := ([@expl:k := 0] 0));
       assert { (not (Rgn.mem (! c) (s.alloct.M.domain at INIT))) \/ ((! c) = null) };
       ([@expl:Cell(c,k)] (CELL.init_Cell s (! c) (! k)));
       assert { M.mem (! c) s.alloct };
       (x := ([@expl:x := x + 1] ((! x) + 1)));
       assert { (not (Rgn.mem (! c) (s.alloct.M.domain at INIT))) \/ ((! c) = null) };
       ([@expl:cset(c,x)] (CELL.cset s (! c) (! x)));
       assert { (not (Rgn.mem (! c) (s.alloct.M.domain at INIT))) \/ ((! c) = null) };
       (result := ([@expl:result := cget(c)] (CELL.cget s (! c))));
       (! result))
end

module Main_Link
  use prelude.Prelude
  use State
  use Main
  use CELL_REL
  
  lemma cellP_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_x : int, r_x : int.
            (((l_s.pool = emptyRgn) -> (l_x >= 0) -> (l_s.Main.CELL.cellP)) /\
               ((r_s.pool = emptyRgn) -> (r_x >= 0) -> (r_s.Main.CELL.cellP)))))
  
  lemma left_cellI_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) -> (forall l_x : int, r_x : int. (l_s.pool = emptyRgn) -> (l_x >= 0) -> (l_s.CELL_REL.ACell.cellI)))
  
  lemma right_cellI_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) -> (forall l_x : int, r_x : int. (r_s.pool = emptyRgn) -> (r_x >= 0) -> (r_s.CELL_REL.BCell.cellI)))
  
  lemma cellC_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_x : int, r_x : int.
            ((l_s.pool = emptyRgn) /\ (r_s.pool = emptyRgn)) -> ((l_x >= 0) /\ (r_x >= 0)) -> (l_x = r_x) -> (cellC l_s r_s pi)))
  
  val main (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_x: int) (r_x: int) : 
    (int, int)
    requires { okRefperm l_s r_s pi }
    requires { (l_x = r_x) }
    requires { ((l_x >= 0) /\ (r_x >= 0)) }
    requires { ((l_s.pool = emptyRgn) /\ (r_s.pool = emptyRgn)) }
    writes { pi, l_s.alloct, l_s.pool, r_s.alloct, r_s.pool }
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { PreRefperm.extends (old pi) pi }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { let l_s_alloc0 = old l_s.alloct.M.domain in
              let r_s_alloc0 = old r_s.alloct.M.domain in
              (l_x = r_x)
                /\
                ((agree_value
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc0) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_value
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc0) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_rep l_s r_s pi (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc0) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_rep
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc0) (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
end

