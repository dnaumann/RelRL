                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_lrep
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc0) r_snap_r9)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_rep
                    l_s
                    r_s
                    pi
                    (Rgn.diff
                        (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc0) l_snap_r9)
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_rep
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc0) r_snap_r9)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_id
                    l_s
                    r_s
                    pi
                    (Rgn.diff
                        (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc0) l_snap_r9)
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
