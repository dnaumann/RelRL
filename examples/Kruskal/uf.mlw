  val init_List (l_s: state) (r_s: state) (pi2: PreRefperm.t) (l_self: reference) (r_self: reference) : 
    (unit, unit)
    requires { hasListType l_s l_self }
    requires { (l_self <> null) }
    requires { hasListType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi2 }
    requires { PreRefperm.idRef pi2 l_self r_self }
    requires { ((agree_head l_s r_s pi2 (Rgn.diff (l_self.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_head r_s l_s (pi2.PreRefperm.invert) (Rgn.diff (r_self.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_lrep l_s r_s pi2 (Rgn.diff (l_self.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_lrep r_s l_s (pi2.PreRefperm.invert) (Rgn.diff (r_self.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((not (Rgn.mem l_self (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (not (Rgn.mem r_self (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    writes { l_s.head, l_s.lrep, r_s.head, r_s.lrep }
    ensures { [@expl:wr {self}`head] (wr_frame_head (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`lrep] (wr_frame_lrep (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`head] (wr_frame_head (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`lrep] (wr_frame_lrep (old r_s) r_s (r_self.singleton)) }
    
    ensures { okRefperm l_s r_s pi2 }
    
    ensures { let l_s_alloc10 = old l_s.alloct.M.domain in
              let r_s_alloc10 = old r_s.alloct.M.domain in
              let l_self12 = old (l_self.singleton) in
              let r_self12 = old (r_self.singleton) in
              ((agree_length
                  l_s
                  r_s
                  pi2
                  (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc10) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_length
                    r_s
                    l_s
                    (pi2.PreRefperm.invert)
                    (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc10) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_value
                    l_s
                    r_s
                    pi2
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc10) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_value
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc10) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_lrep
                    l_s
                    r_s
                    pi2
                    (Rgn.diff
                        (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc10) l_self12)
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_lrep
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc10) r_self12)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_rep
                    l_s
                    r_s
                    pi2
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc10) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_rep
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc10) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_id
                    l_s
                    r_s
                    pi2
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc10) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_id
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc10) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_head
                    l_s
                    r_s
                    pi2
                    (Rgn.diff
                        (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc10) l_self12)
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_head
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc10) r_self12)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_nxt
                    l_s
                    r_s
                    pi2
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc10) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_nxt
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc10) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_slots
                    l_s
                    r_s
                    pi2
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc10) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_slots
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc10) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_part
                    l_s
                    r_s
                    pi2
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc10) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_part
                      r_s
                      l_s
                      (pi2.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc10) (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { ((Main.lrep_closed l_s l_self) /\ (Main.lrep_closed r_s r_self)) }
    
    ensures { (((l_s.lrep[l_self]) = (null.singleton)) /\ ((r_s.lrep[r_self]) = (null.singleton))) }
    
    ensures { (((l_s.head[l_self]) = null) /\ ((r_s.head[r_self]) = null)) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
  
  val init_Node (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (l_v: int) (l_n: reference) (r_self: reference) (r_v: int) (r_n: reference) : 
    (unit, unit)
    requires { hasNodeType l_s l_self }
    requires { (l_self <> null) }
    requires { hasNodeType l_s l_n }
    requires { hasNodeType r_s r_self }
    requires { (r_self <> null) }
    requires { hasNodeType r_s r_n }
    requires { okRefperm l_s r_s pi }
    requires { (l_v = r_v) }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { PreRefperm.idRef pi l_n r_n }
    requires { ((agree_value l_s r_s pi (Rgn.diff (l_self.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_value r_s l_s (pi.PreRefperm.invert) (Rgn.diff (r_self.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_nxt l_s r_s pi (Rgn.diff (l_self.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_nxt r_s l_s (pi.PreRefperm.invert) (Rgn.diff (r_self.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { (((l_s.nxt[l_self]) = null) /\ ((r_s.nxt[r_self]) = null)) }
    requires { ((not (Rgn.mem l_self (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (not (Rgn.mem r_self (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    writes { l_s.value, l_s.nxt, r_s.value, r_s.nxt }
    ensures { [@expl:wr {self}`value] (wr_frame_value (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`nxt] (wr_frame_nxt (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`value] (wr_frame_value (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`nxt] (wr_frame_nxt (old r_s) r_s (r_self.singleton)) }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { let l_s_alloc13 = old l_s.alloct.M.domain in
              let r_s_alloc13 = old r_s.alloct.M.domain in
              let l_self15 = old (l_self.singleton) in
              let r_self15 = old (r_self.singleton) in
              ((agree_length
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc13) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_length
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc13) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_value
                    l_s
                    r_s
                    pi
                    (Rgn.diff
                        (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc13) l_self15)
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_value
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc13) r_self15)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_lrep
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc13) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_lrep
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc13) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_rep
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc13) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_rep
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc13) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_id l_s r_s pi (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc13) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_id
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc13) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_head
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc13) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_head
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc13) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_nxt
                    l_s
                    r_s
                    pi
                    (Rgn.diff
                        (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc13) l_self15)
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_nxt
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc13) r_self15)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_slots
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc13) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_slots
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc13) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_part
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc13) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_part
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc13) (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { (((l_s.value[l_self]) = l_v) /\ ((r_s.value[r_self]) = r_v)) }
    
    ensures { (((l_s.nxt[l_self]) = l_n) /\ ((r_s.nxt[r_self]) = r_n)) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
end

module UFREL_biinterface
  use prelude.Prelude
  use State
  use QuickFind
  use QuickUnion
  use export partition.Partition
  
  predicate samePartition (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_p: reference) (r_p: reference) =
    (okRefperm l_s r_s pi)
      ->
      (hasUfindType l_s l_p)
      ->
      (hasUfindType r_s r_p)
      ->
      (let l_prt = l_s.part[l_p] in
       let r_prt = r_s.part[r_p] in
       ((l_prt.QuickFind.UNIONFIND.pSize) = (r_prt.QuickUnion.UNIONFIND.pSize)) /\ (pEq l_prt r_prt))
  
  predicate eqReps (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_p: reference) (r_p: reference) =
    (okRefperm l_s r_s pi)
      ->
      (hasUfindType l_s l_p)
      ->
      (hasUfindType r_s r_p)
      ->
      (let l_prt = l_s.part[l_p] in
       let r_prt = r_s.part[r_p] in
       forall l_i : int, r_i : int.
         (((0 <= l_i) /\ (l_i < (l_prt.QuickFind.UNIONFIND.pSize))) /\ ((0 <= r_i) /\ (r_i < (r_prt.QuickUnion.UNIONFIND.pSize))))
           ->
           (l_i = r_i)
           ->
           (let l_id = l_s.id[l_p] in
            let r_id = r_s.id[r_p] in
            ((A.get (l_s.slots[l_id]) l_i) = l_i) <-> ((A.get (r_s.slots[r_id]) r_i) = r_i)))
  
  predicate eqRepsExcept (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_p: reference) (l_x: int) (r_p: reference) (r_x: int) =
    (okRefperm l_s r_s pi)
      ->
      (hasUfindType l_s l_p)
      ->
      (hasUfindType r_s r_p)
      ->
      (let l_prt = l_s.part[l_p] in
       let r_prt = r_s.part[r_p] in
       forall l_i : int, r_i : int.
         (((0 <= l_i) /\ (l_i < (l_prt.QuickFind.UNIONFIND.pSize))) /\ ((0 <= r_i) /\ (r_i < (r_prt.QuickUnion.UNIONFIND.pSize))))
           ->
           ((l_i <> l_x) /\ (r_i <> r_x))
           ->
           (l_i = r_i)
           ->
           (let l_id = l_s.id[l_p] in
            let r_id = r_s.id[r_p] in
            ((A.get (l_s.slots[l_id]) l_i) = l_i) <-> ((A.get (r_s.slots[r_id]) r_i) = r_i)))
  
  predicate ufCoupling_aux (l_s: state) (r_s: state) (pi: PreRefperm.t) =
    (okRefperm l_s r_s pi)
      ->
      (PreRefperm.idRgn pi l_s.pool r_s.pool)
      /\
      (forall l_p : reference, r_p : reference.
         (isAllocated l_s l_p)
           ->
           (hasUfindType l_s l_p)
           ->
           (Rgn.mem l_p l_s.pool)
           ->
           (isAllocated r_s r_p)
           ->
           (hasUfindType r_s r_p)
           ->
           (Rgn.mem r_p r_s.pool)
           ->
           (PreRefperm.idRef pi l_p r_p)
           ->
           (samePartition l_s r_s pi l_p r_p)
           /\
           (eqReps l_s r_s pi l_p r_p))
  
  val find (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (l_k: int) (r_self: reference) (r_k: int) : 
    (int, int)
    requires { hasUfindType l_s l_self }
    requires { (l_self <> null) }
    requires { hasUfindType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { (true /\ true) }
    requires { PreRefperm.idRgn pi l_s.pool r_s.pool }
    requires { (l_k = r_k) }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { (((0 <= l_k) /\ (let prt = l_s.part[l_self] in
                                l_k
                                <
                                (prt.QuickFind.UNIONFIND.pSize))) /\
                  ((0 <= r_k) /\ (let prt = r_s.part[r_self] in
                                  r_k
                                  <
                                  (prt.QuickUnion.UNIONFIND.pSize))))
    }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { (true /\ true) }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let id3 = l_s.id[l_self] in
                    ((A.get (l_s.slots[id3]) l_result) = l_result)) /\
                     (let id4 = r_s.id[r_self] in
                      ((A.get (r_s.slots[id4]) r_result) = r_result)))
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  (((0 <= l_result) /\ (let p = l_s.part[l_self] in
                                        l_result
                                        <
                                        (p.QuickFind.UNIONFIND.pSize))) /\
                     ((0 <= r_result) /\ (let p = r_s.part[r_self] in
                                          r_result
                                          <
                                          (p.QuickUnion.UNIONFIND.pSize))))
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let p = l_s.part[l_self] in
                    QuickFind.UNIONFIND.mem l_result (QuickFind.UNIONFIND.pFind l_k p)) /\
                     (let p = r_s.part[r_self] in
                      QuickUnion.UNIONFIND.mem r_result (QuickUnion.UNIONFIND.pFind r_k p)))
              end }
    
    ensures { ((let bsnap_r19 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r19 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r19 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r19 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
  
  val ufUnion (l_s: state) (r_s: state) (pi5: PreRefperm.t) (l_self: reference) (l_x: int) (l_y: int) (r_self: reference) (r_x: int) (r_y: int) : 
    (unit, unit)
    requires { hasUfindType l_s l_self }
    requires { (l_self <> null) }
    requires { hasUfindType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi5 }
    requires { (true /\ true) }
    requires { (l_x = r_x) /\ (l_y = r_y) }
    requires { PreRefperm.idRef pi5 l_self r_self }
    requires { ((agree_allfields l_s r_s pi5 (l_self.singleton)) /\
                  (agree_allfields r_s l_s (pi5.PreRefperm.invert) (r_self.singleton)))
    }
    requires { PreRefperm.idRgn pi5 l_s.pool r_s.pool }
    requires { (((0 <= l_y) /\ (let p = l_s.part[l_self] in
                                l_y
                                <
                                (p.QuickFind.UNIONFIND.pSize))) /\
                  ((0 <= r_y) /\ (let p = r_s.part[r_self] in
                                  r_y
                                  <
                                  (p.QuickUnion.UNIONFIND.pSize))))
    }
    requires { (((0 <= l_x) /\ (let p = l_s.part[l_self] in
                                l_x
                                <
                                (p.QuickFind.UNIONFIND.pSize))) /\
                  ((0 <= r_x) /\ (let p = r_s.part[r_self] in
                                  r_x
                                  <
                                  (p.QuickUnion.UNIONFIND.pSize))))
    }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.part, l_s.slots, l_s.id, l_s.rep, r_s.part, r_s.slots, r_s.id, r_s.rep }
    ensures { [@expl:wr {self}`part] (wr_frame_part (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`id`slots] (wr_frame_slots (old l_s) l_s ((l_s.id[l_self]).singleton)) }
    
    ensures { [@expl:wr {self}`id] (wr_frame_id (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`part] (wr_frame_part (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`id`slots] (wr_frame_slots (old r_s) r_s ((r_s.id[r_self]).singleton)) }
    
    ensures { [@expl:wr {self}`id] (wr_frame_id (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old r_s) r_s (r_self.singleton)) }
    
    ensures { okRefperm l_s r_s pi5 }
    
    ensures { (true /\ true) }
    
    ensures { ((let op = old (l_s.part[l_self]) in
                let p = l_s.part[l_self] in
                (op.QuickFind.UNIONFIND.pSize)
                =
                (p.QuickFind.UNIONFIND.pSize)) /\
                 (let op = old (r_s.part[r_self]) in
                  let p = r_s.part[r_self] in
                  (op.QuickUnion.UNIONFIND.pSize)
                  =
                  (p.QuickUnion.UNIONFIND.pSize))) }
    
    ensures { ((let p = l_s.part[l_self] in
                QuickFind.UNIONFIND.mem l_x (QuickFind.UNIONFIND.pFind l_y p)) /\
                 (let p = r_s.part[r_self] in
                  QuickUnion.UNIONFIND.mem r_x (QuickUnion.UNIONFIND.pFind r_y p))) }
    
    ensures { ((let oid = old (l_s.id[l_self]) in
                (l_s.id[l_self])
                =
                oid) /\
                 (let oid = old (r_s.id[r_self]) in
                  (r_s.id[r_self])
                  =
                  oid)) }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              let l_id = old ((l_s.id[l_self]).singleton) in
              let r_id = old ((r_s.id[r_self]).singleton) in
              let l_o_self = old (l_self.singleton) in
              let r_o_self = old (r_self.singleton) in
              ((agree_allfields l_s r_s pi5 (Rgn.diff l_s.alloct.M.domain (Rgn.union l_s_alloc l_o_self))) /\
                 (agree_allfields r_s l_s (pi5.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain (Rgn.union r_s_alloc r_o_self)))) }
    
    ensures { ((let bsnap_r19 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r19 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r19 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r19 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
end

