module State
  use prelude.Prelude
  use prelude.PreRefperm
  use partition.Partition
  use kruskal_aux.Kruskal_aux
  
  type reftype = 
      | IntArray
      | List
      | Node
      | Ufind
  
  type state = private {
              mutable ghost alloct : M.t reftype;
              mutable id : M.t reference;
              mutable ghost rep : M.t rgn;
              mutable ghost part : M.t partition;
              mutable value : M.t int;
              mutable nxt : M.t reference;
              mutable head : M.t reference;
              mutable ghost lrep : M.t rgn;
              mutable slots : M.t (A.array int);
              mutable length : M.t int;
              mutable ghost pool : rgn
              }
    invariant { not (M.mem null alloct) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = IntArray) ->
              (((M.mem p slots) /\ (M.mem p length)) /\ (((length[p]) >= 0) /\ ((length[p]) = ((slots[p]).A.length)))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = List) ->
              (((M.mem p head) /\ (M.mem p lrep)) /\
                 ((((head[p]) = null) \/ ((M.mem (head[p]) alloct) /\ ((alloct[head[p]]) = Node)))
                    /\
                    (forall q : reference. ((Rgn.mem q (lrep[p])) -> ((q = null) \/ (M.mem q alloct)))))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = Node) ->
              (((M.mem p value) /\ (M.mem p nxt)) /\ (((nxt[p]) = null) \/ ((M.mem (nxt[p]) alloct) /\ ((alloct[nxt[p]]) = Node)))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = Ufind) ->
              (((M.mem p id) /\ (M.mem p rep) /\ (M.mem p part)) /\
                 ((((id[p]) = null) \/ ((M.mem (id[p]) alloct) /\ ((alloct[id[p]]) = IntArray)))
                    /\
                    (forall q : reference. ((Rgn.mem q (rep[p])) -> ((q = null) \/ (M.mem q alloct)))))))) }
    invariant { forall q : reference. ((Rgn.mem q pool) -> ((q = null) \/ (M.mem q alloct))) }
    invariant { not (M.mem null id) }
    invariant { not (M.mem null rep) }
    invariant { not (M.mem null part) }
    invariant { not (M.mem null value) }
    invariant { not (M.mem null nxt) }
    invariant { not (M.mem null head) }
    invariant { not (M.mem null lrep) }
    invariant { not (M.mem null slots) }
    invariant { not (M.mem null length) }
    by
      { alloct = (().M.create) ;
        id = (().M.create) ;
        rep = (().M.create) ;
        part = (().M.create) ;
        value = (().M.create) ;
        nxt = (().M.create) ;
        head = (().M.create) ;
        lrep = (().M.create) ;
        slots = (().M.create) ;
        length = (().M.create) ;
        pool = emptyRgn }
  
  predicate isAllocated (s: state) (p: reference) = M.mem p s.alloct
  
  predicate isValidRgn (s: state) (r: rgn) = forall q : reference. ((Rgn.mem q r) -> ((q = null) \/ (M.mem q s.alloct)))
  
  predicate typeofRgn (s: state) (r: rgn) (types: L.list reftype) =
    forall p : reference. ((Rgn.mem p r) -> ((p = null) \/ ((M.mem p s.alloct) /\ (L.mem (s.alloct[p]) types))))
  
  predicate hasIntArrayType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = IntArray)))
  
  predicate hasListType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = List)))
  
  predicate hasNodeType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Node)))
  
  predicate hasUfindType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Ufind)))
  
  predicate okRefperm (sl: state) (sr: state) (pi: PreRefperm.t) =
    ((forall p : reference. ((M.mem p pi.lor) -> (M.mem p sl.alloct))) /\
       ((forall q : reference. ((M.mem q pi.rol) -> (M.mem q sr.alloct))) /\
          (forall p : reference, q : reference. ((M.mem p pi.lor) -> (((pi.lor[p]) = q) -> ((sl.alloct[p]) = (sr.alloct[q])))))))
  
  val mk_IntArray (s: state) : reference
    writes { s.alloct, s.slots, s.length }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result IntArray (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasIntArrayType s result }
    
    ensures { (s.slots = (M.add result (A.make 0 0) (old s.slots))) }
    
    ensures { (s.length = (M.add result 0 (old s.length))) }
  
  val mk_List (s: state) : reference
    writes { s.alloct, s.head, s.lrep }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result List (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasListType s result }
    
    ensures { (s.head = (M.add result null (old s.head))) }
    
    ensures { (s.lrep = (M.add result emptyRgn (old s.lrep))) }
  
  val mk_Node (s: state) : reference
    writes { s.alloct, s.value, s.nxt }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result Node (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { (s.value = (M.add result 0 (old s.value))) }
    
    ensures { (s.nxt = (M.add result null (old s.nxt))) }
  
  val mk_Ufind (s: state) : reference
    writes { s.alloct, s.id, s.rep, s.part }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result Ufind (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasUfindType s result }
    
    ensures { (s.id = (M.add result null (old s.id))) }
    
    ensures { (s.rep = (M.add result emptyRgn (old s.rep))) }
    
    ensures { (s.part = (M.add result pEmpty (old s.part))) }
  
  val set_pool (s: state) (v: rgn) : unit
    requires { isValidRgn s v }
    writes { s.pool }
    ensures { (s.pool = v) }
  
  val set_id (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasUfindType s o }
    requires { hasIntArrayType s v }
    writes { s.id }
    ensures { (s.id = (M.add o v (old s.id))) }
  
  val set_rep (s: state) (o: reference) (ghost v: rgn) : unit
    requires { (o <> null) }
    requires { hasUfindType s o }
    requires { isValidRgn s v }
    writes { s.rep }
    ensures { (s.rep = (M.add o v (old s.rep))) }
  
  val set_part (s: state) (o: reference) (ghost v: partition) : unit
    requires { (o <> null) }
    requires { hasUfindType s o }
    writes { s.part }
    ensures { (s.part = (M.add o v (old s.part))) }
  
  val set_value (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    writes { s.value }
    ensures { (s.value = (M.add o v (old s.value))) }
  
  val set_nxt (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    requires { hasNodeType s v }
    writes { s.nxt }
    ensures { (s.nxt = (M.add o v (old s.nxt))) }
  
  val set_head (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasListType s o }
    requires { hasNodeType s v }
    writes { s.head }
    ensures { (s.head = (M.add o v (old s.head))) }
  
  val set_lrep (s: state) (o: reference) (ghost v: rgn) : unit
    requires { (o <> null) }
    requires { hasListType s o }
    requires { isValidRgn s v }
    writes { s.lrep }
    ensures { (s.lrep = (M.add o v (old s.lrep))) }
  
  val set_slots (s: state) (o: reference) (v: A.array int) : unit
    requires { (o <> null) }
    requires { hasIntArrayType s o }
    writes { s.slots }
    ensures { (s.slots = (M.add o v (old s.slots))) }
  
  val set_length (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasIntArrayType s o }
    writes { s.length }
    ensures { (s.length = (M.add o v (old s.length))) }
  
  function img_value : state -> (rgn -> rgn)
  
  axiom img_value_ax: forall s : state, r : rgn. ((img_value s r) = emptyRgn)
  
  function img_slots : state -> (rgn -> rgn)
  
  axiom img_slots_ax: forall s : state, r : rgn. ((img_slots s r) = emptyRgn)
  
  function img_rep : state -> (rgn -> rgn)
  
  axiom img_rep_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_rep s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Ufind) /\ ((Rgn.mem q r) /\ (Rgn.mem p (s.rep[q])))))))
  
  function img_part : state -> (rgn -> rgn)
  
  axiom img_part_ax: forall s : state, r : rgn. ((img_part s r) = emptyRgn)
  
  function img_nxt : state -> (rgn -> rgn)
  
  axiom img_nxt_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_nxt s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Node) /\ ((Rgn.mem q r) /\ (p = (s.nxt[q])))))))
  
  function img_lrep : state -> (rgn -> rgn)
  
  axiom img_lrep_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_lrep s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = List) /\ ((Rgn.mem q r) /\ (Rgn.mem p (s.lrep[q])))))))
  
  function img_length : state -> (rgn -> rgn)
  
  axiom img_length_ax: forall s : state, r : rgn. ((img_length s r) = emptyRgn)
  
  function img_id : state -> (rgn -> rgn)
  
  axiom img_id_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_id s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Ufind) /\ ((Rgn.mem q r) /\ (p = (s.id[q])))))))
  
  function img_head : state -> (rgn -> rgn)
  
  axiom img_head_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_head s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = List) /\ ((Rgn.mem q r) /\ (p = (s.head[q])))))))
  
  predicate alloc_does_not_shrink (pre: state) (post: state) =
    forall p : reference. ((M.mem p pre.alloct) -> ((M.mem p post.alloct) /\ ((pre.alloct[p]) = (post.alloct[p]))))
  
  predicate wr_frame_slots (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = IntArray) -> ((not (Rgn.mem p r)) -> ((pre.slots[p]) = (post.slots[p])))))
  
  predicate wr_frame_length (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = IntArray) -> ((not (Rgn.mem p r)) -> ((pre.length[p]) = (post.length[p])))))
  
  predicate wr_frame_head (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = List) -> ((not (Rgn.mem p r)) -> ((pre.head[p]) = (post.head[p])))))
  
  predicate wr_frame_lrep (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = List) -> ((not (Rgn.mem p r)) -> ((pre.lrep[p]) = (post.lrep[p])))))
  
  predicate wr_frame_value (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.value[p]) = (post.value[p])))))
  
  predicate wr_frame_nxt (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.nxt[p]) = (post.nxt[p])))))
  
  predicate wr_frame_id (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Ufind) -> ((not (Rgn.mem p r)) -> ((pre.id[p]) = (post.id[p])))))
  
  predicate wr_frame_rep (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Ufind) -> ((not (Rgn.mem p r)) -> ((pre.rep[p]) = (post.rep[p])))))
  
  predicate wr_frame_part (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Ufind) -> ((not (Rgn.mem p r)) -> ((pre.part[p]) = (post.part[p])))))
  
  predicate agree_value (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.value[o]) = (sr.value[pi.lor[o]])))))))))
  
  predicate agree_slots (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasIntArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.slots[o]) = (sr.slots[pi.lor[o]])))))))))
  
  predicate agree_rep (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasUfindType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRgn pi (sl.rep[o]) (sr.rep[pi.lor[o]])))))))))
  
  predicate agree_part (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasUfindType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.part[o]) = (sr.part[pi.lor[o]])))))))))
  
  predicate agree_nxt (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.nxt[o]) (sr.nxt[pi.lor[o]])))))))))
  
  predicate agree_lrep (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasListType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRgn pi (sl.lrep[o]) (sr.lrep[pi.lor[o]])))))))))
  
  predicate agree_length (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasIntArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.length[o]) = (sr.length[pi.lor[o]])))))))))
  
  predicate agree_id (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasUfindType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.id[o]) (sr.id[pi.lor[o]])))))))))
  
  predicate agree_head (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasListType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.head[o]) (sr.head[pi.lor[o]])))))))))
  
  predicate agree_allfields (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    (agree_slots sl sr pi w)
      /\
      (agree_length sl sr pi w)
      /\
      (agree_head sl sr pi w)
      /\
      (agree_lrep sl sr pi w)
      /\
      (agree_value sl sr pi w)
      /\
      (agree_nxt sl sr pi w)
      /\
      (agree_id sl sr pi w)
      /\
      (agree_rep sl sr pi w)
      /\
      (agree_part sl sr pi w)
end

module MAIN
  use prelude.Prelude
  use State
end

module UNIONFIND
  use prelude.Prelude
  use State
  use export partition.Partition
  
  predicate ufPub (s: state) =
    forall p : reference, q : reference.
      (isAllocated s p)
        ->
        (hasUfindType s p)
        ->
        (Rgn.mem p s.pool)
        ->
        (isAllocated s q)
        ->
        (hasUfindType s q)
        ->
        (Rgn.mem q s.pool)
        ->
        (p <> q)
        ->
        (let prep = s.rep[p] in
         let qrep = s.rep[q] in
         (prep \# qrep) /\ (not (Rgn.mem p qrep)))
  
  val init_Ufind (s: state) (self: reference) (k: int) : unit
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { not (Rgn.mem self s.pool) }
    requires { (s.rep[self]) = emptyRgn }
    requires { k > 0 }
    requires { s.ufPub }
    writes { s.part, s.slots, s.nxt, s.head, s.id, s.rep, s.lrep, s.value, s.length, s.alloct, s.pool }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr ({self} union {self}`rep)`part] (wr_frame_part (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`nxt] (wr_frame_nxt (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`head] (wr_frame_head (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`id] (wr_frame_id (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`lrep] (wr_frame_lrep (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`value] (wr_frame_value (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r28 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r28 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.part[self]) = (k.pMake) }
    
    ensures { let prt = s.part[self] in
              (prt.pSize)
              =
              k }
    
    ensures { Rgn.mem self s.pool }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (s.rep[self]) (Rgn.diff s.alloct.M.domain oa) }
    
    ensures { s.ufPub }
  
  val find (s: state) (self: reference) (k: int) : int
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { (0 <= k) /\ (let p = s.part[self] in
                            k
                            <
                            (p.pSize)) }
    requires { s.ufPub }
    ensures { let bsnap_r28 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r28 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let p = s.part[self] in
              mem result (pFind k p) }
    
    ensures { (0 <= result) /\ (let p = s.part[self] in
                                result
                                <
                                (p.pSize)) }
    
    ensures { s.ufPub }
  
  val ufUnion (s: state) (self: reference) (x: int) (y: int) : unit
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { (0 <= x) /\ (let p = s.part[self] in
                            x
                            <
                            (p.pSize)) }
    requires { (0 <= y) /\ (let p = s.part[self] in
                            y
                            <
                            (p.pSize)) }
    requires { s.ufPub }
    writes { s.part, s.slots, s.nxt, s.head, s.id, s.rep, s.lrep, s.value, s.length }
    ensures { (result = ()) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`part] (wr_frame_part (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`nxt] (wr_frame_nxt (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`head] (wr_frame_head (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`id] (wr_frame_id (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`lrep] (wr_frame_lrep (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`value] (wr_frame_value (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r28 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r28 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let p = s.part[self] in
              mem x (pFind y p) }
    
    ensures { let op = old (s.part[self]) in
              let p = s.part[self] in
              (op.pSize)
              =
              (p.pSize) }
    
    ensures { let orep = old (s.rep[self]) in
              (s.rep[self])
              =
              orep }
    
    ensures { s.ufPub }
end

module QuickFind
  use prelude.Prelude
  use State
  use UNIONFIND
  
  predicate ufInv (s: state) (p: reference) =
    (hasUfindType s p)
      ->
      (p <> null)
      /\
      (let id1 = s.id[p] in
       (id1 <> null)
         /\
         (let len = s.length[id1] in
          let prt = s.part[p] in
          (len = (prt.UNIONFIND.pSize))
            /\
            ((s.rep[p]) = (id1.singleton))
            /\
            (forall x : int. ((0 <= x) /\ (x < len)) -> (let idx = A.get (s.slots[id1]) x in
                                                         (0 <= idx) /\ (idx < len)))
            /\
            (forall x : int. ((0 <= x) /\ (x < len)) -> (let idx = A.get (s.slots[id1]) x in
                                                         ((A.get (s.slots[id1]) idx) = idx)))
            /\
            (forall x : int, y : int.
               ((0 <= x) /\ (x < len))
                 ->
                 ((0 <= y) /\ (y < len))
                 ->
                 (let idx = A.get (s.slots[id1]) x in
                  let idy = A.get (s.slots[id1]) y in
                  (UNIONFIND.mem y (UNIONFIND.pFind x prt)) <-> (idx = idy)))))
  
  predicate ufPriv (s: state) = forall p : reference. (isAllocated s p) -> (hasUfindType s p) -> (Rgn.mem p s.pool) -> (ufInv s p)
  
  lemma qfind1:
    forall s : state.
      forall p : reference, x : int.
        (isAllocated s p)
          ->
          (hasUfindType s p)
          ->
          (Rgn.mem p s.pool)
          ->
          (s.ufPriv)
          ->
          (let prt = s.part[p] in
           let id1 = s.id[p] in
           ((0 <= x) /\ (x < (prt.UNIONFIND.pSize))) -> (let idx = A.get (s.slots[id1]) x in
                                                         UNIONFIND.mem idx (UNIONFIND.pFind x prt)))
  
  lemma qfind2:
    forall s : state.
      forall p : reference, x : int, i : int.
        (isAllocated s p)
          ->
          (hasUfindType s p)
          ->
          (Rgn.mem p s.pool)
          ->
          (s.ufPriv)
          ->
          (let prt = s.part[p] in
           let id1 = s.id[p] in
           ((0 <= x) /\ (x < (prt.UNIONFIND.pSize)))
             ->
             ((0 <= i) /\ (i < (prt.UNIONFIND.pSize)))
             ->
             (UNIONFIND.mem i (UNIONFIND.pFind x prt))
             ->
             ((A.get (s.slots[id1]) i) = i)
             ->
             ((A.get (s.slots[id1]) x) = i))
  
  let init_Ufind (s : state) (self : reference) (k : int) : unit
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { not (Rgn.mem self s.pool) }
    requires { (s.rep[self]) = emptyRgn }
    requires { k > 0 }
    requires { s.UNIONFIND.ufPub }
    requires { s.ufPriv }
    writes { s.alloct, s.id, s.length, s.part, s.pool, s.rep, s.slots }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr ({self} union {self}`rep)`part] (wr_frame_part (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`id] (wr_frame_id (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.part[self]) = (k.UNIONFIND.pMake) }
    
    ensures { let prt = s.part[self] in
              (prt.UNIONFIND.pSize)
              =
              k }
    
    ensures { Rgn.mem self s.pool }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (s.rep[self]) (Rgn.diff s.alloct.M.domain oa) }
    
    ensures { s.UNIONFIND.ufPub }
    
    ensures { s.ufPriv }
    diverges
  = label INIT in
      let result = ref () in
      let self = ref self in
      let k = ref k in
      let i = ref 0 in
      let prt = ref null in
      assert { hasIntArrayType s (! prt) };
      assert { s.ufPriv };
      (prt := ([@expl:prt := new(IntArray){k}] (s.mk_IntArray)));
      ([@expl:prt := new(IntArray){k}] (set_length s (! prt) (! k)));
      ([@expl:prt := new(IntArray){k}] (set_slots s (! prt) (A.make (! k) 0)));
      (i := ([@expl:i := 0] 0));
      assert { s.ufPriv };
      assert {
        forall p : reference.
          (isAllocated s p) -> (hasUfindType s p) -> (Rgn.mem p s.pool) -> (p <> (! self)) -> (not ((s.id[p]) = (! prt))) };
      while ((! i) < (! k)) do
        invariant { [@expl:locals type invariant] ((hasIntArrayType s (! prt)) /\ (hasUfindType s (! self))) }
        invariant { alloc_does_not_shrink (old s) s }
        invariant { [@expl:wr {prt}`slots] (wr_frame_slots (old s) s ((! prt).singleton)) }
        invariant { let s1 = s.slots[! prt] in
                    (s1.A.length)
                    =
                    (! k) }
        invariant {
          forall p : reference.
            (isAllocated s p) -> (hasUfindType s p) -> (Rgn.mem p s.pool) -> (p <> (! self)) -> (not ((s.id[p]) = (! prt))) }
        invariant { (0 <= (! i)) /\ ((! i) <= (! k)) }
        invariant { forall j : int. (0 <= j) -> (j < (! i)) -> ((A.get (s.slots[! prt]) j) = j) }
        invariant { s.ufPriv }
        invariant { s.UNIONFIND.ufPub }
        (set_slots s (! prt) ([@expl:prt.{i} := i] (A.set (s.slots[! prt]) (! i) (! i))));
        (i := ([@expl:i := i + 1] ((! i) + 1)))
      done;
      ([@expl:self.id := prt] (set_id s (! self) (! prt)));
      ([@expl:self.part := pMake(k)] (set_part s (! self) ((! k).UNIONFIND.pMake)));
      (let ghost rep2 = ref emptyRgn in
       assert { isValidRgn s (! rep2) };
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (rep2 := ([@expl:rep := self.rep] (s.rep[! self])));
       ([@expl:self.rep := rep union {prt}] (set_rep s (! self) (Rgn.union (! rep2) ((! prt).singleton))));
       assert { ufInv s (! self) };
       assert { s.UNIONFIND.ufPub };
       (set_pool s ([@expl:pool := pool union {self}] (Rgn.union s.pool ((! self).singleton))));
       (! result))
  
  let find (s : state) (self : reference) (k : int) : int
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { (0 <= k) /\ (let p = s.part[self] in
                            k
                            <
                            (p.UNIONFIND.pSize)) }
    requires { s.UNIONFIND.ufPub }
    requires { s.ufPriv }
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let p = s.part[self] in
              UNIONFIND.mem result (UNIONFIND.pFind k p) }
    
    ensures { (0 <= result) /\ (let p = s.part[self] in
                                result
                                <
                                (p.UNIONFIND.pSize)) }
    
    ensures { s.UNIONFIND.ufPub }
    
    ensures { let id1 = s.id[self] in
              ((A.get (s.slots[id1]) result) = result) }
    
    ensures { s.ufPriv }
  = label INIT in
      let result = ref 0 in
      let self = ref self in
      let k = ref k in
      let id2 = ref null in
      assert { hasIntArrayType s (! id2) };
      assert {
        (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
          \/
          (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
          \/
          ((! self) = null) };
      (id2 := ([@expl:id := self.id] (s.id[! self])));
      assert {
        (Rgn.mem (! id2) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
          \/
          (not (Rgn.mem (! id2) (s.alloct.M.domain at INIT)))
          \/
          ((! id2) = null) };
      (result := ([@expl:result := id.{k}] (A.get (s.slots[! id2]) (! k))));
      (! result)
  
  let ufUnion (s : state) (self : reference) (x : int) (y : int) : unit
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { (0 <= x) /\ (let p = s.part[self] in
                            x
                            <
                            (p.UNIONFIND.pSize)) }
    requires { (0 <= y) /\ (let p = s.part[self] in
                            y
                            <
                            (p.UNIONFIND.pSize)) }
    requires { s.UNIONFIND.ufPub }
    requires { s.ufPriv }
    writes { s.part, s.slots }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`part] (wr_frame_part (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let p = s.part[self] in
              UNIONFIND.mem x (UNIONFIND.pFind y p) }
    
    ensures { let op = old (s.part[self]) in
              let p = s.part[self] in
              (op.UNIONFIND.pSize)
              =
              (p.UNIONFIND.pSize) }
    
    ensures { let orep = old (s.rep[self]) in
              (s.rep[self])
              =
              orep }
    
    ensures { s.UNIONFIND.ufPub }
    
    ensures { s.ufPriv }
    diverges
  = label INIT in
      let result = ref () in
      let self = ref self in
      let x = ref x in
      let y = ref y in
      let ina = ref null in
      assert { hasIntArrayType s (! ina) };
      (let xroot = ref 0 in
       let yroot = ref 0 in
       let ghost sid = ref (A.make 0 0) in
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (ina := ([@expl:ina := self.id] (s.id[! self])));
       assert {
         (Rgn.mem (! ina) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! ina) (s.alloct.M.domain at INIT)))
           \/
           ((! ina) = null) };
       (sid := ([@expl:sid := ina.slots] (s.slots[! ina])));
       assert {
         Rgn.subset
            (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
            (Rgn.union
                ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
       (xroot := ([@expl:xroot := find(self,x)] (find s (! self) (! x))));
       assert {
         Rgn.subset
            (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
            (Rgn.union
                ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
       (yroot := ([@expl:yroot := find(self,y)] (find s (! self) (! y))));
       (if (not ((! xroot) = (! yroot))) then
          (assert { ufInv s (! self) };
           (let ghost prt = ref (any partition) in
            assert {
              (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                \/
                (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
                \/
                ((! self) = null) };
            (prt := ([@expl:prt := self.part] (s.part[! self])));
            ([@expl:self.part := pUnion(prt,pFind(x,prt),pFind(y,prt))]
             (set_part s (! self) (UNIONFIND.pUnion (! prt) (UNIONFIND.pFind (! x) (! prt)) (UNIONFIND.pFind (! y) (! prt)))));
            (let i = ref 0 in
             let len = ref 0 in
             (i := ([@expl:i := 0] 0));
             assert {
               (Rgn.mem (! ina) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                 \/
                 (not (Rgn.mem (! ina) (s.alloct.M.domain at INIT)))
                 \/
                 ((! ina) = null) };
             (len := ([@expl:len := ina.length] (s.length[! ina])));
             assert { forall j : int. ((0 <= j) /\ (j < (! len))) -> ((A.get (s.slots[! ina]) j) = (A.get (! sid) j)) };
             while ((! i) < (! len)) do
               invariant { [@expl:locals type invariant] ((hasIntArrayType s (! ina)) /\ (hasUfindType s (! self))) }
               invariant { alloc_does_not_shrink (old s) s }
               invariant { [@expl:wr {ina}`slots] (wr_frame_slots (old s) s ((! ina).singleton)) }
               invariant { forall j : int. (((! i) <= j) /\ (j < (! len))) -> ((A.get (s.slots[! ina]) j) = (A.get (! sid) j)) }
               invariant { (0 <= (! i)) /\ ((! i) <= (! len)) }
               invariant {
                 forall j : int.
                   ((0 <= j) /\ (j < (! i)))
                     ->
                     (let prt1 = s.part[! self] in
                      (UNIONFIND.mem j (UNIONFIND.pFind (! x) prt1)) -> ((A.get (s.slots[! ina]) j) = (! yroot))) }
               invariant {
                 forall j : int, k2 : int.
                   let prt3 = s.part[! self] in
                   ((0 <= j) /\ (j < (! i)))
                     ->
                     ((0 <= k2) /\ (k2 < (! i)))
                     ->
                     (UNIONFIND.mem j (UNIONFIND.pFind k2 prt3))
                     ->
                     (let inaj = A.get (s.slots[! ina]) j in
                      ((A.get (s.slots[! ina]) k2) = inaj)) }
               invariant {
                 forall j : int.
                   ((0 <= j) /\ (j < (! len))) -> ((A.get (! sid) j) <> (! xroot)) -> ((A.get (s.slots[! ina]) j) = (A.get (! sid) j)) }
               invariant {
                 forall j : int.
                   ((0 <= j) /\ (j < (! i))) -> ((A.get (! sid) j) = (! xroot)) -> ((A.get (s.slots[! ina]) j) = (! yroot)) }
               invariant {
                 forall j : int.
                   ((0 <= j) /\ (j < (! i)))
                     ->
                     (let inaj = A.get (s.slots[! ina]) j in
                      let prt4 = s.part[! self] in
                      (not (UNIONFIND.mem j (UNIONFIND.pFind (! x) prt4)))
                        ->
                        (UNIONFIND.mem j (UNIONFIND.pFind j prt4))
                        /\
                        (inaj = (A.get (! sid) j))
                        /\
                        ((A.get (s.slots[! ina]) inaj) = inaj)) }
               let inai = ref 0 in
               assert {
                 (Rgn.mem (! ina) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                   \/
                   (not (Rgn.mem (! ina) (s.alloct.M.domain at INIT)))
                   \/
                   ((! ina) = null) };
               (inai := ([@expl:inai := ina.{i}] (A.get (s.slots[! ina]) (! i))));
               (if ((! inai) = (! xroot)) then
                  (assert { (A.get (! sid) (! i)) = (! xroot) };
                   (set_slots s (! ina) ([@expl:ina.{i} := yroot] (A.set (s.slots[! ina]) (! i) (! yroot)))))
                else assert { (A.get (! sid) (! i)) <> (! xroot) });
               (i := ([@expl:i := i + 1] ((! i) + 1)))
             done;
             assert { (! i) = (! len) };
             assert { ufInv s (! self) })))
        else ());
       (! result))
  
  lemma boundary_frames_invariant_QuickFind:
    forall s : state, t : state, pi : PreRefperm.t.
      (okRefperm s t pi)
        ->
        (PreRefperm.identity pi s.alloct.M.domain t.alloct.M.domain)
        ->
        (PreRefperm.idRgn pi s.pool t.pool)
        ->
        (agree_allfields s t pi (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (s.ufPriv)
        ->
        (t.ufPriv)
end

module QuickUnion
  use prelude.Prelude
  use State
  use UNIONFIND
  
  predicate ufInv (s: state) (p: reference) =
    (hasUfindType s p)
      ->
      (p <> null)
      /\
      (let id1 = s.id[p] in
       (id1 <> null)
         /\
         (let len = s.length[id1] in
          let prt = s.part[p] in
          (len = (prt.UNIONFIND.pSize))
            /\
            ((s.rep[p]) = (id1.singleton))
            /\
            (forall x : int. ((0 <= x) /\ (x < len)) -> (let idx = A.get (s.slots[id1]) x in
                                                         (0 <= idx) /\ (idx < len)))
            /\
            (forall x : int. ((0 <= x) /\ (x < len)) -> (let idx = A.get (s.slots[id1]) x in
                                                         UNIONFIND.mem idx (UNIONFIND.pFind x prt)))))
  
  predicate ufPriv (s: state) = forall p : reference. (isAllocated s p) -> (hasUfindType s p) -> (Rgn.mem p s.pool) -> (ufInv s p)
  
  let init_Ufind (s : state) (self : reference) (k : int) : unit
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { not (Rgn.mem self s.pool) }
    requires { (s.rep[self]) = emptyRgn }
    requires { k > 0 }
    requires { s.UNIONFIND.ufPub }
    requires { s.ufPriv }
    writes { s.alloct, s.id, s.length, s.part, s.pool, s.rep, s.slots }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr ({self} union {self}`rep)`part] (wr_frame_part (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`id] (wr_frame_id (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r10 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r10 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.part[self]) = (k.UNIONFIND.pMake) }
    
    ensures { let prt = s.part[self] in
              (prt.UNIONFIND.pSize)
              =
              k }
    
    ensures { Rgn.mem self s.pool }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (s.rep[self]) (Rgn.diff s.alloct.M.domain oa) }
    
    ensures { s.UNIONFIND.ufPub }
    
    ensures { s.ufPriv }
    diverges
  = label INIT in
      let result = ref () in
      let self = ref self in
      let k = ref k in
      let i = ref 0 in
      let ina = ref null in
      assert { hasIntArrayType s (! ina) };
      (ina := ([@expl:ina := new(IntArray){k}] (s.mk_IntArray)));
      ([@expl:ina := new(IntArray){k}] (set_length s (! ina) (! k)));
      ([@expl:ina := new(IntArray){k}] (set_slots s (! ina) (A.make (! k) 0)));
      (i := ([@expl:i := 0] 0));
      while ((! i) < (! k)) do
        invariant { [@expl:locals type invariant] ((hasIntArrayType s (! ina)) /\ (hasUfindType s (! self))) }
        invariant { alloc_does_not_shrink (old s) s }
        invariant { [@expl:wr {ina}`slots] (wr_frame_slots (old s) s ((! ina).singleton)) }
        invariant { (0 <= (! i)) /\ ((! i) <= (! k)) }
        invariant { forall j : int. (0 <= j) -> (j < (! i)) -> ((A.get (s.slots[! ina]) j) = j) }
        (set_slots s (! ina) ([@expl:ina.{i} := i] (A.set (s.slots[! ina]) (! i) (! i))));
        (i := ([@expl:i := i + 1] ((! i) + 1)))
      done;
      ([@expl:self.id := ina] (set_id s (! self) (! ina)));
      ([@expl:self.part := pMake(k)] (set_part s (! self) ((! k).UNIONFIND.pMake)));
      (let ghost rep1 = ref emptyRgn in
       assert { isValidRgn s (! rep1) };
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (rep1 := ([@expl:rep := self.rep] (s.rep[! self])));
       ([@expl:self.rep := rep union {ina}] (set_rep s (! self) (Rgn.union (! rep1) ((! ina).singleton))));
       (set_pool s ([@expl:pool := pool union {self}] (Rgn.union s.pool ((! self).singleton))));
       (! result))
  
  let find (s : state) (self : reference) (k : int) : int
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { (0 <= k) /\ (let p = s.part[self] in
                            k
                            <
                            (p.UNIONFIND.pSize)) }
    requires { s.UNIONFIND.ufPub }
    requires { s.ufPriv }
    ensures { let bsnap_r10 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r10 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let p = s.part[self] in
              UNIONFIND.mem result (UNIONFIND.pFind k p) }
    
    ensures { (0 <= result) /\ (let p = s.part[self] in
                                result
                                <
                                (p.UNIONFIND.pSize)) }
    
    ensures { s.UNIONFIND.ufPub }
    
    ensures { let id1 = s.id[self] in
              ((A.get (s.slots[id1]) result) = result) }
    
    ensures { s.ufPriv }
    diverges
  = label INIT in
      let result = ref 0 in
      let self = ref self in
      let k = ref k in
      let id2 = ref null in
      assert { hasIntArrayType s (! id2) };
      (let idy = ref 0 in
       let y = ref 0 in
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (id2 := ([@expl:id := self.id] (s.id[! self])));
       (y := ([@expl:y := k] (! k)));
       assert {
         (Rgn.mem (! id2) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! id2) (s.alloct.M.domain at INIT)))
           \/
           ((! id2) = null) };
       (idy := ([@expl:idy := id.{y}] (A.get (s.slots[! id2]) (! y))));
       while not ((! y) = (! idy)) do
         invariant { [@expl:locals type invariant] ((hasIntArrayType s (! id2)) /\ (hasUfindType s (! self))) }
         invariant { alloc_does_not_shrink (old s) s }
         invariant { (0 <= (! y)) /\ (let prt = s.part[! self] in
                                      (! y)
                                      <
                                      (prt.UNIONFIND.pSize)) }
         invariant { let prt = s.part[! self] in
                     UNIONFIND.mem (! y) (UNIONFIND.pFind (! k) prt) }
         invariant { ufInv s (! self) }
         invariant { ((A.get (s.slots[! id2]) (! y)) = (! idy)) }
         assert {
           (Rgn.mem (! id2) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! id2) (s.alloct.M.domain at INIT)))
             \/
             ((! id2) = null) };
         (y := ([@expl:y := id.{y}] (A.get (s.slots[! id2]) (! y))));
         assert {
           (Rgn.mem (! id2) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! id2) (s.alloct.M.domain at INIT)))
             \/
             ((! id2) = null) };
         (idy := ([@expl:idy := id.{y}] (A.get (s.slots[! id2]) (! y))))
       done;
       (result := ([@expl:result := y] (! y)));
       (! result))
  
  let ufUnion (s : state) (self : reference) (x : int) (y : int) : unit
    requires { hasUfindType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { (0 <= x) /\ (let p = s.part[self] in
                            x
                            <
                            (p.UNIONFIND.pSize)) }
    requires { (0 <= y) /\ (let p = s.part[self] in
                            y
                            <
                            (p.UNIONFIND.pSize)) }
    requires { s.UNIONFIND.ufPub }
    requires { s.ufPriv }
    writes { s.part, s.slots }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`part] (wr_frame_part (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { let bsnap_r10 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r10 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let p = s.part[self] in
              UNIONFIND.mem x (UNIONFIND.pFind y p) }
    
    ensures { let op = old (s.part[self]) in
              let p = s.part[self] in
              (op.UNIONFIND.pSize)
              =
              (p.UNIONFIND.pSize) }
    
    ensures { let orep = old (s.rep[self]) in
              (s.rep[self])
              =
              orep }
    
    ensures { s.UNIONFIND.ufPub }
    
    ensures { s.ufPriv }
    diverges
  = label INIT in
      let result = ref () in
      let self = ref self in
      let x = ref x in
      let y = ref y in
      let ina = ref null in
      assert { hasIntArrayType s (! ina) };
      (let xroot = ref 0 in
       let yroot = ref 0 in
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (ina := ([@expl:ina := self.id] (s.id[! self])));
       assert {
         Rgn.subset
            (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
            (Rgn.union
                ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
       (xroot := ([@expl:xroot := find(self,x)] (find s (! self) (! x))));
       assert {
         Rgn.subset
            (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
            (Rgn.union
                ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
       (yroot := ([@expl:yroot := find(self,y)] (find s (! self) (! y))));
       (if (not ((! xroot) = (! yroot))) then
          (let ghost prt = ref (any partition) in
           assert {
             (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
               \/
               (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
               \/
               ((! self) = null) };
           (prt := ([@expl:prt := self.part] (s.part[! self])));
           ([@expl:self.part := pUnion(prt,pFind(x,prt),pFind(y,prt))]
            (set_part s (! self) (UNIONFIND.pUnion (! prt) (UNIONFIND.pFind (! x) (! prt)) (UNIONFIND.pFind (! y) (! prt)))));
           (set_slots s (! ina) ([@expl:ina.{xroot} := yroot] (A.set (s.slots[! ina]) (! xroot) (! yroot)))))
        else ());
       (! result))
  
  lemma boundary_frames_invariant_QuickUnion:
    forall s : state, t : state, pi : PreRefperm.t.
      (okRefperm s t pi)
        ->
        (PreRefperm.identity pi s.alloct.M.domain t.alloct.M.domain)
        ->
        (PreRefperm.idRgn pi s.pool t.pool)
        ->
        (agree_allfields s t pi (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (s.ufPriv)
        ->
        (t.ufPriv)
end

module UFREL
  use prelude.Prelude
  use State
  use QuickFind
  use QuickUnion
  use export partition.Partition
  
  predicate samePartition (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_p: reference) (r_p: reference) =
    (okRefperm l_s r_s pi)
      ->
      (hasUfindType l_s l_p)
      ->
      (hasUfindType r_s r_p)
      ->
      (let l_prt = l_s.part[l_p] in
       let r_prt = r_s.part[r_p] in
       ((l_prt.QuickFind.UNIONFIND.pSize) = (r_prt.QuickUnion.UNIONFIND.pSize)) /\ (pEq l_prt r_prt))
  
  predicate eqReps (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_p: reference) (r_p: reference) =
    (okRefperm l_s r_s pi)
      ->
      (hasUfindType l_s l_p)
      ->
      (hasUfindType r_s r_p)
      ->
      (let l_prt = l_s.part[l_p] in
       let r_prt = r_s.part[r_p] in
       forall l_i : int, r_i : int.
         (((0 <= l_i) /\ (l_i < (l_prt.QuickFind.UNIONFIND.pSize))) /\ ((0 <= r_i) /\ (r_i < (r_prt.QuickUnion.UNIONFIND.pSize))))
           ->
           (l_i = r_i)
           ->
           (let l_id = l_s.id[l_p] in
            let r_id = r_s.id[r_p] in
            ((A.get (l_s.slots[l_id]) l_i) = l_i) <-> ((A.get (r_s.slots[r_id]) r_i) = r_i)))
  
  predicate eqRepsExcept (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_p: reference) (l_x: int) (r_p: reference) (r_x: int) =
    (okRefperm l_s r_s pi)
      ->
      (hasUfindType l_s l_p)
      ->
      (hasUfindType r_s r_p)
      ->
      (let l_prt = l_s.part[l_p] in
       let r_prt = r_s.part[r_p] in
       forall l_i : int, r_i : int.
         (((0 <= l_i) /\ (l_i < (l_prt.QuickFind.UNIONFIND.pSize))) /\ ((0 <= r_i) /\ (r_i < (r_prt.QuickUnion.UNIONFIND.pSize))))
           ->
           ((l_i <> l_x) /\ (r_i <> r_x))
           ->
           (l_i = r_i)
           ->
           (let l_id = l_s.id[l_p] in
            let r_id = r_s.id[r_p] in
            ((A.get (l_s.slots[l_id]) l_i) = l_i) <-> ((A.get (r_s.slots[r_id]) r_i) = r_i)))
  
  predicate ufCoupling_aux (l_s: state) (r_s: state) (pi: PreRefperm.t) =
    (okRefperm l_s r_s pi)
      ->
      (PreRefperm.idRgn pi l_s.pool r_s.pool)
      /\
      (forall l_p : reference, r_p : reference.
         (isAllocated l_s l_p)
           ->
           (hasUfindType l_s l_p)
           ->
           (Rgn.mem l_p l_s.pool)
           ->
           (isAllocated r_s r_p)
           ->
           (hasUfindType r_s r_p)
           ->
           (Rgn.mem r_p r_s.pool)
           ->
           (PreRefperm.idRef pi l_p r_p)
           ->
           (samePartition l_s r_s pi l_p r_p)
           /\
           (eqReps l_s r_s pi l_p r_p))
  
  predicate ufCoupling (l_s: state) (r_s: state) (pi: PreRefperm.t) =
    (okRefperm l_s r_s pi)
      ->
      ((l_s.QuickFind.UNIONFIND.ufPub) /\ (r_s.QuickUnion.UNIONFIND.ufPub))
      /\
      ((l_s.QuickFind.ufPriv) /\ (r_s.QuickUnion.ufPriv))
      /\
      (ufCoupling_aux l_s r_s pi)
  
  let find (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_self : reference) (l_k : int) (r_self : reference) (r_k : int) : 
    (int, int)
    requires { hasUfindType l_s l_self }
    requires { (l_self <> null) }
    requires { hasUfindType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { ufCoupling l_s r_s pi }
    requires { PreRefperm.idRgn pi l_s.pool r_s.pool }
    requires { (l_k = r_k) }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { (((0 <= l_k) /\ (let prt = l_s.part[l_self] in
                                l_k
                                <
                                (prt.QuickFind.UNIONFIND.pSize))) /\
                  ((0 <= r_k) /\ (let prt = r_s.part[r_self] in
                                  r_k
                                  <
                                  (prt.QuickUnion.UNIONFIND.pSize))))
    }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { ufCoupling l_s r_s pi }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let id1 = l_s.id[l_self] in
                    ((A.get (l_s.slots[id1]) l_result) = l_result)) /\
                     (let id2 = r_s.id[r_self] in
                      ((A.get (r_s.slots[id2]) r_result) = r_result)))
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  (((0 <= l_result) /\ (let p = l_s.part[l_self] in
                                        l_result
                                        <
                                        (p.QuickFind.UNIONFIND.pSize))) /\
                     ((0 <= r_result) /\ (let p = r_s.part[r_self] in
                                          r_result
                                          <
                                          (p.QuickUnion.UNIONFIND.pSize))))
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let p = l_s.part[l_self] in
                    QuickFind.UNIONFIND.mem l_result (QuickFind.UNIONFIND.pFind l_k p)) /\
                     (let p = r_s.part[r_self] in
                      QuickUnion.UNIONFIND.mem r_result (QuickUnion.UNIONFIND.pFind r_k p)))
              end }
    
    ensures { ((let bsnap_r19 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r19 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r19 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r19 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    diverges
  = label INIT in
      let r_result = ref 0 in
      let l_result = ref 0 in
      let l_self = ref l_self in
      let l_k = ref l_k in
      let r_self = ref r_self in
      let r_k = ref r_k in
      (let id3 = ref null in
       assert { hasIntArrayType l_s (! id3) };
       (id3 := ([@expl:id := self.id] (l_s.id[! l_self])));
       (l_result := ([@expl:result := id.{k}] (A.get (l_s.slots[! id3]) (! l_k)))));
      (let id4 = ref null in
       assert { hasIntArrayType r_s (! id4) };
       (let idy = ref 0 in
        let y5 = ref 0 in
        (id4 := ([@expl:id := self.id] (r_s.id[! r_self])));
        (y5 := ([@expl:y := k] (! r_k)));
        (idy := ([@expl:idy := id.{y}] (A.get (r_s.slots[! id4]) (! y5))));
        while not ((! y5) = (! idy)) do
          invariant { [@expl:locals type invariant] ((hasIntArrayType r_s (! id4)) /\ (hasUfindType r_s (! r_self))) }
          invariant { alloc_does_not_shrink (old r_s) r_s }
          invariant { (0 <= (! y5)) /\ (let prt = r_s.part[! r_self] in
                                        (! y5)
                                        <
                                        (prt.QuickUnion.UNIONFIND.pSize)) }
          invariant { let prt = r_s.part[! r_self] in
                      QuickUnion.UNIONFIND.mem (! y5) (QuickUnion.UNIONFIND.pFind (! r_k) prt) }
          invariant { QuickUnion.ufInv r_s (! r_self) }
          invariant { ((A.get (r_s.slots[! id4]) (! y5)) = (! idy)) }
          (y5 := ([@expl:y := id.{y}] (A.get (r_s.slots[! id4]) (! y5))));
          (idy := ([@expl:idy := id.{y}] (A.get (r_s.slots[! id4]) (! y5))))
        done;
        (r_result := ([@expl:result := y] (! y5)));
        ((! l_result), (! r_result))))
  
  let ufUnion (l_s : state) (r_s : state) (pi6 : PreRefperm.t) (l_self : reference) (l_x : int) (l_y : int) (r_self : reference) (r_x : int) (r_y : int) : 
    (unit, unit)
    requires { hasUfindType l_s l_self }
    requires { (l_self <> null) }
    requires { hasUfindType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi6 }
    requires { ufCoupling l_s r_s pi6 }
    requires { (l_x = r_x) /\ (l_y = r_y) }
    requires { PreRefperm.idRef pi6 l_self r_self }
    requires { ((agree_allfields l_s r_s pi6 (l_self.singleton)) /\
                  (agree_allfields r_s l_s (pi6.PreRefperm.invert) (r_self.singleton)))
    }
    requires { PreRefperm.idRgn pi6 l_s.pool r_s.pool }
    requires { (((0 <= l_y) /\ (let p = l_s.part[l_self] in
                                l_y
                                <
                                (p.QuickFind.UNIONFIND.pSize))) /\
                  ((0 <= r_y) /\ (let p = r_s.part[r_self] in
                                  r_y
                                  <
                                  (p.QuickUnion.UNIONFIND.pSize))))
    }
    requires { (((0 <= l_x) /\ (let p = l_s.part[l_self] in
                                l_x
                                <
                                (p.QuickFind.UNIONFIND.pSize))) /\
                  ((0 <= r_x) /\ (let p = r_s.part[r_self] in
                                  r_x
                                  <
                                  (p.QuickUnion.UNIONFIND.pSize))))
    }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.part, l_s.slots, r_s.part, r_s.slots }
    ensures { [@expl:wr {self}`part] (wr_frame_part (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`id`slots] (wr_frame_slots (old l_s) l_s ((l_s.id[l_self]).singleton)) }
    
    ensures { [@expl:wr {self}`part] (wr_frame_part (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`id`slots] (wr_frame_slots (old r_s) r_s ((r_s.id[r_self]).singleton)) }
    
    ensures { okRefperm l_s r_s pi6 }
    
    ensures { ufCoupling l_s r_s pi6 }
    
    ensures { ((let op = old (l_s.part[l_self]) in
                let p = l_s.part[l_self] in
                (op.QuickFind.UNIONFIND.pSize)
                =
                (p.QuickFind.UNIONFIND.pSize)) /\
                 (let op = old (r_s.part[r_self]) in
                  let p = r_s.part[r_self] in
                  (op.QuickUnion.UNIONFIND.pSize)
                  =
                  (p.QuickUnion.UNIONFIND.pSize))) }
    
    ensures { ((let p = l_s.part[l_self] in
                QuickFind.UNIONFIND.mem l_x (QuickFind.UNIONFIND.pFind l_y p)) /\
                 (let p = r_s.part[r_self] in
                  QuickUnion.UNIONFIND.mem r_x (QuickUnion.UNIONFIND.pFind r_y p))) }
    
    ensures { ((let oid = old (l_s.id[l_self]) in
                (l_s.id[l_self])
                =
                oid) /\
                 (let oid = old (r_s.id[r_self]) in
                  (r_s.id[r_self])
                  =
                  oid)) }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              let l_id = old ((l_s.id[l_self]).singleton) in
              let r_id = old ((r_s.id[r_self]).singleton) in
              let l_o_self = old (l_self.singleton) in
              let r_o_self = old (r_self.singleton) in
              ((agree_allfields l_s r_s pi6 (Rgn.diff l_s.alloct.M.domain (Rgn.union l_s_alloc l_o_self))) /\
                 (agree_allfields r_s l_s (pi6.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain (Rgn.union r_s_alloc r_o_self)))) }
    
    ensures { ((let bsnap_r19 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r19 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r19 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r19 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
    diverges
  = label INIT in
      let r_result = ref () in
      let l_result = ref () in
      let l_self = ref l_self in
      let l_x = ref l_x in
      let l_y = ref l_y in
      let r_self = ref r_self in
      let r_x = ref r_x in
      let r_y = ref r_y in
      let l_ina = ref null in
      let r_ina = ref null in
      let l_xroot = ref 0 in
      let r_xroot = ref 0 in
      let l_yroot = ref 0 in
      let r_yroot = ref 0 in
      let ghost l_sid = ref (A.make 0 0) in
      let ghost r_sid = ref (A.make 0 0) in
      (l_ina := ([@expl:ina := self.id] (l_s.id[! l_self])));
      (r_ina := ([@expl:ina := self.id] (r_s.id[! r_self])));
      assert {
        ((forall p : reference.
            (isAllocated l_s p) -> (hasUfindType l_s p) -> (Rgn.mem p l_s.pool) -> (p <> (! l_self)) -> (not ((l_s.id[p]) = (! l_ina)))) /\
           (forall p : reference.
              (isAllocated r_s p)
                ->
                (hasUfindType r_s p)
                ->
                (Rgn.mem p r_s.pool)
                ->
                (p <> (! r_self))
                ->
                (not ((r_s.id[p]) = (! r_ina))))) };
      (l_sid := ([@expl:sid := ina.slots] (l_s.slots[! l_ina])));
      (match find l_s r_s pi6 (! l_self) (! l_x) (! r_self) (! r_x) with
       | (l_find_res, r_find_res) ->
           (l_xroot := ([@expl:xroot := find(self,x)] l_find_res));
           (r_xroot := ([@expl:xroot := find(self,x)] r_find_res))
       end);
      (match find l_s r_s pi6 (! l_self) (! l_y) (! r_self) (! r_y) with
       | (l_find_res, r_find_res) ->
           (l_yroot := ([@expl:yroot := find(self,y)] l_find_res));
           (r_yroot := ([@expl:yroot := find(self,y)] r_find_res))
       end);
      ([@expl:guard agreement] assert { (((! l_xroot) <> (! l_yroot)) = ((! r_xroot) <> (! r_yroot))) });
      (if (not ((! l_xroot) = (! l_yroot))) then
         (assert { eqReps l_s r_s pi6 (! l_self) (! r_self) };
          assert { eqRepsExcept l_s r_s pi6 (! l_self) (! l_xroot) (! r_self) (! r_xroot) };
          (let ghost l_prt = ref (any partition) in
           let ghost r_prt = ref (any partition) in
           (l_prt := ([@expl:prt := self.part] (l_s.part[! l_self])));
           (r_prt := ([@expl:prt := self.part] (r_s.part[! r_self])));
           ([@expl:self.part := pUnion(prt,pFind(x,prt),pFind(y,prt))]
            (set_part
               l_s
               (! l_self)
               (QuickFind.UNIONFIND.pUnion
                   (! l_prt)
                   (QuickFind.UNIONFIND.pFind (! l_x) (! l_prt))
                   (QuickFind.UNIONFIND.pFind (! l_y) (! l_prt)))));
           ([@expl:self.part := pUnion(prt,pFind(x,prt),pFind(y,prt))]
            (set_part
               r_s
               (! r_self)
               (QuickUnion.UNIONFIND.pUnion
                   (! r_prt)
                   (QuickUnion.UNIONFIND.pFind (! r_x) (! r_prt))
                   (QuickUnion.UNIONFIND.pFind (! r_y) (! r_prt)))));
           assert { samePartition l_s r_s pi6 (! l_self) (! r_self) };
           (let l_i = ref 0 in
            let r_i = ref 0 in
            let l_len = ref 0 in
            let r_len = ref 0 in
            (l_i := ([@expl:i := 0] 0));
            (l_len := ([@expl:len := ina.length] (l_s.length[! l_ina])));
            assert {
              forall l_p : reference, r_p : reference.
                (isAllocated l_s l_p)
                  ->
                  (hasUfindType l_s l_p)
                  ->
                  (Rgn.mem l_p l_s.pool)
                  ->
                  (isAllocated r_s r_p)
                  ->
                  (hasUfindType r_s r_p)
                  ->
                  (Rgn.mem r_p r_s.pool)
                  ->
                  ((l_p <> (! l_self)) /\ (r_p <> (! r_self)))
                  ->
                  (PreRefperm.idRef pi6 l_p r_p)
                  ->
                  (samePartition l_s r_s pi6 l_p r_p)
                  /\
                  (eqReps l_s r_s pi6 l_p r_p) };
            while ((! l_i) < (! l_len)) do
              invariant { [@expl:locals type invariant] ((hasIntArrayType l_s (! l_ina)) /\ (hasUfindType l_s (! l_self))) }
              invariant { alloc_does_not_shrink (old l_s) l_s }
              invariant { [@expl:wr {ina}`slots] (wr_frame_slots (old l_s) l_s ((! l_ina).singleton)) }
              invariant { forall j : int. (((! l_i) <= j) /\ (j < (! l_len))) -> ((A.get (l_s.slots[! l_ina]) j) = (A.get (! l_sid) j)) }
              invariant { (0 <= (! l_i)) /\ ((! l_i) <= (! l_len)) }
              invariant {
                forall j : int.
                  ((0 <= j) /\ (j < (! l_i)))
                    ->
                    (QuickFind.UNIONFIND.mem j (QuickFind.UNIONFIND.pFind (! l_x) (! l_prt)))
                    ->
                    ((A.get (l_s.slots[! l_ina]) j) = (! l_yroot)) }
              invariant {
                forall j : int, k7 : int.
                  ((0 <= j) /\ (j < (! l_i)))
                    ->
                    ((0 <= k7) /\ (k7 < (! l_i)))
                    ->
                    (QuickFind.UNIONFIND.mem j (QuickFind.UNIONFIND.pFind k7 (! l_prt)))
                    ->
                    (let inaj = A.get (l_s.slots[! l_ina]) j in
                     ((A.get (l_s.slots[! l_ina]) k7) = inaj)) }
              invariant {
                forall j : int.
                  ((0 <= j) /\ (j < (! l_i))) -> ((A.get (! l_sid) j) = (! l_xroot)) -> ((A.get (l_s.slots[! l_ina]) j) = (! l_yroot)) }
              invariant {
                forall j : int.
                  ((0 <= j) /\ (j < (! l_len)))
                    ->
                    ((A.get (! l_sid) j) <> (! l_xroot))
                    ->
                    ((A.get (l_s.slots[! l_ina]) j) = (A.get (! l_sid) j)) }
              invariant {
                forall j : int.
                  ((0 <= j) /\ (j < (! l_i)))
                    ->
                    (let inaj = A.get (l_s.slots[! l_ina]) j in
                     (not (QuickFind.UNIONFIND.mem j (QuickFind.UNIONFIND.pFind (! l_x) (! l_prt))))
                       ->
                       (QuickFind.UNIONFIND.mem j (QuickFind.UNIONFIND.pFind j (! l_prt)))
                       /\
                       (inaj = (A.get (! l_sid) j))
                       /\
                       ((A.get (l_s.slots[! l_ina]) inaj) = inaj)) }
              invariant {
                forall p : reference.
                  (isAllocated l_s p)
                    ->
                    (hasUfindType l_s p)
                    ->
                    (Rgn.mem p l_s.pool)
                    ->
                    (p <> (! l_self))
                    ->
                    (not ((l_s.id[p]) = (! l_ina))) }
              let inai = ref 0 in
              (inai := ([@expl:inai := ina.{i}] (A.get (l_s.slots[! l_ina]) (! l_i))));
              (if ((! inai) = (! l_xroot)) then
                 (assert { (A.get (! l_sid) (! l_i)) = (! l_xroot) };
                  (set_slots l_s (! l_ina) ([@expl:ina.{i} := yroot] (A.set (l_s.slots[! l_ina]) (! l_i) (! l_yroot)))))
               else assert { (A.get (! l_sid) (! l_i)) <> (! l_xroot) });
              (l_i := ([@expl:i := i + 1] ((! l_i) + 1)));
              assume {
                forall j : int.
                  ((0 <= j) /\ (j < (! l_i)))
                    ->
                    (let inaj = A.get (l_s.slots[! l_ina]) j in
                     (not (QuickFind.UNIONFIND.mem j (QuickFind.UNIONFIND.pFind (! l_x) (! l_prt))))
                       ->
                       (QuickFind.UNIONFIND.mem j (QuickFind.UNIONFIND.pFind j (! l_prt)))
                       /\
                       (inaj = (A.get (! l_sid) j))
                       /\
                       ((A.get (l_s.slots[! l_ina]) inaj) = inaj)) }
            done;
            assert {
              forall p : reference.
                (isAllocated r_s p)
                  ->
                  (hasUfindType r_s p)
                  ->
                  (Rgn.mem p r_s.pool)
                  ->
                  (p <> (! r_self))
                  ->
                  (not ((r_s.id[p]) = (! r_ina))) };
            (set_slots r_s (! r_ina) ([@expl:ina.{xroot} := yroot] (A.set (r_s.slots[! r_ina]) (! r_xroot) (! r_yroot))));
            assert { eqReps l_s r_s pi6 (! l_self) (! r_self) };
            assert {
              forall l_p : reference, r_p : reference.
                (isAllocated l_s l_p)
                  ->
                  (hasUfindType l_s l_p)
                  ->
                  (Rgn.mem l_p l_s.pool)
                  ->
                  (isAllocated r_s r_p)
                  ->
                  (hasUfindType r_s r_p)
                  ->
                  (Rgn.mem r_p r_s.pool)
                  ->
                  ((l_p <> (! l_self)) /\ (r_p <> (! r_self)))
                  ->
                  (PreRefperm.idRef pi6 l_p r_p)
                  ->
                  (samePartition l_s r_s pi6 l_p r_p)
                  /\
                  (eqReps l_s r_s pi6 l_p r_p) })))
       else ());
      assert { eqReps l_s r_s pi6 (! l_self) (! r_self) };
      assume {
        ((l_s.QuickFind.UNIONFIND.ufPub) /\ (r_s.QuickUnion.UNIONFIND.ufPub)) /\ ((l_s.QuickFind.ufPriv) /\ (r_s.QuickUnion.ufPriv)) };
      ((! l_result), (! r_result))
  
  lemma boundary_frames_coupling_UFREL:
    forall s : state, t : state, s' : state, t' : state, pi : PreRefperm.t, pi' : PreRefperm.t, rho : PreRefperm.t.
      (okRefperm s t pi)
        ->
        (okRefperm s' t' pi')
        ->
        (PreRefperm.identity pi s.alloct.M.domain t.alloct.M.domain)
        ->
        (PreRefperm.identity pi' s'.alloct.M.domain t'.alloct.M.domain)
        ->
        (okRefperm s s' rho)
        ->
        (okRefperm t t' rho)
        ->
        (PreRefperm.idRgn pi s.pool t.pool)
        ->
        (agree_allfields s t pi (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (PreRefperm.idRgn pi' s'.pool t'.pool)
        ->
        (agree_allfields s' t' pi' (Rgn.union s'.pool (img_rep s' s'.pool)))
        ->
        (ufCoupling s s' rho)
        ->
        (ufCoupling t t' rho)
  
  lemma ufCoupling_is_refperm_monotonic:
    forall s : state, t : state, pi : PreRefperm.t.
      ((okRefperm s t pi) ->
         ((ufCoupling s t pi) ->
            (forall rho : PreRefperm.t. ((okRefperm s t rho) -> ((PreRefperm.extends pi rho) -> (ufCoupling s t rho))))))
end

module Main
  use prelude.Prelude
  use State
  use MAIN
  use UNIONFIND
  use export kruskal_aux.Kruskal_aux
  
  predicate lrep_closed (s: state) (xs: reference) =
    (hasListType s xs)
      ->
      (xs <> null)
      ->
      (let hd = s.head[xs] in
       let lrep1 = s.lrep[xs] in
       (typeofRgn s lrep1 (L.Cons Node L.Nil)) /\ (Rgn.subset (img_nxt s lrep1) lrep1) /\ (Rgn.mem null lrep1) /\ (Rgn.mem hd lrep1))
  
  let init_Node (s : state) (self : reference) (v : int) (n : reference) : 
    unit
    requires { hasNodeType s self }
    requires { (self <> null) }
    requires { hasNodeType s n }
    requires { not (Rgn.mem self (Rgn.union s.pool (img_rep s s.pool))) }
    requires { (s.nxt[self]) = null }
    writes { s.nxt, s.value }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`nxt] (wr_frame_nxt (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`value] (wr_frame_value (old s) s (self.singleton)) }
    
    ensures { (s.nxt[self]) = n }
    
    ensures { (s.value[self]) = v }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let v = ref v in
      let n = ref n in
      assert { not (Rgn.mem (! self) (Rgn.union s.pool (img_rep s s.pool))) };
      ([@expl:self.nxt := n] (set_nxt s (! self) (! n)));
      assert { not (Rgn.mem (! self) (Rgn.union s.pool (img_rep s s.pool))) };
      ([@expl:self.value := v] (set_value s (! self) (! v)));
      (! result)
  
  let init_List (s : state) (self : reference) : unit
    requires { hasListType s self }
    requires { (self <> null) }
    requires { not (Rgn.mem self (Rgn.union s.pool (img_rep s s.pool))) }
    writes { s.head, s.lrep }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`lrep] (wr_frame_lrep (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`head] (wr_frame_head (old s) s (self.singleton)) }
    
    ensures { (s.head[self]) = null }
    
    ensures { (s.lrep[self]) = (null.singleton) }
    
    ensures { lrep_closed s self }
  = label INIT in
      let result = ref () in
      let self = ref self in
      assert { not (Rgn.mem (! self) (Rgn.union s.pool (img_rep s s.pool))) };
      ([@expl:self.lrep := {null}] (set_lrep s (! self) (null.singleton)));
      assert { not (Rgn.mem (! self) (Rgn.union s.pool (img_rep s s.pool))) };
      ([@expl:self.head := null] (set_head s (! self) null));
      (! result)
  
  let main (s : state) (g : graph) : reference
    requires { (g.numVertices) > 0 }
    requires { s.pool = emptyRgn }
    writes { s.alloct, s.head, s.id, s.length, s.lrep, s.nxt, s.part, s.pool, s.rep, s.slots, s.value }
    ensures { (result <> null) }
    
    ensures { hasListType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr (pool union pool`rep)`part] (wr_frame_part (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`slots] (wr_frame_slots (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`nxt] (wr_frame_nxt (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`id] (wr_frame_id (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`rep] (wr_frame_rep (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`lrep] (wr_frame_lrep (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`value] (wr_frame_value (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`length] (wr_frame_length (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { true }
    diverges
  = label INIT in
      let result = ref null in
      let g = ref g in
      let uf = ref null in
      assert { hasUfindType s (! uf) };
      (let es = ref (A.make 0 (any edge)) in
       (es := ([@expl:es := edges(g)] ((! g).edges)));
       (let nverts = ref 0 in
        (nverts := ([@expl:nverts := numVertices(g)] ((! g).numVertices)));
        (uf := ([@expl:uf := new Ufind] (s.mk_Ufind)));
        assert {
          Rgn.subset
             (Rgn.diff (Rgn.union ((! uf).singleton) (s.rep[! uf])) (null.singleton))
             (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
        ([@expl:Ufind(uf,nverts)] (UNIONFIND.init_Ufind s (! uf) (! nverts)));
        assert { let prt = s.part[! uf] in
                 (! nverts)
                 =
                 (prt.UNIONFIND.pSize) };
        (let l = ref null in
         assert { hasListType s (! l) };
         (l := ([@expl:l := new List] (s.mk_List)));
         assert {
           (Rgn.mem (! l) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
             \/
             (not (Rgn.mem (! l) (s.alloct.M.domain at INIT)))
             \/
             ((! l) = null) };
         ([@expl:List(l)] (init_List s (! l)));
         assert { not (Rgn.mem (! l) (Rgn.union s.pool (img_rep s s.pool))) };
         (let i = ref 0 in
          while ((! i) < ((! es).numEdges)) do
            invariant { [@expl:locals type invariant] ((hasListType s (! l)) /\ (hasListType s (! result)) /\ (hasUfindType s (! uf))) }
            invariant { alloc_does_not_shrink (old s) s }
            invariant {
              [@expl:wr ({uf} union {uf}`rep union {l}`lrep)`part]
              (wr_frame_part (old s) s (Rgn.union ((! uf).singleton) (Rgn.union (s.rep[! uf]) (s.lrep[! l])))) }
            invariant { [@expl:wr ({uf}`rep union {l}`lrep)`slots] (wr_frame_slots (old s) s (Rgn.union (s.rep[! uf]) (s.lrep[! l]))) }
            invariant { [@expl:wr ({uf}`rep union {l}`lrep)`nxt] (wr_frame_nxt (old s) s (Rgn.union (s.rep[! uf]) (s.lrep[! l]))) }
            invariant { [@expl:wr ({uf}`rep union {l}`lrep)`head] (wr_frame_head (old s) s (Rgn.union (s.rep[! uf]) (s.lrep[! l]))) }
            invariant {
              [@expl:wr ({uf}`rep union {l} union {l}`lrep)`lrep]
              (wr_frame_lrep (old s) s (Rgn.union (s.rep[! uf]) (Rgn.union ((! l).singleton) (s.lrep[! l])))) }
            invariant { [@expl:wr ({uf}`rep union {l}`lrep)`value] (wr_frame_value (old s) s (Rgn.union (s.rep[! uf]) (s.lrep[! l]))) }
            invariant { s.UNIONFIND.ufPub }
            invariant { (0 <= (! i)) /\ ((! i) <= ((! es).numEdges)) }
            invariant { let prt = s.part[! uf] in
                        (! nverts)
                        =
                        (prt.UNIONFIND.pSize) }
            invariant { let s_alloc = old s.alloct.M.domain in
                        let lrep1 = s.lrep[! l] in
                        lrep1 \# s_alloc }
            invariant { not (Rgn.mem (! l) (Rgn.union s.pool (img_rep s s.pool))) }
            invariant { Rgn.mem (! uf) s.pool }
            invariant { let s_alloc = old s.alloct.M.domain in
                        Rgn.subset (s.rep[! uf]) (Rgn.diff s.alloct.M.domain s_alloc) }
            let curredge = ref (any edge) in
            let startv = ref 0 in
            let endv = ref 0 in
            (curredge := ([@expl:curredge := get(es,i)] (A.get (! es) (! i))));
            (startv := ([@expl:startv := startVertex(curredge)] ((! curredge).startVertex)));
            (endv := ([@expl:endv := endVertex(curredge)] ((! curredge).endVertex)));
            (let srepr = ref 0 in
             let erepr = ref 0 in
             assert {
               Rgn.subset
                  (Rgn.diff (Rgn.union ((! uf).singleton) (s.rep[! uf])) (null.singleton))
                  (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
             (srepr := ([@expl:srepr := find(uf,startv)] (UNIONFIND.find s (! uf) (! startv))));
             assert {
               Rgn.subset
                  (Rgn.diff (Rgn.union ((! uf).singleton) (s.rep[! uf])) (null.singleton))
                  (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
             (erepr := ([@expl:erepr := find(uf,endv)] (UNIONFIND.find s (! uf) (! endv))));
             (if (not ((! srepr) = (! erepr))) then
                (assert { not (Rgn.mem (! l) (Rgn.union s.pool (img_rep s s.pool))) };
                 assert {
                   Rgn.subset
                      (Rgn.diff (Rgn.union ((! uf).singleton) (s.rep[! uf])) (null.singleton))
                      (Rgn.union
                          ((Rgn.union s.pool (img_rep s s.pool)) at INIT)
                          (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
                 ([@expl:ufUnion(uf,startv,endv)] (UNIONFIND.ufUnion s (! uf) (! startv) (! endv)));
                 assert { not (Rgn.mem (! l) s.pool) };
                 assert { not (Rgn.mem (! l) (img_rep s s.pool)) };
                 (let p = ref null in
                  assert { hasNodeType s (! p) };
                  (p := ([@expl:p := new Node] (s.mk_Node)));
                  (let hd = ref null in
                   assert { hasNodeType s (! hd) };
                   assert { not (Rgn.mem (! l) (Rgn.union s.pool (img_rep s s.pool))) };
                   assert {
                     (Rgn.mem (! l) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                       \/
                       (not (Rgn.mem (! l) (s.alloct.M.domain at INIT)))
                       \/
                       ((! l) = null) };
                   (hd := ([@expl:hd := l.head] (s.head[! l])));
                   assert {
                     (Rgn.mem (! p) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                       \/
                       (not (Rgn.mem (! p) (s.alloct.M.domain at INIT)))
                       \/
                       ((! p) = null) };
                   ([@expl:Node(p,i,hd)] (init_Node s (! p) (! i) (! hd)));
                   assert { (s.nxt[! p]) = (! hd) };
                   assert { not (Rgn.mem (! l) (Rgn.union s.pool (img_rep s s.pool))) };
                   ([@expl:l.head := p] (set_head s (! l) (! p)));
                   (let ghost lr = ref emptyRgn in
                    assert { isValidRgn s (! lr) };
                    assert { not (Rgn.mem (! l) (Rgn.union s.pool (img_rep s s.pool))) };
                    assert {
                      (Rgn.mem (! l) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                        \/
                        (not (Rgn.mem (! l) (s.alloct.M.domain at INIT)))
                        \/
                        ((! l) = null) };
                    (lr := ([@expl:lr := l.lrep] (s.lrep[! l])));
                    assert { not (Rgn.mem (! l) (Rgn.union s.pool (img_rep s s.pool))) };
                    ([@expl:l.lrep := lr union {p}] (set_lrep s (! l) (Rgn.union (! lr) ((! p).singleton))))))))
              else ());
             (i := ([@expl:i := i + 1] ((! i) + 1))))
          done;
          (result := ([@expl:result := l] (! l)));
          (! result)))))
end

module Main_Link
  use prelude.Prelude
  use State
  use Main
  use UFREL
  
  lemma ufPub_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph.
            ((((l_g.Main.numVertices) > 0) -> (l_s.pool = emptyRgn) -> (l_s.Main.UNIONFIND.ufPub)) /\
               (((r_g.Main.numVertices) > 0) -> (r_s.pool = emptyRgn) -> (r_s.Main.UNIONFIND.ufPub)))))
  
  lemma left_ufPriv_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph. ((l_g.Main.numVertices) > 0) -> (l_s.pool = emptyRgn) -> (l_s.UFREL.QuickFind.ufPriv)))
  
  lemma right_ufPriv_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph. ((r_g.Main.numVertices) > 0) -> (r_s.pool = emptyRgn) -> (r_s.UFREL.QuickUnion.ufPriv)))
  
  lemma ufCoupling_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph.
            (((l_g.Main.numVertices) > 0) /\ ((r_g.Main.numVertices) > 0))
              ->
              ((l_s.pool = emptyRgn) /\ (r_s.pool = emptyRgn))
              ->
              (l_g = r_g)
              ->
              ((agree_length
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_length
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_value
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_value
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_lrep
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_lrep
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_rep l_s r_s pi (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_rep
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_id l_s r_s pi (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_id
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_head
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_head
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_nxt l_s r_s pi (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_nxt
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_slots
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_slots
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              ((agree_part
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_part
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
              ->
              (ufCoupling l_s r_s pi)))
  
  val main (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_g: graph) (r_g: graph) : 
    (reference, reference)
    requires { okRefperm l_s r_s pi }
    requires { ((agree_part
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_part
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_slots
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_slots
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_nxt
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_nxt
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_head
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_head
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_id l_s r_s pi (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_id
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_rep
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_rep
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_lrep
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_lrep
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_value
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_value
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_length
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_length
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { (l_g = r_g) }
    requires { ((l_s.pool = emptyRgn) /\ (r_s.pool = emptyRgn)) }
    requires { (((l_g.Main.numVertices) > 0) /\ ((r_g.Main.numVertices) > 0)) }
    writes { l_s.part,
      l_s.slots,
      l_s.nxt,
      l_s.head,
      l_s.id,
      l_s.rep,
      l_s.lrep,
      l_s.value,
      l_s.length,
      l_s.pool,
      l_s.alloct,
      r_s.part,
      r_s.slots,
      r_s.nxt,
      r_s.head,
      r_s.id,
      r_s.rep,
      r_s.lrep,
      r_s.value,
      r_s.length,
      r_s.pool,
      r_s.alloct }
    ensures { match result with
              | (l_result, _) -> hasListType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasListType r_s r_result
              end }
    
    ensures { [@expl:wr (pool union pool`rep)`part] (wr_frame_part (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`slots] (wr_frame_slots (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`nxt] (wr_frame_nxt (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`id] (wr_frame_id (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`lrep] (wr_frame_lrep (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`value] (wr_frame_value (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`length] (wr_frame_length (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr (pool union pool`rep)`part] (wr_frame_part (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`slots] (wr_frame_slots (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`nxt] (wr_frame_nxt (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`id] (wr_frame_id (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`lrep] (wr_frame_lrep (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`value] (wr_frame_value (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`length] (wr_frame_length (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { let l_s_alloc0 = old l_s.alloct.M.domain in
              let r_s_alloc0 = old r_s.alloct.M.domain in
              let l_snap_r9 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
              let r_snap_r9 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
              ((agree_length
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc0) l_snap_r9) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_length
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff
                        (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc0) r_snap_r9)
                        (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_value
                    l_s
                    r_s
                    pi
                    (Rgn.diff
                        (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc0) l_snap_r9)
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_value
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc0) r_snap_r9)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
