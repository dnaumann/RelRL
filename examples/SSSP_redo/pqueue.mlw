  let decreaseKey (s : state) (self : reference) (handle : reference) (k : int) : 
    unit
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { hasNodeType s handle }
    requires { (handle <> null) }
    requires { Rgn.mem self s.pool }
    requires { let rep1 = s.rep[self] in
