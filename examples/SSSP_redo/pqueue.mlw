      r_s.slots }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr {}`slots] (wr_frame_slots (old l_s) l_s emptyRgn) }
    
    ensures { [@expl:wr {}`length] (wr_frame_length (old l_s) l_s emptyRgn) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { [@expl:wr {}`slots] (wr_frame_slots (old r_s) r_s emptyRgn) }
    
    ensures { [@expl:wr {}`length] (wr_frame_length (old r_s) r_s emptyRgn) }
    
    ensures { okRefperm l_s r_s pi20 }
    
    ensures { pqueueR l_s r_s pi20 }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { ((let rep21 = l_s.rep[l_self] in
                forall n : reference.
                  (isAllocated l_s n)
                    ->
                    (hasNodeType l_s n)
                    ->
                    (Rgn.mem n rep21)
                    ->
                    (let otag = old (l_s.tag[n]) in
                     let okey = old (l_s.key[n]) in
                     ((l_s.tag[n]) = otag) /\ ((l_s.key[n]) = okey))) /\
                 (let rep22 = r_s.rep[r_self] in
                  forall n : reference.
                    (isAllocated r_s n)
                      ->
                      (hasNodeType r_s n)
                      ->
                      (Rgn.mem n rep22)
                      ->
                      (let otag = old (r_s.tag[n]) in
                       let okey = old (r_s.key[n]) in
                       ((r_s.tag[n]) = otag) /\ ((r_s.key[n]) = okey)))) }
    
    ensures { ((let orep = old (l_s.rep[l_self]) in
                (l_s.rep[l_self])
                =
                orep) /\
                 (let orep = old (r_s.rep[r_self]) in
                  (r_s.rep[r_self])
                  =
                  orep)) }
    
    ensures { ((let osz = old (l_s.size[l_self]) in
                (l_s.size[l_self])
                =
                osz
                -
                1) /\
                 (let osz = old (r_s.size[r_self]) in
                  (r_s.size[r_self])
                  =
                  osz
                  -
                  1)) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi20 l_result r_result
              end }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  = label INIT in
      let r_result = ref null in
      let l_result = ref null in
      let l_self = ref l_self in
      let r_self = ref r_self in
      (match findMin l_s r_s pi20 (! l_self) (! r_self) with
       | (l_findMin_res, r_findMin_res) ->
           (l_result := ([@expl:result := findMin(self)] l_findMin_res));
           (r_result := ([@expl:result := findMin(self)] r_findMin_res))
       end);
      (let l_tmp = ref null in
       let r_tmp = ref null in
       let l_sntl = ref null in
       let r_sntl = ref null in
       (r_sntl := ([@expl:sntl := self.sntl] (r_s.sntl[! r_self])));
       (l_tmp := ([@expl:tmp := self.head] (l_s.head[! l_self])));
       (r_tmp := ([@expl:tmp := self.head] (r_s.head[! r_self])));
       (l_tmp := ([@expl:tmp := tmp.child] (l_s.child[! l_tmp])));
       (r_tmp := ([@expl:tmp := tmp.child] (r_s.child[! r_tmp])));
       ([@expl:guard agreement] assert { (((! l_tmp) = null) = ((! r_tmp) = (! r_sntl))) });
       (if ((! l_tmp) =. null) then
          (assume { (((l_s.size[! l_self]) = 1) /\ ((r_s.size[! r_self]) = 1)) };
           ([@expl:self.head := null] (set_head l_s (! l_self) null));
           ([@expl:self.head := sntl] (set_head r_s (! r_self) (! r_sntl))))
        else
          (assume { ((let sz = l_s.size[! l_self] in
                      sz
                      >
                      1) /\ (let sz = r_s.size[! r_self] in
                             sz
                             >
                             1)) };
           (match combine l_s r_s pi20 (! l_self) (! l_tmp) (! r_self) (! r_tmp) with
            | (l_combine_res, r_combine_res) ->
                (l_tmp := ([@expl:tmp := combine(self,tmp)] l_combine_res));
                (r_tmp := ([@expl:tmp := combine(self,tmp)] r_combine_res))
            end);
           ([@expl:self.head := tmp] (set_head l_s (! l_self) (! l_tmp)));
           ([@expl:self.head := tmp] (set_head r_s (! r_self) (! r_tmp)))));
       (let l_sz = ref 0 in
        let r_sz = ref 0 in
        (l_sz := ([@expl:sz := self.size] (l_s.size[! l_self])));
        (r_sz := ([@expl:sz := self.size] (r_s.size[! r_self])));
        ([@expl:self.size := sz - 1] (set_size l_s (! l_self) ((! l_sz) - 1)));
        ([@expl:self.size := sz - 1] (set_size r_s (! r_self) ((! r_sz) - 1)));
        assume { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) };
        ((! l_result), (! r_result))))
  
  let decreaseKey (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_self : reference) (l_handle : reference) (l_k : int) (r_self : reference) (r_handle : reference) (r_k : int) : 
    (unit, unit)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasNodeType l_s l_handle }
    requires { (l_handle <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { hasNodeType r_s r_handle }
    requires { (r_handle <> null) }
    requires { okRefperm l_s r_s pi }
    requires { pqueueR l_s r_s pi }
    requires { (l_k = r_k) }
    requires { PreRefperm.idRef pi l_handle r_handle }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((let sz = l_s.size[l_self] in
                 sz
                 >
                 0) /\ (let sz = r_s.size[r_self] in
                        sz
                        >
                        0)) }
    requires { ((let key23 = l_s.key[l_handle] in
                 l_k
                 <=
                 key23) /\ (let key24 = r_s.key[r_handle] in
                            r_k
                            <=
                            key24)) }
    requires { ((let rep25 = l_s.rep[l_self] in
                 Rgn.mem l_handle rep25) /\ (let rep26 = r_s.rep[r_self] in
                                             Rgn.mem r_handle rep26)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.child, l_s.head, l_s.key, l_s.prev, l_s.sibling, r_s.child, r_s.head, r_s.key, r_s.prev, r_s.sibling }
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { pqueueR l_s r_s pi }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { (((l_s.key[l_handle]) = l_k) /\ ((r_s.key[r_handle]) = r_k)) }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
  = label INIT in
      let r_result = ref () in
      let l_result = ref () in
      let l_self = ref l_self in
      let l_handle = ref l_handle in
      let l_k = ref l_k in
      let r_self = ref r_self in
      let r_handle = ref r_handle in
      let r_k = ref r_k in
      let l_tmp = ref null in
      let r_tmp = ref null in
      let l_pos = ref null in
      let r_pos = ref null in
      let l_sntl = ref null in
      let r_sntl = ref null in
      (r_sntl := ([@expl:sntl := self.sntl] (r_s.sntl[! r_self])));
      ([@expl:handle.key := k] (set_key l_s (! l_handle) (! l_k)));
      ([@expl:handle.key := k] (set_key r_s (! r_handle) (! r_k)));
      (l_tmp := ([@expl:tmp := self.head] (l_s.head[! l_self])));
      (r_tmp := ([@expl:tmp := self.head] (r_s.head[! r_self])));
      ([@expl:guard agreement] assert { (((! l_handle) <> (! l_tmp)) = ((! r_handle) <> (! r_tmp))) });
      (if ((! l_handle) <>. (! l_tmp)) then
         ((l_tmp := ([@expl:tmp := handle.sibling] (l_s.sibling[! l_handle])));
          (r_tmp := ([@expl:tmp := handle.sibling] (r_s.sibling[! r_handle])));
          ([@expl:guard agreement] assert { (((! l_tmp) <> null) = ((! r_tmp) <> (! r_sntl))) });
          (if ((! l_tmp) <>. null) then
             ((l_pos := ([@expl:pos := handle.prev] (l_s.prev[! l_handle])));
              (r_pos := ([@expl:pos := handle.prev] (r_s.prev[! r_handle])));
              ([@expl:tmp.prev := pos] (set_prev l_s (! l_tmp) (! l_pos)));
              ([@expl:tmp.prev := pos] (set_prev r_s (! r_tmp) (! r_pos))))
           else ());
          (l_tmp := ([@expl:tmp := handle.prev] (l_s.prev[! l_handle])));
          (r_tmp := ([@expl:tmp := handle.prev] (r_s.prev[! r_handle])));
          ([@expl:guard agreement] assert { (((! l_tmp) <> null) = ((! r_tmp) <> (! r_sntl))) });
          (if ((! l_tmp) <>. null) then
             ((l_pos := ([@expl:pos := tmp.child] (l_s.child[! l_tmp])));
              (r_pos := ([@expl:pos := tmp.child] (r_s.child[! r_tmp])));
              assert {
                ((not ((l_s.prev[! l_handle]) = null)) /\ (not ((r_s.prev[! r_handle]) = null)))
                  /\
                  (not ((r_s.prev[! r_handle]) = (! r_sntl))) };
              assert { (PreRefperm.idRef pi (! l_tmp) (! r_tmp)) /\ ((! l_tmp) <> null) /\ ((! r_tmp) <> (! r_sntl)) };
              assert {
                let l_c = l_s.child[! l_tmp] in
                let r_c = r_s.child[! r_tmp] in
                ((PreRefperm.idRef pi l_c r_c) /\ (l_c <> null) /\ (r_c <> (! r_sntl))) \/ (l_c = null) /\ (r_c = (! r_sntl)) };
              ([@expl:guard agreement] assert { (((! l_pos) = (! l_handle)) = ((! r_pos) = (! r_handle))) });
              (if ((! l_pos) =. (! l_handle)) then
                 ((l_pos := ([@expl:pos := handle.sibling] (l_s.sibling[! l_handle])));
                  (r_pos := ([@expl:pos := handle.sibling] (r_s.sibling[! r_handle])));
                  ([@expl:tmp.child := pos] (set_child l_s (! l_tmp) (! l_pos)));
                  ([@expl:tmp.child := pos] (set_child r_s (! r_tmp) (! r_pos))))
               else
                 ((l_pos := ([@expl:pos := handle.sibling] (l_s.sibling[! l_handle])));
                  (r_pos := ([@expl:pos := handle.sibling] (r_s.sibling[! r_handle])));
                  ([@expl:tmp.sibling := pos] (set_sibling l_s (! l_tmp) (! l_pos)));
                  ([@expl:tmp.sibling := pos] (set_sibling r_s (! r_tmp) (! r_pos)))));
              assert { coupling0 l_s r_s pi (! l_self) (! r_self) })
           else ());
          ([@expl:handle.sibling := null] (set_sibling l_s (! l_handle) null));
          ([@expl:handle.sibling := sntl] (set_sibling r_s (! r_handle) (! r_sntl)));
          (l_pos := ([@expl:pos := self.head] (l_s.head[! l_self])));
          (r_pos := ([@expl:pos := self.head] (r_s.head[! r_self])));
          assume {
            (((l_s.PqueueL.PQUEUE.pqueuePub) /\ (l_s.PqueueL.pqueueI)) /\ ((r_s.PqueueR.PQUEUE.pqueuePub) /\ (r_s.PqueueR.pqueueI))) };
          (match link l_s r_s pi (! l_self) (! l_pos) (! l_handle) (! r_self) (! r_pos) (! r_handle) with
           | (l_link_res, r_link_res) ->
               (l_tmp := ([@expl:tmp := link(self,pos,handle)] l_link_res));
               (r_tmp := ([@expl:tmp := link(self,pos,handle)] r_link_res))
           end);
          ([@expl:self.head := tmp] (set_head l_s (! l_self) (! l_tmp)));
          ([@expl:self.head := tmp] (set_head r_s (! r_self) (! r_tmp))))
       else ());
      assume {
        (((l_s.PqueueL.PQUEUE.pqueuePub) /\ (l_s.PqueueL.pqueueI)) /\ ((r_s.PqueueR.PQUEUE.pqueuePub) /\ (r_s.PqueueR.pqueueI))) };
      ((! l_result), (! r_result))
  
  lemma boundary_frames_coupling_PQUEUE_REL:
    forall s : state, t27 : state, s' : state, t' : state, pi28 : PreRefperm.t, pi' : PreRefperm.t, rho : PreRefperm.t.
      (okRefperm s t27 pi28)
        ->
        (okRefperm s' t' pi')
        ->
        (PreRefperm.identity pi28 s.alloct.M.domain t27.alloct.M.domain)
        ->
        (PreRefperm.identity pi' s'.alloct.M.domain t'.alloct.M.domain)
        ->
        (okRefperm s s' rho)
        ->
        (okRefperm t27 t' rho)
        ->
        (PreRefperm.idRgn pi28 s.pool t27.pool)
        ->
        (agree_allfields s t27 pi28 (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (PreRefperm.idRgn pi' s'.pool t'.pool)
        ->
        (agree_allfields s' t' pi' (Rgn.union s'.pool (img_rep s' s'.pool)))
        ->
        (pqueueR s s' rho)
        ->
        (pqueueR t27 t' rho)
  
  lemma pqueueR_is_refperm_monotonic:
    forall s : state, t29 : state, pi30 : PreRefperm.t.
      ((okRefperm s t29 pi30) ->
         ((pqueueR s t29 pi30) ->
            (forall rho : PreRefperm.t. ((okRefperm s t29 rho) -> ((PreRefperm.extends pi30 rho) -> (pqueueR s t29 rho))))))
end

module Main
  use prelude.Prelude
  use State
  use MAIN
  use PQUEUE
  use export graph_theory.Graph_theory
  
  val initDistances (s: state) (d: reference) (k: int) : unit
    requires { hasDistArrayType s d }
    requires { (d <> null) }
    requires { k >= 0 }
    writes { s.dSlots }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {d}`dSlots] (wr_frame_dSlots (old s) s (d.singleton)) }
    
    ensures { let len = s.dLength[d] in
              forall i : int. (0 <= i) -> (i < len) -> ((A.get (s.dSlots[d]) i) = k) }
  
  let main (s : state) (g : graph) (source : int) : reference
    requires { s.pool = emptyRgn }
    requires { s.PQUEUE.pqueuePub }
    requires { hasVertex g source }
    writes { s.alloct,
      s.child,
      s.dLength,
      s.dSlots,
      s.head,
      s.key,
      s.length,
      s.pool,
      s.prev,
      s.rep,
      s.sibling,
      s.size,
      s.slots,
      s.sntl,
      s.tag }
    ensures { (result <> null) }
    
    ensures { hasDistArrayType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr (pool union pool`rep)`slots] (wr_frame_slots (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`dSlots] (wr_frame_dSlots (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`sntl] (wr_frame_sntl (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`sibling] (wr_frame_sibling (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`prev] (wr_frame_prev (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`child] (wr_frame_child (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool union pool`rep)`rep]
              (wr_frame_rep (old s) s (Rgn.union s.pool (Rgn.union s.pool (img_rep s s.pool)))) }
    
    ensures { [@expl:wr (pool union pool`rep)`tag] (wr_frame_tag (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`size] (wr_frame_size (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`length] (wr_frame_length (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`key] (wr_frame_key (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`dLength] (wr_frame_dLength (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    diverges
  = label INIT in
      let result = ref null in
      let g = ref g in
      let source = ref source in
      let queue = ref null in
      assert { hasPqueueType s (! queue) };
      (let numVs = ref 0 in
       (numVs := ([@expl:numVs := numVertices(g)] ((! g).numVertices)));
       (queue := ([@expl:queue := new Pqueue] (s.mk_Pqueue)));
       ([@expl:Pqueue(queue)] (PQUEUE.init_Pqueue s (! queue)));
       (let dist = ref null in
        assert { hasDistArrayType s (! dist) };
        (dist := ([@expl:dist := new(DistArray){numVs}] (s.mk_DistArray)));
        ([@expl:dist := new(DistArray){numVs}] (set_dLength s (! dist) (! numVs)));
        ([@expl:dist := new(DistArray){numVs}] (set_dSlots s (! dist) (A.make (! numVs) 0)));
        assert {
          (Rgn.mem (! dist) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
            \/
            (not (Rgn.mem (! dist) (s.alloct.M.domain at INIT)))
            \/
            ((! dist) = null) };
        ([@expl:initDistances(dist,maxWeight)] (initDistances s (! dist) maxWeight));
        (let initDist = ref 0 in
         (initDist := ([@expl:initDist := 0] 0));
         (let ins = ref null in
          assert { hasNodeType s (! ins) };
          assert {
            (Rgn.subset
                (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                (Rgn.union
                    ((Rgn.union s.pool (Rgn.union s.pool (img_rep s s.pool))) at INIT)
                    (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))))
              /\
              (Rgn.subset
                  (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                  (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT)))) };
          (ins := ([@expl:ins := insert(queue,initDist,source)] (PQUEUE.insert s (! queue) (! initDist) (! source))));
          (let isEmp = ref false in
           assert {
             (Rgn.mem (! queue) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
               \/
               (not (Rgn.mem (! queue) (s.alloct.M.domain at INIT)))
               \/
               ((! queue) = null) };
           (isEmp := ([@expl:isEmp := isEmpty(queue)] (PQUEUE.isEmpty s (! queue))));
           (let min = ref null in
            assert { hasNodeType s (! min) };
            (let minTag = ref 0 in
             let minKey = ref 0 in
             (min := ([@expl:min := ins] (! ins)));
             while not (! isEmp) do
               invariant {
                 [@expl:locals type invariant]
                 ((hasDistArrayType s (! dist))
                    /\
                    (hasNodeType s (! ins))
                    /\
                    (hasNodeType s (! min))
                    /\
                    (hasPqueueType s (! queue))
                    /\
                    (hasDistArrayType s (! result))) }
               invariant { alloc_does_not_shrink (old s) s }
               invariant { [@expl:wr {queue}`rep`slots] (wr_frame_slots (old s) s (s.rep[! queue])) }
               invariant {
                 [@expl:wr ({dist} union {queue}`rep)`dSlots]
                 (wr_frame_dSlots (old s) s (Rgn.union ((! dist).singleton) (s.rep[! queue]))) }
               invariant { [@expl:wr {queue}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[! queue])) }
               invariant { [@expl:wr {queue}`rep`prev] (wr_frame_prev (old s) s (s.rep[! queue])) }
               invariant {
                 [@expl:wr ({queue} union {queue}`rep)`head]
                 (wr_frame_head (old s) s (Rgn.union ((! queue).singleton) (s.rep[! queue]))) }
               invariant { [@expl:wr {queue}`rep`child] (wr_frame_child (old s) s (s.rep[! queue])) }
               invariant {
                 [@expl:wr ({queue} union {queue}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union ((! queue).singleton) (s.rep[! queue]))) }
               invariant { [@expl:wr {queue}`rep`tag] (wr_frame_tag (old s) s (s.rep[! queue])) }
               invariant {
                 [@expl:wr ({queue} union {queue}`rep)`size]
                 (wr_frame_size (old s) s (Rgn.union ((! queue).singleton) (s.rep[! queue]))) }
               invariant { [@expl:wr {queue}`rep`length] (wr_frame_length (old s) s (s.rep[! queue])) }
               invariant { [@expl:wr {queue}`rep`key] (wr_frame_key (old s) s (s.rep[! queue])) }
               invariant { (! isEmp) <-> ((s.size[! queue]) = 0) }
               invariant { ((! numVs) = ((! g).numVertices)) /\ ((s.dLength[! dist]) = (! numVs)) }
               invariant { ((! dist).singleton) \# (Rgn.union s.pool (img_rep s s.pool)) }
               invariant {
                 let len = s.dLength[! dist] in
                 forall k : int. (0 <= k) -> (k < len) -> (let v = A.get (s.dSlots[! dist]) k in
                                                           0
                                                           <=
                                                           v) }
               invariant { let rep1 = s.rep[! queue] in
                           Rgn.mem (! min) rep1 }
               invariant {
                 let rep2 = s.rep[! queue] in
                 forall n : reference. (isAllocated s n) -> (hasNodeType s n) -> (Rgn.mem n rep2) -> (let key3 = s.key[n] in
                                                                    key3
                                                                    >=
                                                                    0) }
               invariant {
                 let rep4 = s.rep[! queue] in
                 forall n : reference.
                   (isAllocated s n)
                     ->
                     (hasNodeType s n)
                     ->
                     (Rgn.mem n rep4)
                     ->
                     (let len = s.dLength[! dist] in
                      let tag5 = s.tag[n] in
                      (tag5 >= 0) /\ (tag5 < len)) }
               invariant {
                 let oa = old s.alloct.M.domain in
                 Rgn.subset
                    (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                    (Rgn.diff s.alloct.M.domain oa) }
               invariant { s.PQUEUE.pqueuePub }
               assert {
                 (Rgn.subset
                     (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                     (Rgn.union
                         ((Rgn.union s.pool (Rgn.union s.pool (img_rep s s.pool))) at INIT)
                         (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))))
                   /\
                   (Rgn.subset
                       (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                       (Rgn.union
                           ((Rgn.union s.pool (img_rep s s.pool)) at INIT)
                           (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT)))) };
               (min := ([@expl:min := deleteMin(queue)] (PQUEUE.deleteMin s (! queue))));
               assert {
                 (Rgn.mem (! min) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                   \/
                   (not (Rgn.mem (! min) (s.alloct.M.domain at INIT)))
                   \/
                   ((! min) = null) };
               (minTag := ([@expl:minTag := getTag(min)] (PQUEUE.getTag s (! min))));
               assert {
                 (Rgn.mem (! min) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                   \/
                   (not (Rgn.mem (! min) (s.alloct.M.domain at INIT)))
                   \/
                   ((! min) = null) };
               (minKey := ([@expl:minKey := getKey(min)] (PQUEUE.getKey s (! min))));
               assert { ((! minTag) >= 0) /\ (let len = s.dLength[! dist] in
                                              (! minTag)
                                              <
                                              len) };
               (let i = ref 0 in
                assert { not (Rgn.mem (! dist) (Rgn.union s.pool (img_rep s s.pool))) };
                assert {
                  (Rgn.mem (! dist) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                    \/
                    (not (Rgn.mem (! dist) (s.alloct.M.domain at INIT)))
                    \/
                    ((! dist) = null) };
                (i := ([@expl:i := dist.{minTag}] (A.get (s.dSlots[! dist]) (! minTag))));
                (if ((! minKey) < (! i)) then
                   (assert { not (Rgn.mem (! dist) (Rgn.union s.pool (img_rep s s.pool))) };
                    (set_dSlots s (! dist) ([@expl:dist.{minTag} := minKey] (A.set (s.dSlots[! dist]) (! minTag) (! minKey))));
                    (let eLen = ref 0 in
                     let gEdges = ref (A.make 0 (any edge)) in
                     assert {
                       (Rgn.mem (! queue) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                         \/
                         (not (Rgn.mem (! queue) (s.alloct.M.domain at INIT)))
                         \/
                         ((! queue) = null) };
                     (isEmp := ([@expl:isEmp := isEmpty(queue)] (PQUEUE.isEmpty s (! queue))));
                     (gEdges := ([@expl:gEdges := edges(g)] ((! g).edges)));
                     (eLen := ([@expl:eLen := length(gEdges)] ((! gEdges).A.length)));
                     (let i6 = ref 0 in
                      while (0 <= (! i6))  && ((! i6) < (! eLen)) do
                        invariant {
                          [@expl:locals type invariant]
                          ((hasDistArrayType s (! dist))
                             /\
                             (hasNodeType s (! ins))
                             /\
                             (hasNodeType s (! min))
                             /\
                             (hasPqueueType s (! queue))
                             /\
                             (hasDistArrayType s (! result))) }
                        invariant { alloc_does_not_shrink (old s) s }
                        invariant {
                          [@expl:wr ({dist} union {queue}`rep)`dSlots]
                          (wr_frame_dSlots (old s) s (Rgn.union ((! dist).singleton) (s.rep[! queue]))) }
                        invariant { [@expl:wr {queue}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[! queue])) }
                        invariant { [@expl:wr {queue}`rep`prev] (wr_frame_prev (old s) s (s.rep[! queue])) }
                        invariant {
                          [@expl:wr ({queue} union {queue}`rep)`head]
                          (wr_frame_head (old s) s (Rgn.union ((! queue).singleton) (s.rep[! queue]))) }
                        invariant { [@expl:wr {queue}`rep`child] (wr_frame_child (old s) s (s.rep[! queue])) }
                        invariant {
                          [@expl:wr ({queue} union {queue}`rep)`rep]
                          (wr_frame_rep (old s) s (Rgn.union ((! queue).singleton) (s.rep[! queue]))) }
                        invariant { [@expl:wr {queue}`rep`tag] (wr_frame_tag (old s) s (s.rep[! queue])) }
                        invariant {
                          [@expl:wr ({queue} union {queue}`rep)`size]
                          (wr_frame_size (old s) s (Rgn.union ((! queue).singleton) (s.rep[! queue]))) }
                        invariant { [@expl:wr {queue}`rep`key] (wr_frame_key (old s) s (s.rep[! queue])) }
                        invariant { (0 <= (! i6)) /\ ((! i6) <= (! eLen)) }
                        invariant { (! isEmp) <-> ((s.size[! queue]) = 0) }
                        invariant { ((! numVs) = ((! g).numVertices)) /\ ((s.dLength[! dist]) = (! numVs)) }
                        invariant {
                          let len = s.dLength[! dist] in
                          forall k : int. (0 <= k) -> (k < len) -> (let v = A.get (s.dSlots[! dist]) k in
                                                                    0
                                                                    <=
                                                                    v) }
                        invariant { let rep7 = s.rep[! queue] in
                                    Rgn.mem (! min) rep7 }
                        invariant {
                          let rep8 = s.rep[! queue] in
                          forall n : reference.
                            (isAllocated s n)
                              ->
                              (hasNodeType s n)
                              ->
                              (Rgn.mem n rep8)
                              ->
                              (let len = s.dLength[! dist] in
                               let tag9 = s.tag[n] in
                               (tag9 >= 0) /\ (tag9 < len)) }
                        invariant { ((! dist).singleton) \# (Rgn.union s.pool (img_rep s s.pool)) }
                        invariant {
                          let rep10 = s.rep[! queue] in
                          forall n : reference.
                            (isAllocated s n) -> (hasNodeType s n) -> (Rgn.mem n rep10) -> (let key11 = s.key[n] in
                                                                    key11
                                                                    >=
                                                                    0) }
                        invariant {
                          let oa = old s.alloct.M.domain in
                          Rgn.subset
                             (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                             (Rgn.diff s.alloct.M.domain oa) }
                        invariant { s.PQUEUE.pqueuePub }
                        let startV = ref 0 in
                        let endV = ref 0 in
                        let currWeight = ref 0 in
                        let currEdge = ref (any edge) in
                        (currEdge := ([@expl:currEdge := get(gEdges,i)] (A.get (! gEdges) (! i6))));
                        (startV := ([@expl:startV := startVertex(currEdge)] ((! currEdge).startVertex)));
                        (endV := ([@expl:endV := endVertex(currEdge)] ((! currEdge).endVertex)));
                        (currWeight := ([@expl:currWeight := weight(currEdge)] ((! currEdge).weight)));
                        (let d = ref 0 in
                         let candidateDist = ref 0 in
                         assert { not (Rgn.mem (! dist) (Rgn.union s.pool (img_rep s s.pool))) };
                         assert {
                           (Rgn.mem (! dist) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                             \/
                             (not (Rgn.mem (! dist) (s.alloct.M.domain at INIT)))
                             \/
                             ((! dist) = null) };
                         (d := ([@expl:d := dist.{startV}] (A.get (s.dSlots[! dist]) (! startV))));
                         (candidateDist := ([@expl:candidateDist := d + currWeight] ((! d) + (! currWeight))));
                         assert { not (Rgn.mem (! dist) (Rgn.union s.pool (img_rep s s.pool))) };
                         assert {
                           (Rgn.mem (! dist) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                             \/
                             (not (Rgn.mem (! dist) (s.alloct.M.domain at INIT)))
                             \/
                             ((! dist) = null) };
                         (d := ([@expl:d := dist.{endV}] (A.get (s.dSlots[! dist]) (! endV))));
                         (if ((! candidateDist) < (! d)) then
                            (assert { ((! candidateDist) >= 0) /\ ((! endV) >= 0) };
                             assert {
                               (Rgn.subset
                                   (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                                   (Rgn.union
                                       ((Rgn.union s.pool (Rgn.union s.pool (img_rep s s.pool))) at INIT)
                                       (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))))
                                 /\
                                 (Rgn.subset
                                     (Rgn.diff (Rgn.union ((! queue).singleton) (s.rep[! queue])) (null.singleton))
                                     (Rgn.union
                                         ((Rgn.union s.pool (img_rep s s.pool)) at INIT)
                                         (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT)))) };
                             (ins
                                := ([@expl:ins := insert(queue,candidateDist,endV)]
                                    (PQUEUE.insert s (! queue) (! candidateDist) (! endV))));
                             assert { not (Rgn.mem (! dist) (Rgn.union s.pool (img_rep s s.pool))) };
                             (set_dSlots
                                s
                                (! dist)
                                ([@expl:dist.{endV} := candidateDist] (A.set (s.dSlots[! dist]) (! endV) (! candidateDist)))))
                          else ());
                         (i6 := ([@expl:i := i + 1] ((! i6) + 1)));
                         assert {
                           (Rgn.mem (! queue) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                             \/
                             (not (Rgn.mem (! queue) (s.alloct.M.domain at INIT)))
                             \/
                             ((! queue) = null) };
                         (isEmp := ([@expl:isEmp := isEmpty(queue)] (PQUEUE.isEmpty s (! queue)))))
                      done)))
                 else ());
                assert {
                  (Rgn.mem (! queue) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
                    \/
                    (not (Rgn.mem (! queue) (s.alloct.M.domain at INIT)))
                    \/
                    ((! queue) = null) };
                (isEmp := ([@expl:isEmp := isEmpty(queue)] (PQUEUE.isEmpty s (! queue)))))
             done;
             (result := ([@expl:result := dist] (! dist)));
             (! result))))))))
end

module Main_Link
  use prelude.Prelude
  use State
  use Main
  use PQUEUE_REL
  
  lemma pqueuePub_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph.
            forall l_source : int, r_source : int.
              (((l_s.pool = emptyRgn) -> (l_s.Main.PQUEUE.pqueuePub) -> (Main.hasVertex l_g l_source) -> (l_s.Main.PQUEUE.pqueuePub)) /\
                 ((r_s.pool = emptyRgn) -> (r_s.Main.PQUEUE.pqueuePub) -> (Main.hasVertex r_g r_source) -> (r_s.Main.PQUEUE.pqueuePub)))))
  
  lemma left_pqueueI_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph.
            forall l_source : int, r_source : int.
              (l_s.pool = emptyRgn) -> (l_s.Main.PQUEUE.pqueuePub) -> (Main.hasVertex l_g l_source) -> (l_s.PQUEUE_REL.PqueueL.pqueueI)))
  
  lemma right_pqueueI_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph.
            forall l_source : int, r_source : int.
              (r_s.pool = emptyRgn) -> (r_s.Main.PQUEUE.pqueuePub) -> (Main.hasVertex r_g r_source) -> (r_s.PQUEUE_REL.PqueueR.pqueueI)))
  
  lemma pqueueR_holds_in_main:
    forall l_s : state, r_s : state, pi : PreRefperm.t.
      ((okRefperm l_s r_s pi) ->
         (forall l_g : graph, r_g : graph.
            forall l_source : int, r_source : int.
              ((l_s.pool = emptyRgn) /\ (r_s.pool = emptyRgn))
                ->
                ((l_s.Main.PQUEUE.pqueuePub) /\ (r_s.Main.PQUEUE.pqueuePub))
                ->
                ((Main.hasVertex l_g l_source) /\ (Main.hasVertex r_g r_source))
                ->
                (l_g = r_g)
                ->
                (l_source = r_source)
                ->
                ((agree_dLength
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_dLength
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_key
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_key
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_length
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_length
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_size
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_size
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_tag
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_tag
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_rep
                    l_s
                    r_s
                    pi
                    (Rgn.diff
                        (Rgn.union l_s.pool (Rgn.union l_s.pool (img_rep l_s l_s.pool)))
                        (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_rep
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union r_s.pool (Rgn.union r_s.pool (img_rep r_s r_s.pool)))
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_child
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_child
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_head
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_head
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_prev
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_prev
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_sibling
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_sibling
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_sntl
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_sntl
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_dSlots
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_dSlots
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                ((agree_slots
                    l_s
                    r_s
                    pi
                    (Rgn.diff (Rgn.union l_s.pool (img_rep l_s l_s.pool)) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_slots
                      r_s
                      l_s
                      (pi.PreRefperm.invert)
                      (Rgn.diff (Rgn.union r_s.pool (img_rep r_s r_s.pool)) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                ->
                (pqueueR l_s r_s pi)))
  
  val main (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_g: graph) (l_source: int) (r_g: graph) (r_source: int) : 
