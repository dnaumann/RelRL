  use prelude.Prelude
  use State
  use PQUEUE
  
  predicate repOk (s: state) (pq: reference) =
    (hasPqueueType s pq)
      ->
      (pq <> null)
      ->
      (let sntl1 = s.sntl[pq] in
       let rep2 = s.rep[pq] in
       (typeofRgn s rep2 (L.Cons Node L.Nil))
         /\
         (not (Rgn.mem sntl1 rep2))
         /\
         (not (Rgn.mem null rep2))
         /\
         (forall n : reference.
            (isAllocated s n)
              ->
              (hasNodeType s n)
              ->
              (Rgn.mem n rep2)
              ->
              (let chl = s.child[n] in
               let sib = s.sibling[n] in
               let pre = s.prev[n] in
               ((Rgn.mem chl rep2) \/ (chl = sntl1)) /\ ((Rgn.mem sib rep2) \/ (sib = sntl1)) /\ (Rgn.mem pre rep2) \/ (pre = sntl1))))
  
  lemma repOk_EMPTY:
    forall s : state. forall p : reference. (isAllocated s p) -> (hasPqueueType s p) -> ((s.rep[p]) = emptyRgn) -> (repOk s p)
  
  predicate sntlOk (s: state) (sntl1: reference) =
    (hasNodeType s sntl1)
      ->
      (sntl1 <> null)
      ->
      ((s.tag[sntl1]) = 0 - 1)
      /\
      ((s.key[sntl1]) = 0 - 1)
      /\
      ((s.sibling[sntl1]) = sntl1)
      /\
      ((s.child[sntl1]) = sntl1)
      /\
      ((s.prev[sntl1]) = sntl1)
  
  predicate strongDisjoint (s: state) (r: rgn) =
    forall p : reference, q : reference.
      (isAllocated s p)
        ->
        (hasPqueueType s p)
        ->
        (Rgn.mem p r)
        ->
        (isAllocated s q)
        ->
        (hasPqueueType s q)
        ->
        (Rgn.mem q r)
        ->
        (let prep = s.rep[p] in
         let qrep = s.rep[q] in
         (p <> q) -> ((Rgn.inter prep qrep) = emptyRgn))
  
  predicate pqueueI (s: state) =
    forall pq : reference.
      (isAllocated s pq)
        ->
        (hasPqueueType s pq)
        ->
        (Rgn.mem pq s.pool)
        ->
        (let rep1 = s.rep[pq] in
         let sz = s.size[pq] in
         let sntl2 = s.sntl[pq] in
         let head3 = s.head[pq] in
         (sntl2 <> null)
           /\
           (Rgn.mem sntl2 s.pool)
           /\
           (not (Rgn.mem sntl2 rep1))
           /\
           (repOk s pq)
           /\
           (head3 <> null)
           /\
           ((head3 <> sntl2) -> (Rgn.mem head3 rep1))
           /\
           (sz >= 0)
           /\
           ((sz = 0) <-> (head3 = sntl2))
           /\
           (forall pq2 : reference.
              (isAllocated s pq2) -> (hasPqueueType s pq2) -> (Rgn.mem pq2 s.pool) -> (pq <> pq2) -> (not ((s.sntl[pq2]) = sntl2)))
           /\
           (forall pq2 : reference.
              (isAllocated s pq2) -> (hasPqueueType s pq2) -> (Rgn.mem pq2 s.pool) -> (let r = s.rep[pq2] in
                                                                    not (Rgn.mem sntl2 r)))
           /\
           (sntlOk s sntl2))
  
  lemma disjointNotIn:
    forall s : state.
      forall r : rgn.
        forall p : reference, q : reference.
          (isAllocated s p)
            ->
            (hasPqueueType s p)
            ->
            (Rgn.mem p s.pool)
            ->
            (isAllocated s q)
            ->
            (hasPqueueType s q)
            ->
            (Rgn.mem q s.pool)
            ->
            (s.PQUEUE.pqueuePub)
            ->
            (p <> q)
            ->
            (let prep = s.rep[p] in
             let qrep = s.rep[q] in
             forall n : reference. (isAllocated s n) -> (hasNodeType s n) -> (Rgn.mem n prep) -> (not (Rgn.mem n qrep)))
  
  let init_Node (s : state) (self : reference) (k : int) (t : int) : 
    unit
    requires { hasNodeType s self }
    requires { (self <> null) }
    writes { s.key, s.tag }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`key] (wr_frame_key (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`tag] (wr_frame_tag (old s) s (self.singleton)) }
    
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.key[self]) = k }
    
    ensures { (s.tag[self]) = t }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let k = ref k in
      let t = ref t in
      ([@expl:self.key := k] (set_key s (! self) (! k)));
      ([@expl:self.tag := t] (set_tag s (! self) (! t)));
      (! result)
  
  let getTag (s : state) (self : reference) : int
    requires { hasNodeType s self }
    requires { (self <> null) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.tag[self]) = result }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref 0 in
      let self = ref self in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (result := ([@expl:result := self.tag] (s.tag[! self])));
      (! result)
  
  let getKey (s : state) (self : reference) : int
    requires { hasNodeType s self }
    requires { (self <> null) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.key[self]) = result }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref 0 in
      let self = ref self in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (result := ([@expl:result := self.key] (s.key[! self])));
      (! result)
  
  let init_Pqueue (s : state) (self : reference) : unit
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { ((s.rep[self]) = emptyRgn) /\ ((s.size[self]) = 0) /\ ((s.head[self]) = null) }
    requires { not (Rgn.mem self s.pool) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.alloct, s.child, s.head, s.key, s.pool, s.prev, s.rep, s.sibling, s.sntl, s.tag }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr ({self}`rep union {self})`sntl] (wr_frame_sntl (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self}`rep union {self})`head] (wr_frame_head (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self}`rep union {self})`rep] (wr_frame_rep (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { Rgn.mem self s.pool }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.subset rep1 (null.singleton) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff s.alloct.M.domain oa) (Rgn.union s.pool (s.rep[self])) }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let sntl2 = ref null in
      assert { hasNodeType s (! sntl2) };
      (sntl2 := ([@expl:sntl := new Node] (s.mk_Node)));
      (let sntlVal = ref 0 in
       (sntlVal := ([@expl:sntlVal := - 1] (0 - 1)));
       assert { (not (Rgn.mem (! sntl2) (s.alloct.M.domain at INIT))) \/ ((! sntl2) = null) };
       ([@expl:Node(sntl,sntlVal,sntlVal)] (init_Node s (! sntl2) (! sntlVal) (! sntlVal)));
       assert {
         forall pq : reference. (isAllocated s pq) -> (hasPqueueType s pq) -> (Rgn.mem pq s.pool) -> (not ((s.sntl[pq]) = (! sntl2))) };
       ([@expl:self.rep := {}] (set_rep s (! self) emptyRgn));
       ([@expl:self.sntl := sntl] (set_sntl s (! self) (! sntl2)));
       ([@expl:self.head := sntl] (set_head s (! self) (! sntl2)));
       ([@expl:sntl.sibling := sntl] (set_sibling s (! sntl2) (! sntl2)));
       ([@expl:sntl.child := sntl] (set_child s (! sntl2) (! sntl2)));
       ([@expl:sntl.prev := sntl] (set_prev s (! sntl2) (! sntl2)));
       (set_pool
          s
          ([@expl:pool := pool union {self} union {sntl}] (Rgn.union (Rgn.union s.pool ((! self).singleton)) ((! sntl2).singleton))));
       (! result))
  
  let isEmpty (s : state) (self : reference) : bool
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { ((s.size[self]) = 0) <-> result }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref false in
      let self = ref self in
      let sz = ref 0 in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (sz := ([@expl:sz := self.size] (s.size[! self])));
      (result := ([@expl:result := sz = 0] ((! sz) = 0)));
      (! result)
  
  let findMin (s : state) (self : reference) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let hd = s.head[self] in
              result
              =
              hd }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref null in
      let self = ref self in
      assert { let sntl1 = s.sntl[! self] in
               not ((s.head[! self]) = sntl1) };
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (result := ([@expl:result := self.head] (s.head[! self])));
      (! result)
  
  let link (s : state) (self : reference) (first : reference) (second : reference) : 
    reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { hasNodeType s first }
    requires { (first <> null) }
    requires { hasNodeType s second }
    requires { (second <> null) }
    requires { Rgn.mem self s.pool }
    requires { let rep2 = s.rep[self] in
               (Rgn.mem first rep2) /\ (Rgn.mem second rep2) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.child, s.prev, s.sibling }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
    
    ensures { ((result = first) /\ ((s.child[first]) = second)) \/ (result = second) /\ ((s.child[second]) = first) }
    
    ensures { (result = first) \/ (result = second) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
  = label INIT in
      let result = ref null in
      let self = ref self in
      let first = ref first in
      let second = ref second in
      let fkey = ref 0 in
      let skey = ref 0 in
      let tmp = ref null in
      assert { hasNodeType s (! tmp) };
      (let ghost rep3 = ref emptyRgn in
       assert { isValidRgn s (! rep3) };
       (let sntl4 = ref null in
        assert { hasNodeType s (! sntl4) };
        assert {
          (Rgn.mem (! self) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (sntl4 := ([@expl:sntl := self.sntl] (s.sntl[! self])));
        assert { ((! first) <> (! sntl4)) /\ ((! second) <> (! sntl4)) };
        assert {
          forall p : reference.
            (isAllocated s p)
              ->
              (hasPqueueType s p)
              ->
              (Rgn.mem p s.pool)
              ->
              (let snt = s.sntl[p] in
               ((! first) <> snt) /\ ((! second) <> snt)) };
        assert {
          (Rgn.mem (! self) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (rep3 := ([@expl:rep := self.rep] (s.rep[! self])));
        assert {
          (Rgn.mem (! first) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
            \/
            (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
            \/
            ((! first) = null) };
        (fkey := ([@expl:fkey := first.key] (s.key[! first])));
        assert {
          (Rgn.mem (! second) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
            \/
            (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
            \/
            ((! second) = null) };
        (skey := ([@expl:skey := second.key] (s.key[! second])));
        assert {
          forall p : reference. (isAllocated s p) -> (hasPqueueType s p) -> (Rgn.mem p s.pool) -> (p <> (! self)) -> (repOk s p) };
        assert { sntlOk s (! sntl4) };
        assert {
          forall p : reference.
            (isAllocated s p) -> (hasPqueueType s p) -> (Rgn.mem p s.pool) -> (p <> (! self)) -> (let snt = s.sntl[p] in
                                                                    sntlOk s snt) };
        (if ((! skey) < (! fkey)) then
           (assert {
              (Rgn.mem (! first) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
                \/
                (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
                \/
                ((! first) = null) };
            (tmp := ([@expl:tmp := first.prev] (s.prev[! first])));
            assert { ((! tmp) <> (! sntl4)) -> (Rgn.mem (! tmp) (! rep3)) };
            ([@expl:second.prev := tmp] (set_prev s (! second) (! tmp)));
            assert { let snt = s.sntl[! self] in
                     sntlOk s snt };
            ([@expl:first.prev := second] (set_prev s (! first) (! second)));
            assert { let p = s.prev[! first] in
                     Rgn.mem p (! rep3) };
            assert {
              (Rgn.mem (! second) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
                \/
                (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
                \/
                ((! second) = null) };
            (tmp := ([@expl:tmp := second.child] (s.child[! second])));
            ([@expl:first.sibling := tmp] (set_sibling s (! first) (! tmp)));
            assert { sntlOk s (! sntl4) };
            assert {
              forall p : reference.
                (isAllocated s p) -> (hasPqueueType s p) -> (Rgn.mem p s.pool) -> (let snt = s.sntl[p] in
                                                                    sntlOk s snt) };
            (if ((! tmp) <>. (! sntl4)) then
               (assert {
                  (Rgn.mem (! first) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
                    \/
                    (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
                    \/
                    ((! first) = null) };
                (tmp := ([@expl:tmp := first.sibling] (s.sibling[! first])));
                assert { let rep5 = s.rep[! self] in
                         Rgn.mem (! tmp) rep5 };
                assert {
                  forall p : reference.
                    (isAllocated s p)
                      ->
                      (hasPqueueType s p)
                      ->
                      (Rgn.mem p s.pool)
                      ->
                      (p <> (! self))
                      ->
                      (let rep6 = s.rep[p] in
                       not (Rgn.mem (! tmp) rep6)) };
                assert { let rep7 = s.rep[! self] in
                         let p = s.prev[! tmp] in
                         (p = (! sntl4)) \/ (Rgn.mem p rep7) };
                ([@expl:tmp.prev := first] (set_prev s (! tmp) (! first)));
                assert { Rgn.mem (! tmp) (! rep3) };
                assert { let p = s.prev[! tmp] in
                         Rgn.mem p (! rep3) };
                assert { repOk s (! self) };
                assert { sntlOk s (! sntl4) };
                assert {
                  forall p : reference.
                    (isAllocated s p) -> (hasPqueueType s p) -> (Rgn.mem p s.pool) -> (let snt = s.sntl[p] in
                                                                    sntlOk s snt) })
             else ());
            assert { (! first) <> (! sntl4) };
            ([@expl:second.child := first] (set_child s (! second) (! first)));
            assert { not ((s.child[! second]) = (! sntl4)) };
            (result := ([@expl:result := second] (! second)));
            assert { repOk s (! self) };
            assert { sntlOk s (! sntl4) };
            assert {
              forall p : reference.
                (isAllocated s p) -> (hasPqueueType s p) -> (Rgn.mem p s.pool) -> (let snt = s.sntl[p] in
                                                                    sntlOk s snt) })
         else
           (([@expl:second.prev := first] (set_prev s (! second) (! first)));
            assert {
              (Rgn.mem (! second) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
                \/
                (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
                \/
                ((! second) = null) };
            (tmp := ([@expl:tmp := second.sibling] (s.sibling[! second])));
            assert { ((! tmp) <> (! sntl4)) -> (Rgn.mem (! tmp) (! rep3)) };
            ([@expl:first.sibling := tmp] (set_sibling s (! first) (! tmp)));
            (if ((! tmp) <>. (! sntl4)) then
               (assert {
                  (Rgn.mem (! first) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
                    \/
                    (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
                    \/
                    ((! first) = null) };
                (tmp := ([@expl:tmp := first.sibling] (s.sibling[! first])));
                ([@expl:tmp.prev := first] (set_prev s (! tmp) (! first))))
             else ());
            assert {
              (Rgn.mem (! first) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
                \/
                (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
                \/
                ((! first) = null) };
            (tmp := ([@expl:tmp := first.child] (s.child[! first])));
            ([@expl:second.sibling := tmp] (set_sibling s (! second) (! tmp)));
            (if ((! tmp) <>. (! sntl4)) then
               (assert { Rgn.mem (! tmp) (! rep3) };
                assert {
                  (Rgn.mem (! second) ((Rgn.union (s.rep[! self]) ((! self).singleton)) at INIT))
                    \/
                    (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
                    \/
                    ((! second) = null) };
                (tmp := ([@expl:tmp := second.sibling] (s.sibling[! second])));
                assert { Rgn.mem (! tmp) (! rep3) };
                ([@expl:tmp.prev := second] (set_prev s (! tmp) (! second))))
             else ());
            ([@expl:first.child := second] (set_child s (! first) (! second)));
            (result := ([@expl:result := first] (! first)));
            assert { repOk s (! self) }));
        (! result)))
  
  lemma insert_wr_rgn_eq:
    forall s : state.
      forall self1 : reference, n : reference.
        (isAllocated s self1)
          ->
          (hasPqueueType s self1)
          ->
          (isAllocated s n)
          ->
          (hasNodeType s n)
          ->
          (let rep2 = s.rep[self1] in
           (Rgn.mem n rep2) -> ((Rgn.union (n.singleton) (s.rep[self1])) = (s.rep[self1])))
  
  let insert (s : state) (self : reference) (k : int) (t : int) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.alloct, s.child, s.head, s.key, s.prev, s.rep, s.sibling, s.size, s.tag }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
