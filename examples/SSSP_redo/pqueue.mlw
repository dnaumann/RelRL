module State
  use prelude.Prelude
  use prelude.PreRefperm
  use graph_theory.Graph_theory
  
  type reftype = 
      | DistArray
      | Node
      | NodeArray
      | Pqueue
  
  type state = private {
              mutable ghost alloct : M.t reftype;
              mutable ghost rep : M.t rgn;
              mutable size : M.t int;
              mutable head : M.t reference;
              mutable sntl : M.t reference;
              mutable slots : M.t (A.array reference);
              mutable length : M.t int;
              mutable prev : M.t reference;
              mutable sibling : M.t reference;
              mutable child : M.t reference;
              mutable key : M.t int;
              mutable tag : M.t int;
              mutable dLength : M.t int;
              mutable dSlots : M.t (A.array int);
              mutable ghost pool : rgn
              }
    invariant { not (M.mem null alloct) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = DistArray) ->
              (((M.mem p dLength) /\ (M.mem p dSlots)) /\ (((dLength[p]) >= 0) /\ ((dLength[p]) = ((dSlots[p]).A.length)))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = Node) ->
              (((M.mem p prev) /\ (M.mem p sibling) /\ (M.mem p child) /\ (M.mem p key) /\ (M.mem p tag)) /\
                 ((((prev[p]) = null) \/ ((M.mem (prev[p]) alloct) /\ ((alloct[prev[p]]) = Node)))
                    /\
                    (((sibling[p]) = null) \/ ((M.mem (sibling[p]) alloct) /\ ((alloct[sibling[p]]) = Node)))
                    /\
                    (((child[p]) = null) \/ ((M.mem (child[p]) alloct) /\ ((alloct[child[p]]) = Node))))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = NodeArray) ->
              (((M.mem p slots) /\ (M.mem p length)) /\
                 (((length[p]) >= 0)
                    /\
                    ((length[p]) = ((slots[p]).A.length))
                    /\
                    (let arr = slots[p] in
                     forall i : int.
                       ((0 <= i) ->
                          ((i < (arr.A.length)) -> (let v = A.get arr i in
                                                    ((v = null) \/ ((M.mem v alloct) /\ ((alloct[v]) = Node))))))))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = Pqueue) ->
              (((M.mem p rep) /\ (M.mem p size) /\ (M.mem p head) /\ (M.mem p sntl)) /\
                 ((((head[p]) = null) \/ ((M.mem (head[p]) alloct) /\ ((alloct[head[p]]) = Node)))
                    /\
                    (((sntl[p]) = null) \/ ((M.mem (sntl[p]) alloct) /\ ((alloct[sntl[p]]) = Node)))
                    /\
                    (forall q : reference. ((Rgn.mem q (rep[p])) -> ((q = null) \/ (M.mem q alloct)))))))) }
    invariant { forall q : reference. ((Rgn.mem q pool) -> ((q = null) \/ (M.mem q alloct))) }
    invariant { not (M.mem null rep) }
    invariant { not (M.mem null size) }
    invariant { not (M.mem null head) }
    invariant { not (M.mem null sntl) }
    invariant { not (M.mem null slots) }
    invariant { not (M.mem null length) }
    invariant { not (M.mem null prev) }
    invariant { not (M.mem null sibling) }
    invariant { not (M.mem null child) }
    invariant { not (M.mem null key) }
    invariant { not (M.mem null tag) }
    invariant { not (M.mem null dLength) }
    invariant { not (M.mem null dSlots) }
    by
      { alloct = (().M.create) ;
        rep = (().M.create) ;
        size = (().M.create) ;
        head = (().M.create) ;
        sntl = (().M.create) ;
        slots = (().M.create) ;
        length = (().M.create) ;
        prev = (().M.create) ;
        sibling = (().M.create) ;
        child = (().M.create) ;
        key = (().M.create) ;
        tag = (().M.create) ;
        dLength = (().M.create) ;
        dSlots = (().M.create) ;
        pool = emptyRgn }
  
  predicate isAllocated (s: state) (p: reference) = M.mem p s.alloct
  
  predicate isValidRgn (s: state) (r: rgn) = forall q : reference. ((Rgn.mem q r) -> ((q = null) \/ (M.mem q s.alloct)))
  
  predicate typeofRgn (s: state) (r: rgn) (types: L.list reftype) =
    forall p : reference. ((Rgn.mem p r) -> ((p = null) \/ ((M.mem p s.alloct) /\ (L.mem (s.alloct[p]) types))))
  
  predicate hasDistArrayType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = DistArray)))
  
  predicate hasNodeType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Node)))
  
  predicate hasNodeArrayType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = NodeArray)))
  
  predicate hasPqueueType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Pqueue)))
  
  predicate okRefperm (sl: state) (sr: state) (pi: PreRefperm.t) =
    ((forall p : reference. ((M.mem p pi.lor) -> (M.mem p sl.alloct))) /\
       ((forall q : reference. ((M.mem q pi.rol) -> (M.mem q sr.alloct))) /\
          (forall p : reference, q : reference. ((M.mem p pi.lor) -> (((pi.lor[p]) = q) -> ((sl.alloct[p]) = (sr.alloct[q])))))))
  
  val mk_DistArray (s: state) : reference
    writes { s.alloct, s.dLength, s.dSlots }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result DistArray (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasDistArrayType s result }
    
    ensures { (s.dLength = (M.add result 0 (old s.dLength))) }
    
    ensures { (s.dSlots = (M.add result (A.make 0 0) (old s.dSlots))) }
  
  val mk_Node (s: state) : reference
    writes { s.alloct, s.prev, s.sibling, s.child, s.key, s.tag }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result Node (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { (s.prev = (M.add result null (old s.prev))) }
    
    ensures { (s.sibling = (M.add result null (old s.sibling))) }
    
    ensures { (s.child = (M.add result null (old s.child))) }
    
    ensures { (s.key = (M.add result 0 (old s.key))) }
    
    ensures { (s.tag = (M.add result 0 (old s.tag))) }
  
  val mk_NodeArray (s: state) : reference
    writes { s.alloct, s.slots, s.length }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result NodeArray (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasNodeArrayType s result }
    
    ensures { (s.slots = (M.add result (A.make 0 null) (old s.slots))) }
    
    ensures { (s.length = (M.add result 0 (old s.length))) }
  
  val mk_Pqueue (s: state) : reference
    writes { s.alloct, s.rep, s.size, s.head, s.sntl }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result Pqueue (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasPqueueType s result }
    
    ensures { (s.rep = (M.add result emptyRgn (old s.rep))) }
    
    ensures { (s.size = (M.add result 0 (old s.size))) }
    
    ensures { (s.head = (M.add result null (old s.head))) }
    
    ensures { (s.sntl = (M.add result null (old s.sntl))) }
  
  val set_pool (s: state) (ghost v: rgn) : unit
    requires { isValidRgn s v }
    writes { s.pool }
    ensures { (s.pool = v) }
  
  val set_rep (s: state) (o: reference) (ghost v: rgn) : unit
    requires { (o <> null) }
    requires { hasPqueueType s o }
    requires { isValidRgn s v }
    writes { s.rep }
    ensures { (s.rep = (M.add o v (old s.rep))) }
  
  val set_size (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasPqueueType s o }
    writes { s.size }
    ensures { (s.size = (M.add o v (old s.size))) }
  
  val set_head (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasPqueueType s o }
    requires { hasNodeType s v }
    writes { s.head }
    ensures { (s.head = (M.add o v (old s.head))) }
  
  val set_sntl (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasPqueueType s o }
    requires { hasNodeType s v }
    writes { s.sntl }
    ensures { (s.sntl = (M.add o v (old s.sntl))) }
  
  val set_slots (s: state) (o: reference) (v: A.array reference) : unit
    requires { (o <> null) }
    requires { hasNodeArrayType s o }
    writes { s.slots }
    ensures { (s.slots = (M.add o v (old s.slots))) }
  
  val set_length (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasNodeArrayType s o }
    writes { s.length }
    ensures { (s.length = (M.add o v (old s.length))) }
  
  val set_prev (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    requires { hasNodeType s v }
    writes { s.prev }
    ensures { (s.prev = (M.add o v (old s.prev))) }
  
  val set_sibling (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    requires { hasNodeType s v }
    writes { s.sibling }
    ensures { (s.sibling = (M.add o v (old s.sibling))) }
  
  val set_child (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    requires { hasNodeType s v }
    writes { s.child }
    ensures { (s.child = (M.add o v (old s.child))) }
  
  val set_key (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    writes { s.key }
    ensures { (s.key = (M.add o v (old s.key))) }
  
  val set_tag (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    writes { s.tag }
    ensures { (s.tag = (M.add o v (old s.tag))) }
  
  val set_dLength (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasDistArrayType s o }
    writes { s.dLength }
    ensures { (s.dLength = (M.add o v (old s.dLength))) }
  
  val set_dSlots (s: state) (o: reference) (v: A.array int) : unit
    requires { (o <> null) }
    requires { hasDistArrayType s o }
    writes { s.dSlots }
    ensures { (s.dSlots = (M.add o v (old s.dSlots))) }
  
  function img_tag : state -> (rgn -> rgn)
  
  axiom img_tag_ax: forall s : state, r : rgn. ((img_tag s r) = emptyRgn)
  
  function img_sntl : state -> (rgn -> rgn)
  
  axiom img_sntl_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_sntl s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Pqueue) /\ ((Rgn.mem q r) /\ (p = (s.sntl[q])))))))
  
  function img_slots : state -> (rgn -> rgn)
  
  axiom img_slots_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_slots s r)) <->
         (((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Node))) /\
            (exists arr : reference.
               ((M.mem arr s.alloct) /\
                  (((s.alloct[arr]) = NodeArray) /\
                     ((Rgn.mem arr r) /\
                        (exists i : int. ((0 <= i) /\ ((i < ((s.slots[arr]).A.length)) /\ ((A.get (s.slots[arr]) i) = p))))))))))
  
  function img_size : state -> (rgn -> rgn)
  
  axiom img_size_ax: forall s : state, r : rgn. ((img_size s r) = emptyRgn)
  
  function img_sibling : state -> (rgn -> rgn)
  
  axiom img_sibling_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_sibling s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Node) /\ ((Rgn.mem q r) /\ (p = (s.sibling[q])))))))
  
  function img_rep : state -> (rgn -> rgn)
  
  axiom img_rep_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_rep s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Pqueue) /\ ((Rgn.mem q r) /\ (Rgn.mem p (s.rep[q])))))))
  
  function img_prev : state -> (rgn -> rgn)
  
  axiom img_prev_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_prev s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Node) /\ ((Rgn.mem q r) /\ (p = (s.prev[q])))))))
  
  function img_length : state -> (rgn -> rgn)
  
  axiom img_length_ax: forall s : state, r : rgn. ((img_length s r) = emptyRgn)
  
  function img_key : state -> (rgn -> rgn)
  
  axiom img_key_ax: forall s : state, r : rgn. ((img_key s r) = emptyRgn)
  
  function img_head : state -> (rgn -> rgn)
  
  axiom img_head_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_head s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Pqueue) /\ ((Rgn.mem q r) /\ (p = (s.head[q])))))))
  
  function img_dSlots : state -> (rgn -> rgn)
  
  axiom img_dSlots_ax: forall s : state, r : rgn. ((img_dSlots s r) = emptyRgn)
  
  function img_dLength : state -> (rgn -> rgn)
  
  axiom img_dLength_ax: forall s : state, r : rgn. ((img_dLength s r) = emptyRgn)
  
  function img_child : state -> (rgn -> rgn)
  
  axiom img_child_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_child s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Node) /\ ((Rgn.mem q r) /\ (p = (s.child[q])))))))
  
  predicate alloc_does_not_shrink (pre: state) (post: state) =
    forall p : reference. ((M.mem p pre.alloct) -> ((M.mem p post.alloct) /\ ((pre.alloct[p]) = (post.alloct[p]))))
  
  predicate wr_frame_dLength (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = DistArray) -> ((not (Rgn.mem p r)) -> ((pre.dLength[p]) = (post.dLength[p])))))
  
  predicate wr_frame_dSlots (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = DistArray) -> ((not (Rgn.mem p r)) -> ((pre.dSlots[p]) = (post.dSlots[p])))))
  
  predicate wr_frame_prev (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.prev[p]) = (post.prev[p])))))
  
  predicate wr_frame_sibling (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.sibling[p]) = (post.sibling[p])))))
  
  predicate wr_frame_child (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.child[p]) = (post.child[p])))))
  
  predicate wr_frame_key (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.key[p]) = (post.key[p])))))
  
  predicate wr_frame_tag (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.tag[p]) = (post.tag[p])))))
  
  predicate wr_frame_slots (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = NodeArray) -> ((not (Rgn.mem p r)) -> ((pre.slots[p]) = (post.slots[p])))))
  
  predicate wr_frame_length (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = NodeArray) -> ((not (Rgn.mem p r)) -> ((pre.length[p]) = (post.length[p])))))
  
  predicate wr_frame_rep (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Pqueue) -> ((not (Rgn.mem p r)) -> ((pre.rep[p]) = (post.rep[p])))))
  
  predicate wr_frame_size (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Pqueue) -> ((not (Rgn.mem p r)) -> ((pre.size[p]) = (post.size[p])))))
  
  predicate wr_frame_head (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Pqueue) -> ((not (Rgn.mem p r)) -> ((pre.head[p]) = (post.head[p])))))
  
  predicate wr_frame_sntl (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Pqueue) -> ((not (Rgn.mem p r)) -> ((pre.sntl[p]) = (post.sntl[p])))))
  
  predicate agree_tag (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.tag[o]) = (sr.tag[pi.lor[o]])))))))))
  
  predicate agree_sntl (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasPqueueType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.sntl[o]) (sr.sntl[pi.lor[o]])))))))))
  
  predicate agree_slots (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.slots[o]) = (sr.slots[pi.lor[o]])))))))))
  
  predicate agree_size (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasPqueueType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.size[o]) = (sr.size[pi.lor[o]])))))))))
  
  predicate agree_sibling (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.sibling[o]) (sr.sibling[pi.lor[o]])))))))))
  
  predicate agree_rep (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasPqueueType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRgn pi (sl.rep[o]) (sr.rep[pi.lor[o]])))))))))
  
  predicate agree_prev (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.prev[o]) (sr.prev[pi.lor[o]])))))))))
  
  predicate agree_length (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.length[o]) = (sr.length[pi.lor[o]])))))))))
  
  predicate agree_key (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.key[o]) = (sr.key[pi.lor[o]])))))))))
  
  predicate agree_head (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasPqueueType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.head[o]) (sr.head[pi.lor[o]])))))))))
  
  predicate agree_dSlots (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasDistArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.dSlots[o]) = (sr.dSlots[pi.lor[o]])))))))))
  
  predicate agree_dLength (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasDistArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.dLength[o]) = (sr.dLength[pi.lor[o]])))))))))
  
  predicate agree_child (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.child[o]) (sr.child[pi.lor[o]])))))))))
  
  predicate agree_allfields (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    (agree_dLength sl sr pi w)
      /\
      (agree_dSlots sl sr pi w)
      /\
      (agree_prev sl sr pi w)
      /\
      (agree_sibling sl sr pi w)
      /\
      (agree_child sl sr pi w)
      /\
      (agree_key sl sr pi w)
      /\
      (agree_tag sl sr pi w)
      /\
      (agree_slots sl sr pi w)
      /\
      (agree_length sl sr pi w)
      /\
      (agree_rep sl sr pi w)
      /\
      (agree_size sl sr pi w)
      /\
      (agree_head sl sr pi w)
      /\
      (agree_sntl sl sr pi w)
end

module CLIENT
  use prelude.Prelude
  use State
end

module MAIN
  use prelude.Prelude
  use State
end

module PQUEUE
  use prelude.Prelude
  use State
  
  predicate pqueuePub (s: state) =
    (typeofRgn s s.pool (L.Cons Node (L.Cons Pqueue L.Nil)))
      /\
      (typeofRgn s (img_rep s s.pool) (L.Cons Node L.Nil))
      /\
      (forall p : reference, q : reference.
         (isAllocated s p)
           ->
           (hasPqueueType s p)
           ->
           (Rgn.mem p s.pool)
           ->
           (isAllocated s q)
           ->
           (hasPqueueType s q)
           ->
           (Rgn.mem q s.pool)
           ->
           (let prep = s.rep[p] in
            let qrep = s.rep[q] in
            (p <> q) -> (prep \# qrep)))
  
  lemma noPqueueInRep:
    forall s : state.
      (s.pqueuePub)
        ->
        (forall p : reference, q : reference.
           (isAllocated s p)
             ->
             (hasPqueueType s p)
             ->
             (Rgn.mem p s.pool)
             ->
             (isAllocated s q)
             ->
             (hasPqueueType s q)
             ->
             (Rgn.mem q s.pool)
             ->
             (let prep = s.rep[p] in
              (p <> q) -> (not (Rgn.mem q prep))))
  
  val getTag (s: state) (self: reference) : int
    requires { hasNodeType s self }
    requires { (self <> null) }
    requires { s.pqueuePub }
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.tag[self]) = result }
    
    ensures { s.pqueuePub }
  
  val getKey (s: state) (self: reference) : int
    requires { hasNodeType s self }
    requires { (self <> null) }
    requires { s.pqueuePub }
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.key[self]) = result }
    
    ensures { s.pqueuePub }
  
  val init_Pqueue (s: state) (self: reference) : unit
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { ((s.rep[self]) = emptyRgn) /\ ((s.size[self]) = 0) /\ ((s.head[self]) = null) }
    requires { not (Rgn.mem self s.pool) }
    requires { s.pqueuePub }
    writes { s.slots,
      s.dSlots,
      s.sntl,
      s.sibling,
      s.prev,
      s.head,
      s.child,
      s.rep,
      s.tag,
      s.size,
      s.length,
      s.key,
      s.dLength,
      s.alloct,
      s.pool }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self}`rep union {self})`sntl] (wr_frame_sntl (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self}`rep union {self})`head] (wr_frame_head (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self}`rep union {self})`rep] (wr_frame_rep (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self}`rep union {self})`size] (wr_frame_size (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { Rgn.mem self s.pool }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.subset rep1 (null.singleton) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff s.alloct.M.domain oa) (Rgn.union s.pool (s.rep[self])) }
    
    ensures { s.pqueuePub }
  
  val isEmpty (s: state) (self: reference) : bool
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.pqueuePub }
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { ((s.size[self]) = 0) <-> result }
    
    ensures { s.pqueuePub }
  
  val findMin (s: state) (self: reference) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.pqueuePub }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let hd = s.head[self] in
              result
              =
              hd }
    
    ensures { s.pqueuePub }
  
  val insert (s: state) (self: reference) (k: int) (t: int) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.pqueuePub }
    writes { s.slots, s.dSlots, s.sntl, s.sibling, s.prev, s.head, s.child, s.rep, s.tag, s.size, s.length, s.key, s.dLength, s.alloct }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`sntl] (wr_frame_sntl (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    
    ensures { let orep = old (s.rep[self]) in
              (s.rep[self])
              =
              (Rgn.union orep (result.singleton)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              +
              1 }
    
    ensures { (s.key[result]) = k }
    
    ensures { (s.tag[result]) = t }
    
    ensures { let rep2 = s.rep[self] in
              forall n : reference.
                (isAllocated s n)
                  ->
                  (hasNodeType s n)
                  ->
                  (Rgn.mem n rep2)
                  ->
                  (n <> result)
                  ->
                  (let ot = old (s.tag[n]) in
                   let ok = old (s.key[n]) in
                   ((s.tag[n]) = ot) /\ ((s.key[n]) = ok)) }
    
    ensures { let oa = old s.alloct.M.domain in
              (Rgn.subset (Rgn.diff s.alloct.M.domain oa) (s.rep[self])) /\ (Rgn.mem result (Rgn.diff s.alloct.M.domain oa)) }
    
    ensures { s.pqueuePub }
  
  val deleteMin (s: state) (self: reference) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { not ((s.size[self]) = 0) }
    requires { s.pqueuePub }
    writes { s.slots, s.dSlots, s.sntl, s.sibling, s.prev, s.head, s.child, s.rep, s.tag, s.size, s.length, s.key, s.dLength, s.alloct }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`sntl] (wr_frame_sntl (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              -
              1 }
    
    ensures { let orep = old (s.rep[self]) in
              (s.rep[self])
              =
              orep }
    
    ensures { let rep2 = s.rep[self] in
              forall n : reference.
                (isAllocated s n)
                  ->
                  (hasNodeType s n)
                  ->
                  (Rgn.mem n rep2)
                  ->
                  (let otag = old (s.tag[n]) in
                   let okey = old (s.key[n]) in
                   ((s.tag[n]) = otag) /\ ((s.key[n]) = okey)) }
    
    ensures { s.pqueuePub }
  
  val decreaseKey (s: state) (self: reference) (handle: reference) (k: int) : 
    unit
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { hasNodeType s handle }
    requires { (handle <> null) }
    requires { Rgn.mem self s.pool }
    requires { let rep1 = s.rep[self] in
               Rgn.mem handle rep1 }
    requires { let key2 = s.key[handle] in
               k
               <=
               key2 }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.pqueuePub }
    writes { s.slots, s.dSlots, s.sntl, s.sibling, s.prev, s.head, s.child, s.rep, s.tag, s.size, s.length, s.key, s.dLength }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`sntl] (wr_frame_sntl (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.key[handle]) = k }
    
    ensures { s.pqueuePub }
end

module PqueueL
  use prelude.Prelude
  use State
  use PQUEUE
  
  predicate repClosed (s: state) (rep1: rgn) =
    (typeofRgn s rep1 (L.Cons Node L.Nil))
      /\
      (Rgn.mem null rep1)
      /\
      (Rgn.subset (img_sibling s rep1) rep1)
      /\
      (Rgn.subset (img_child s rep1) rep1)
      /\
      (Rgn.subset (img_prev s rep1) rep1)
  
  lemma repClosed_DEF:
    forall s : state.
      forall r : rgn.
        (repClosed s r)
          <->
          (typeofRgn s r (L.Cons Node L.Nil))
          /\
          (Rgn.mem null r)
          /\
          (forall n : reference.
             (isAllocated s n)
               ->
               (hasNodeType s n)
               ->
               (Rgn.mem n r)
               ->
               (let sib = s.sibling[n] in
                let pre = s.prev[n] in
                let chl = s.child[n] in
                (Rgn.mem sib r) /\ (Rgn.mem pre r) /\ (Rgn.mem chl r)))
  
  predicate strongDisjoint (s: state) (r: rgn) =
    forall p : reference, q : reference.
      (isAllocated s p)
        ->
        (hasPqueueType s p)
        ->
        (Rgn.mem p r)
        ->
        (isAllocated s q)
        ->
        (hasPqueueType s q)
        ->
        (Rgn.mem q r)
        ->
        (let prep = s.rep[p] in
         let qrep = s.rep[q] in
         (p <> q) -> ((Rgn.inter prep qrep) = (null.singleton)))
  
  predicate pqueueI (s: state) =
    forall p : reference.
      (isAllocated s p)
        ->
        (hasPqueueType s p)
        ->
        (Rgn.mem p s.pool)
        ->
        (let rep1 = s.rep[p] in
         let sz = s.size[p] in
         let hd = s.head[p] in
         (repClosed s rep1) /\ (sz >= 0) /\ (Rgn.mem hd rep1) /\ (sz = 0) <-> (hd = null))
  
  lemma disjointNotIn:
    forall s : state.
      forall r : rgn.
        forall p : reference, q : reference.
          (isAllocated s p)
            ->
            (hasPqueueType s p)
            ->
            (Rgn.mem p s.pool)
            ->
            (isAllocated s q)
            ->
            (hasPqueueType s q)
            ->
            (Rgn.mem q s.pool)
            ->
            (s.PQUEUE.pqueuePub)
            ->
            (p <> q)
            ->
            (let prep = s.rep[p] in
             let qrep = s.rep[q] in
             forall n : reference. (isAllocated s n) -> (hasNodeType s n) -> (Rgn.mem n prep) -> (not (Rgn.mem n qrep)))
  
  let init_Node (s : state) (self : reference) (k : int) (t : int) : 
    unit
    requires { hasNodeType s self }
    requires { (self <> null) }
    writes { s.key, s.tag }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`key] (wr_frame_key (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`tag] (wr_frame_tag (old s) s (self.singleton)) }
    
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.key[self]) = k }
    
    ensures { (s.tag[self]) = t }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let k = ref k in
      let t = ref t in
      ([@expl:self.key := k] (set_key s (! self) (! k)));
      ([@expl:self.tag := t] (set_tag s (! self) (! t)));
      (! result)
  
  let getTag (s : state) (self : reference) : int
    requires { hasNodeType s self }
    requires { (self <> null) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.tag[self]) = result }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref 0 in
      let self = ref self in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (result := ([@expl:result := self.tag] (s.tag[! self])));
      (! result)
  
  let getKey (s : state) (self : reference) : int
    requires { hasNodeType s self }
    requires { (self <> null) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.key[self]) = result }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref 0 in
      let self = ref self in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (result := ([@expl:result := self.key] (s.key[! self])));
      (! result)
  
  let init_Pqueue (s : state) (self : reference) : unit
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { ((s.rep[self]) = emptyRgn) /\ ((s.size[self]) = 0) /\ ((s.head[self]) = null) }
    requires { not (Rgn.mem self s.pool) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.pool, s.rep }
    ensures { (result = ()) }
    
    ensures { [@expl:wr ({self}`rep union {self})`rep] (wr_frame_rep (old s) s (Rgn.union (s.rep[self]) (self.singleton))) }
    
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { Rgn.mem self s.pool }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.subset rep1 (null.singleton) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff s.alloct.M.domain oa) (Rgn.union s.pool (s.rep[self])) }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref () in
      let self = ref self in
      ([@expl:self.rep := {null}] (set_rep s (! self) (null.singleton)));
      (set_pool s ([@expl:pool := pool union {self}] (Rgn.union s.pool ((! self).singleton))));
      (! result)
  
  let isEmpty (s : state) (self : reference) : bool
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { ((s.size[self]) = 0) <-> result }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref false in
      let self = ref self in
      let sz = ref 0 in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (sz := ([@expl:sz := self.size] (s.size[! self])));
      (result := ([@expl:result := sz = 0] ((! sz) = 0)));
      (! result)
  
  let findMin (s : state) (self : reference) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let hd = s.head[self] in
              result
              =
              hd }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref null in
      let self = ref self in
      assert { not ((s.head[! self]) = null) };
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (result := ([@expl:result := self.head] (s.head[! self])));
      (! result)
  
  let link (s : state) (self : reference) (first : reference) (second : reference) : 
    reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { hasNodeType s first }
    requires { (first <> null) }
    requires { hasNodeType s second }
    requires { (second <> null) }
    requires { Rgn.mem self s.pool }
    requires { let rep2 = s.rep[self] in
               (Rgn.mem first rep2) /\ (Rgn.mem second rep2) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.child, s.prev, s.sibling }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
    
    ensures { ((result = first) /\ ((s.child[first]) = second)) \/ (result = second) /\ ((s.child[second]) = first) }
    
    ensures { (result = first) \/ (result = second) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
  = label INIT in
      let result = ref null in
      let self = ref self in
      let first = ref first in
      let second = ref second in
      let fkey = ref 0 in
      let skey = ref 0 in
      let tmp = ref null in
      assert { hasNodeType s (! tmp) };
      (let ghost rep3 = ref emptyRgn in
       assert { isValidRgn s (! rep3) };
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (rep3 := ([@expl:rep := self.rep] (s.rep[! self])));
       assert {
         (Rgn.mem (! first) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
           \/
           ((! first) = null) };
       (fkey := ([@expl:fkey := first.key] (s.key[! first])));
       assert {
         (Rgn.mem (! second) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
           \/
           ((! second) = null) };
       (skey := ([@expl:skey := second.key] (s.key[! second])));
       (if ((! skey) < (! fkey)) then
          (assert {
             (Rgn.mem (! first) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
               \/
               (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
               \/
               ((! first) = null) };
           (tmp := ([@expl:tmp := first.prev] (s.prev[! first])));
           assert { Rgn.mem (! tmp) (! rep3) };
           ([@expl:second.prev := tmp] (set_prev s (! second) (! tmp)));
           ([@expl:first.prev := second] (set_prev s (! first) (! second)));
           assert { let p = s.prev[! first] in
                    Rgn.mem p (! rep3) };
           assert {
             (Rgn.mem (! second) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
               \/
               (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
               \/
               ((! second) = null) };
           (tmp := ([@expl:tmp := second.child] (s.child[! second])));
           ([@expl:first.sibling := tmp] (set_sibling s (! first) (! tmp)));
           (if ((! tmp) <>. null) then
              (assert {
                 (Rgn.mem (! first) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                   \/
                   (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
                   \/
                   ((! first) = null) };
               (tmp := ([@expl:tmp := first.sibling] (s.sibling[! first])));
               ([@expl:tmp.prev := first] (set_prev s (! tmp) (! first)));
               assert { Rgn.mem (! tmp) (! rep3) };
               assert { let p = s.prev[! tmp] in
                        Rgn.mem p (! rep3) };
               assert { repClosed s (! rep3) })
            else ());
           ([@expl:second.child := first] (set_child s (! second) (! first)));
           (result := ([@expl:result := second] (! second)));
           assert { repClosed s (! rep3) })
        else
          (([@expl:second.prev := first] (set_prev s (! second) (! first)));
           assert {
             (Rgn.mem (! second) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
               \/
               (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
               \/
               ((! second) = null) };
           (tmp := ([@expl:tmp := second.sibling] (s.sibling[! second])));
           assert { Rgn.mem (! tmp) (! rep3) };
           ([@expl:first.sibling := tmp] (set_sibling s (! first) (! tmp)));
           (if ((! tmp) <>. null) then
              (assert {
                 (Rgn.mem (! first) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                   \/
                   (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
                   \/
                   ((! first) = null) };
               (tmp := ([@expl:tmp := first.sibling] (s.sibling[! first])));
               assert { Rgn.mem (! tmp) (! rep3) };
               ([@expl:tmp.prev := first] (set_prev s (! tmp) (! first))))
            else ());
           assert {
             (Rgn.mem (! first) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
               \/
               (not (Rgn.mem (! first) (s.alloct.M.domain at INIT)))
               \/
               ((! first) = null) };
           (tmp := ([@expl:tmp := first.child] (s.child[! first])));
           ([@expl:second.sibling := tmp] (set_sibling s (! second) (! tmp)));
           (if ((! tmp) <>. null) then
              (assert {
                 (Rgn.mem (! second) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                   \/
                   (not (Rgn.mem (! second) (s.alloct.M.domain at INIT)))
                   \/
                   ((! second) = null) };
               (tmp := ([@expl:tmp := second.sibling] (s.sibling[! second])));
               assert { Rgn.mem (! tmp) (! rep3) };
               ([@expl:tmp.prev := second] (set_prev s (! tmp) (! second))))
            else ());
           ([@expl:first.child := second] (set_child s (! first) (! second)));
           (result := ([@expl:result := first] (! first)));
           assert { repClosed s (! rep3) }));
       (! result))
  
  lemma insert_wr_rgn_eq:
    forall s : state.
      forall self1 : reference, n : reference.
        (isAllocated s self1)
          ->
          (hasPqueueType s self1)
          ->
          (isAllocated s n)
          ->
          (hasNodeType s n)
          ->
          (let rep2 = s.rep[self1] in
           (Rgn.mem n rep2) -> ((Rgn.union (n.singleton) (s.rep[self1])) = (s.rep[self1])))
  
  lemma img_rep_lem:
    forall s : state. forall self1 : reference. (isAllocated s self1) -> (hasPqueueType s self1) -> ((s.rep[self1]) = (s.rep[self1]))
  
  let insert (s : state) (self : reference) (k : int) (t : int) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.alloct, s.child, s.head, s.key, s.prev, s.rep, s.sibling, s.size, s.tag }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    
    ensures { let orep = old (s.rep[self]) in
              (s.rep[self])
              =
              (Rgn.union orep (result.singleton)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              +
              1 }
    
    ensures { (s.key[result]) = k }
    
    ensures { (s.tag[result]) = t }
    
    ensures { let rep2 = s.rep[self] in
              forall n : reference.
                (isAllocated s n)
                  ->
                  (hasNodeType s n)
                  ->
                  (Rgn.mem n rep2)
                  ->
                  (n <> result)
                  ->
                  (let ot = old (s.tag[n]) in
                   let ok = old (s.key[n]) in
                   ((s.tag[n]) = ot) /\ ((s.key[n]) = ok)) }
    
    ensures { let oa = old s.alloct.M.domain in
              (Rgn.subset (Rgn.diff s.alloct.M.domain oa) (s.rep[self])) /\ (Rgn.mem result (Rgn.diff s.alloct.M.domain oa)) }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref null in
      let self = ref self in
      let k = ref k in
      let t = ref t in
      assert { s.PQUEUE.pqueuePub };
      (result := ([@expl:result := new Node] (s.mk_Node)));
      assert { s.pqueueI };
      assert { (! result) <> null };
      assert {
        (Rgn.mem (! result) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
          \/
          (not (Rgn.mem (! result) (s.alloct.M.domain at INIT)))
          \/
          ((! result) = null) };
      ([@expl:Node(result,k,t)] (init_Node s (! result) (! k) (! t)));
      assert { s.PQUEUE.pqueuePub };
      assert {
        forall p : reference.
          (isAllocated s p) -> (hasPqueueType s p) -> (Rgn.mem p s.pool) -> (let rep3 = s.rep[p] in
                                                                    not (Rgn.mem (! result) rep3)) };
      assert { s.pqueueI };
      (let ghost rep4 = ref emptyRgn in
       assert { isValidRgn s (! rep4) };
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (rep4 := ([@expl:rep := self.rep] (s.rep[! self])));
       ([@expl:self.rep := rep union {result}] (set_rep s (! self) (Rgn.union (! rep4) ((! result).singleton))));
       assert {
         forall p : reference.
           (isAllocated s p)
             ->
             (hasPqueueType s p)
             ->
             (Rgn.mem p s.pool)
             ->
             (p <> (! self))
             ->
             (let prep = s.rep[p] in
              not (Rgn.mem (! result) prep)) };
       assert {
         forall p : reference.
           (isAllocated s p)
             ->
             (hasPqueueType s p)
             ->
             (Rgn.mem p s.pool)
             ->
             (p <> (! self))
             ->
             (let prep = s.rep[p] in
              let srep = s.rep[! self] in
              srep \# prep) };
       assert {
         forall p : reference, q : reference.
           (isAllocated s p)
             ->
             (hasPqueueType s p)
             ->
             (Rgn.mem p s.pool)
             ->
             (isAllocated s q)
             ->
             (hasPqueueType s q)
             ->
             (Rgn.mem q s.pool)
             ->
             (p <> q)
             ->
             (p <> (! self))
             ->
             (q <> (! self))
             ->
             (let prep = s.rep[p] in
              let qrep = s.rep[q] in
              prep \# qrep) };
       assert { s.PQUEUE.pqueuePub };
       assert { let rep5 = s.rep[! self] in
                repClosed s rep5 };
       assert { s.pqueueI };
       (let hd = ref null in
        assert { hasNodeType s (! hd) };
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (hd := ([@expl:hd := self.head] (s.head[! self])));
        (if ((! hd) =. null) then
           (assert { let rep6 = s.rep[! self] in
                     repClosed s rep6 };
            ([@expl:self.head := result] (set_head s (! self) (! result)));
            assert { (s.head[! self]) = (! result) };
            assert { let hd7 = s.head[! self] in
                     let rep8 = s.rep[! self] in
                     Rgn.mem hd7 rep8 };
            assert { let hd9 = s.head[! self] in
                     ((s.sibling[hd9]) = null) /\ ((s.prev[hd9]) = null) /\ ((s.child[hd9]) = null) })
         else
           (let tmp = ref null in
            assert { hasNodeType s (! tmp) };
            assert {
              Rgn.subset
                 (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
                 (Rgn.union
                     ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                     (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
            (tmp := ([@expl:tmp := link(self,hd,result)] (link s (! self) (! hd) (! result))));
            ([@expl:self.head := tmp] (set_head s (! self) (! tmp)));
            assert { let hd10 = s.head[! self] in
                     let rep11 = s.rep[! self] in
                     Rgn.mem hd10 rep11 }));
        (let sz = ref 0 in
         assert {
           (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
             \/
             ((! self) = null) };
         (sz := ([@expl:sz := self.size] (s.size[! self])));
         ([@expl:self.size := sz + 1] (set_size s (! self) ((! sz) + 1)));
         (! result))))
  
  let combineAux (s : state) (self : reference) (handle : reference) : 
    reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { hasNodeType s handle }
    requires { (handle <> null) }
    requires { Rgn.mem self s.pool }
    requires { not ((s.size[self]) = 0) }
    requires { let rep2 = s.rep[self] in
               Rgn.mem handle rep2 }
    requires { not ((s.sibling[handle]) = null) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.alloct, s.child, s.length, s.prev, s.sibling, s.slots }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {}`length] (wr_frame_length (old s) s emptyRgn) }
    
    ensures { [@expl:wr {}`slots] (wr_frame_slots (old s) s emptyRgn) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r27 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r27 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    diverges
  = label INIT in
      let result = ref null in
      let self = ref self in
      let handle = ref handle in
      let trees = ref null in
      assert { hasNodeArrayType s (! trees) };
      (let index = ref 0 in
       let current = ref null in
       assert { hasNodeType s (! current) };
       (let tmp = ref null in
        assert { hasNodeType s (! tmp) };
        (let fst = ref null in
         assert { hasNodeType s (! fst) };
         (let snd = ref null in
          assert { hasNodeType s (! snd) };
          (let i = ref 0 in
           let j = ref 0 in
           (trees := ([@expl:trees := new(NodeArray){1024}] (s.mk_NodeArray)));
           ([@expl:trees := new(NodeArray){1024}] (set_length s (! trees) 1024));
           ([@expl:trees := new(NodeArray){1024}] (set_slots s (! trees) (A.make 1024 null)));
           (set_slots s (! trees) ([@expl:trees.{0} := handle] (A.set (s.slots[! trees]) 0 (! handle))));
           assert { not ((A.get (s.slots[! trees]) 0) = null) };
           assert {
             forall p : reference.
               (isAllocated s p) -> (hasNodeArrayType s p) -> (p <> (! trees)) -> (let s3 = old (s.slots[p]) in
                                                                    (s.slots[p])
                                                                    =
                                                                    s3) };
           (index := ([@expl:index := 1] 1));
           assert {
             (Rgn.mem (! handle) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
               \/
               (not (Rgn.mem (! handle) (s.alloct.M.domain at INIT)))
               \/
               ((! handle) = null) };
           (current := ([@expl:current := handle.sibling] (s.sibling[! handle])));
           while ((! current) <>. null) do
             invariant {
               [@expl:locals type invariant]
               ((hasNodeType s (! current))
                  /\
                  (hasNodeType s (! fst))
                  /\
                  (hasNodeType s (! handle))
                  /\
                  (hasNodeType s (! result))
                  /\
                  (hasPqueueType s (! self))
                  /\
                  (hasNodeType s (! snd))
                  /\
                  (hasNodeType s (! tmp))
                  /\
                  (hasNodeArrayType s (! trees))) }
             invariant { alloc_does_not_shrink (old s) s }
             invariant { [@expl:wr {trees}`slots] (wr_frame_slots (old s) s ((! trees).singleton)) }
             invariant { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[! self])) }
             invariant { (1 <= (! index)) /\ (let l = s.length[! trees] in
                                              (! index)
                                              <
                                              l) }
             invariant { forall k4 : int. (0 <= k4) -> (k4 < (! index)) -> (not ((A.get (s.slots[! trees]) k4) = null)) }
             invariant {
               let l = s.length[! trees] in
               forall k5 : int. ((! index) <= k5) -> (k5 < l) -> ((A.get (s.slots[! trees]) k5) = null) }
             invariant {
               forall k6 : int.
                 (0 <= k6) -> (k6 < (! index)) -> (let n = A.get (s.slots[! trees]) k6 in
                                                   let rep7 = s.rep[! self] in
                                                   Rgn.mem n rep7) }
             invariant { let rep8 = s.rep[! self] in
                         Rgn.mem (! current) rep8 }
             invariant { let rep9 = s.rep[! self] in
                         repClosed s rep9 }
             invariant { s.PQUEUE.pqueuePub }
