              ohd }
    diverges
  = label INIT in
      let result = ref null in
      let self = ref self in
      let handle = ref handle in
      let tmp = ref null in
      assert { hasNodeType s (! tmp) };
      (let sntl3 = ref null in
       assert { hasNodeType s (! sntl3) };
       assert {
         (Rgn.mem (! handle) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! handle) (s.alloct.M.domain at INIT)))
           \/
           ((! handle) = null) };
       (tmp := ([@expl:tmp := handle.sibling] (s.sibling[! handle])));
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (sntl3 := ([@expl:sntl := self.sntl] (s.sntl[! self])));
       (if ((! tmp) =. (! sntl3)) then (result := ([@expl:result := handle] (! handle)))
        else
          (assert {
             Rgn.subset
                (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
                (Rgn.union
                    ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                    (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
           (result := ([@expl:result := combineAux(self,handle)] (combineAux s (! self) (! handle))))));
       (! result))
  
  let deleteMin (s : state) (self : reference) : reference
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { not ((s.size[self]) = 0) }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.alloct, s.child, s.head, s.length, s.prev, s.sibling, s.size, s.slots }
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              -
              1 }
    
    ensures { let orep = old (s.rep[self]) in
              (s.rep[self])
              =
              orep }
    
    ensures { let rep2 = s.rep[self] in
              forall n : reference.
                (isAllocated s n)
                  ->
                  (hasNodeType s n)
                  ->
                  (Rgn.mem n rep2)
                  ->
                  (let otag = old (s.tag[n]) in
                   let okey = old (s.key[n]) in
                   ((s.tag[n]) = otag) /\ ((s.key[n]) = okey)) }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
    diverges
  = label INIT in
      let result = ref null in
      let self = ref self in
      assert {
        (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
          \/
          (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
          \/
          ((! self) = null) };
      (result := ([@expl:result := findMin(self)] (findMin s (! self))));
      (let tmp = ref null in
       assert { hasNodeType s (! tmp) };
       (let sntl3 = ref null in
        assert { hasNodeType s (! sntl3) };
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (sntl3 := ([@expl:sntl := self.sntl] (s.sntl[! self])));
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (tmp := ([@expl:tmp := self.head] (s.head[! self])));
        assert {
          (Rgn.mem (! tmp) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
            \/
            (not (Rgn.mem (! tmp) (s.alloct.M.domain at INIT)))
            \/
            ((! tmp) = null) };
        (tmp := ([@expl:tmp := tmp.child] (s.child[! tmp])));
        (if ((! tmp) =. (! sntl3)) then (assume { (s.size[! self]) = 1 }; ([@expl:self.head := sntl] (set_head s (! self) (! sntl3))))
         else
           (assume { let sz = s.size[! self] in
                     sz
                     >
                     1 };
            assert {
              Rgn.subset
                 (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
                 (Rgn.union
                     ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                     (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
            (tmp := ([@expl:tmp := combine(self,tmp)] (combine s (! self) (! tmp))));
            ([@expl:self.head := tmp] (set_head s (! self) (! tmp)))));
        (let sz = ref 0 in
         assert {
           (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
             \/
             ((! self) = null) };
         (sz := ([@expl:sz := self.size] (s.size[! self])));
         ([@expl:self.size := sz - 1] (set_size s (! self) ((! sz) - 1)));
         (! result))))
  
  let decreaseKey (s : state) (self : reference) (handle : reference) (k : int) : 
    unit
    requires { hasPqueueType s self }
    requires { (self <> null) }
    requires { hasNodeType s handle }
    requires { (handle <> null) }
    requires { Rgn.mem self s.pool }
    requires { let rep1 = s.rep[self] in
               Rgn.mem handle rep1 }
    requires { let key2 = s.key[handle] in
               k
               <=
               key2 }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.PQUEUE.pqueuePub }
    requires { s.pqueueI }
    writes { s.child, s.head, s.key, s.prev, s.sibling }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r40 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r40 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.key[handle]) = k }
    
    ensures { s.PQUEUE.pqueuePub }
    
    ensures { s.pqueueI }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let handle = ref handle in
      let k = ref k in
      let tmp = ref null in
      assert { hasNodeType s (! tmp) };
      (let pos = ref null in
       assert { hasNodeType s (! pos) };
       (let sntl3 = ref null in
        assert { hasNodeType s (! sntl3) };
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (sntl3 := ([@expl:sntl := self.sntl] (s.sntl[! self])));
        ([@expl:handle.key := k] (set_key s (! handle) (! k)));
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (tmp := ([@expl:tmp := self.head] (s.head[! self])));
        assert { repOk s (! self) };
        (if ((! handle) <>. (! tmp)) then
           (assert {
              (Rgn.mem (! handle) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                \/
                (not (Rgn.mem (! handle) (s.alloct.M.domain at INIT)))
                \/
                ((! handle) = null) };
            (tmp := ([@expl:tmp := handle.sibling] (s.sibling[! handle])));
            (if ((! tmp) <>. (! sntl3)) then
               (assert {
                  (Rgn.mem (! handle) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                    \/
                    (not (Rgn.mem (! handle) (s.alloct.M.domain at INIT)))
                    \/
                    ((! handle) = null) };
                (pos := ([@expl:pos := handle.prev] (s.prev[! handle])));
                ([@expl:tmp.prev := pos] (set_prev s (! tmp) (! pos)));
                assert { repOk s (! self) })
             else ());
            assert {
              (Rgn.mem (! handle) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                \/
                (not (Rgn.mem (! handle) (s.alloct.M.domain at INIT)))
                \/
                ((! handle) = null) };
            (tmp := ([@expl:tmp := handle.prev] (s.prev[! handle])));
            (if ((! tmp) <>. (! sntl3)) then
               (assert {
                  (Rgn.mem (! tmp) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                    \/
                    (not (Rgn.mem (! tmp) (s.alloct.M.domain at INIT)))
                    \/
                    ((! tmp) = null) };
                (pos := ([@expl:pos := tmp.child] (s.child[! tmp])));
                (if ((! pos) =. (! handle)) then
                   (assert {
                      (Rgn.mem (! handle) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                        \/
                        (not (Rgn.mem (! handle) (s.alloct.M.domain at INIT)))
                        \/
                        ((! handle) = null) };
                    (pos := ([@expl:pos := handle.sibling] (s.sibling[! handle])));
                    ([@expl:tmp.child := pos] (set_child s (! tmp) (! pos))))
                 else
                   (assert { not ((s.prev[! handle]) = (! sntl3)) };
                    assert {
                      (Rgn.mem (! handle) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                        \/
                        (not (Rgn.mem (! handle) (s.alloct.M.domain at INIT)))
                        \/
                        ((! handle) = null) };
                    (pos := ([@expl:pos := handle.sibling] (s.sibling[! handle])));
                    ([@expl:tmp.sibling := pos] (set_sibling s (! tmp) (! pos)));
                    assert { ((! pos) <> (! sntl3)) -> (let rep4 = s.rep[! self] in
                                                        let s5 = s.sibling[! tmp] in
                                                        Rgn.mem s5 rep4) }));
                assert {
                  forall p : reference.
                    (isAllocated s p)
                      ->
                      (hasNodeType s p)
                      ->
                      (let r = s.rep[! self] in
                       (not (Rgn.mem p r)) -> (let sib = old (s.sibling[p]) in
                                               (s.sibling[p])
                                               =
                                               sib)) })
             else ());
            ([@expl:handle.sibling := sntl] (set_sibling s (! handle) (! sntl3)));
            assert {
              (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
                \/
                (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
                \/
                ((! self) = null) };
            (pos := ([@expl:pos := self.head] (s.head[! self])));
            assert {
              Rgn.subset
                 (Rgn.diff (Rgn.union ((! self).singleton) (s.rep[! self])) (null.singleton))
                 (Rgn.union
                     ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT)
                     (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
            (tmp := ([@expl:tmp := link(self,pos,handle)] (link s (! self) (! pos) (! handle))));
            ([@expl:self.head := tmp] (set_head s (! self) (! tmp))))
         else ());
        (! result)))
  
  lemma boundary_frames_invariant_PqueueR:
    forall s : state, t6 : state, pi : PreRefperm.t.
      (okRefperm s t6 pi)
        ->
        (PreRefperm.identity pi s.alloct.M.domain t6.alloct.M.domain)
        ->
        (PreRefperm.idRgn pi s.pool t6.pool)
        ->
        (agree_allfields s t6 pi (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (s.pqueueI)
        ->
        (t6.pqueueI)
end

module PQUEUE_REL
  use prelude.Prelude
  use State
  use PqueueL
  use PqueueR
  
  predicate coupling0 (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_pq: reference) (r_pq: reference) =
    (okRefperm l_s r_s pi)
      ->
      (hasPqueueType l_s l_pq)
      ->
      (hasPqueueType r_s r_pq)
      ->
      ((l_pq <> null) /\ (r_pq <> null))
      ->
      (PreRefperm.idRef pi l_pq r_pq)
      ->
      (let l_sntl = l_s.sntl[l_pq] in
       let r_sntl = r_s.sntl[r_pq] in
       let l_rep = l_s.rep[l_pq] in
       let r_rep = r_s.rep[r_pq] in
       let l_hd = l_s.head[l_pq] in
       let r_hd = r_s.head[r_pq] in
       let l_sz = l_s.size[l_pq] in
       let r_sz = r_s.size[r_pq] in
       (l_sz = r_sz)
         /\
         ((PreRefperm.idRef pi l_hd r_hd) \/ (l_hd = null) /\ (r_hd = r_sntl))
         /\
         (PreRefperm.idRgn pi (rgnSubK l_rep l_s.alloct Node) (rgnSubK r_rep r_s.alloct Node))
         /\
         (forall l_n : reference, r_n : reference.
            (isAllocated l_s l_n)
              ->
              (hasNodeType l_s l_n)
              ->
              (Rgn.mem l_n l_rep)
              ->
              (isAllocated r_s r_n)
              ->
              (hasNodeType r_s r_n)
              ->
              (Rgn.mem r_n r_rep)
              ->
              (PreRefperm.idRef pi l_n r_n)
              ->
              (let l_k = l_s.key[l_n] in
               let r_k = r_s.key[r_n] in
               let l_t = l_s.tag[l_n] in
               let r_t = r_s.tag[r_n] in
               let l_pre = l_s.prev[l_n] in
               let r_pre = r_s.prev[r_n] in
               let l_sib = l_s.sibling[l_n] in
               let r_sib = r_s.sibling[r_n] in
               let l_chl = l_s.child[l_n] in
               let r_chl = r_s.child[r_n] in
               (l_k = r_k)
                 /\
                 (l_t = r_t)
                 /\
                 (((PreRefperm.idRef pi l_pre r_pre) /\ (l_pre <> null) /\ (r_pre <> r_sntl)) \/ (l_pre = null) /\ (r_pre = r_sntl))
                 /\
                 (((PreRefperm.idRef pi l_sib r_sib) /\ (l_sib <> null) /\ (r_sib <> r_sntl)) \/ (l_sib = null) /\ (r_sib = r_sntl))
                 /\
                 ((PreRefperm.idRef pi l_chl r_chl) /\ (l_chl <> null) /\ (r_chl <> r_sntl))
                 \/
                 (l_chl = null)
                 /\
                 (r_chl = r_sntl))))
  
  predicate pqueueR (l_s: state) (r_s: state) (pi: PreRefperm.t) =
    (okRefperm l_s r_s pi)
      ->
      (PreRefperm.idRgn pi (rgnSubK l_s.pool l_s.alloct Pqueue) (rgnSubK r_s.pool r_s.alloct Pqueue))
      /\
      (forall l_pq : reference, r_pq : reference.
         (isAllocated l_s l_pq)
           ->
           (hasPqueueType l_s l_pq)
           ->
           (Rgn.mem l_pq l_s.pool)
           ->
           (isAllocated r_s r_pq)
           ->
           (hasPqueueType r_s r_pq)
           ->
           (Rgn.mem r_pq r_s.pool)
           ->
           (PreRefperm.idRef pi l_pq r_pq)
           ->
           (coupling0 l_s r_s pi l_pq r_pq))
      /\
      ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI))
      /\
      ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub))
  
  let isEmpty (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_self : reference) (r_self : reference) : 
    (bool, bool)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { pqueueR l_s r_s pi }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((agree_size l_s r_s pi (l_self.singleton)) /\ (agree_size r_s l_s (pi.PreRefperm.invert) (r_self.singleton))) }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { pqueueR l_s r_s pi }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
  = label INIT in
      let r_result = ref false in
      let l_result = ref false in
      let l_self = ref l_self in
      let r_self = ref r_self in
      let l_sz = ref 0 in
      let r_sz = ref 0 in
      (l_sz := ([@expl:sz := self.size] (l_s.size[! l_self])));
      (r_sz := ([@expl:sz := self.size] (r_s.size[! r_self])));
      (l_result := ([@expl:result := sz = 0] ((! l_sz) = 0)));
      (r_result := ([@expl:result := sz = 0] ((! r_sz) = 0)));
      ((! l_result), (! r_result))
  
  let findMin (l_s : state) (r_s : state) (pi7 : PreRefperm.t) (l_self : reference) (r_self : reference) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi7 }
    requires { pqueueR l_s r_s pi7 }
    requires { PreRefperm.idRef pi7 l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((let sz = l_s.size[l_self] in
                 sz
                 >
                 0) /\ (let sz = r_s.size[r_self] in
                        sz
                        >
                        0)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { okRefperm l_s r_s pi7 }
    
    ensures { pqueueR l_s r_s pi7 }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi7 l_result r_result
              end }
    
    ensures { match result with
              | (l_result, r_result) -> ((let hd = l_s.head[l_self] in
                                          l_result
                                          =
                                          hd) /\ (let hd = r_s.head[r_self] in
                                                  r_result
                                                  =
                                                  hd))
              end }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi7 (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi7.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  = label INIT in
      let r_result = ref null in
      let l_result = ref null in
      let l_self = ref l_self in
      let r_self = ref r_self in
      assert { (not ((l_s.head[! l_self]) = null)) /\ (let sntl8 = r_s.sntl[! r_self] in
                                                       not ((r_s.head[! r_self]) = sntl8)) };
      (l_result := ([@expl:result := self.head] (l_s.head[! l_self])));
      (r_result := ([@expl:result := self.head] (r_s.head[! r_self])));
      ((! l_result), (! r_result))
  
  val link (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (l_first: reference) (l_second: reference) (r_self: reference) (r_first: reference) (r_second: reference) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasNodeType l_s l_first }
    requires { (l_first <> null) }
    requires { hasNodeType l_s l_second }
    requires { (l_second <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { hasNodeType r_s r_first }
    requires { (r_first <> null) }
    requires { hasNodeType r_s r_second }
    requires { (r_second <> null) }
    requires { okRefperm l_s r_s pi }
    requires { PreRefperm.idRef pi l_second r_second }
    requires { PreRefperm.idRef pi l_first r_first }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { pqueueR l_s r_s pi }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((let rep9 = l_s.rep[l_self] in
                 (Rgn.mem l_first rep9) /\ (Rgn.mem l_second rep9)) /\
                  (let rep10 = r_s.rep[r_self] in
                   (Rgn.mem r_first rep10) /\ (Rgn.mem r_second rep10)))
    }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.child, l_s.prev, l_s.sibling, r_s.child, r_s.prev, r_s.sibling }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { pqueueR l_s r_s pi }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi l_result r_result
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  (((l_result = l_first) \/ (l_result = l_second)) /\ ((r_result = r_first) \/ (r_result = r_second)))
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((((l_result = l_first) /\ ((l_s.child[l_first]) = l_second))
                      \/
                      (l_result = l_second)
                      /\
                      ((l_s.child[l_second]) = l_first)) /\
                     (((r_result = r_first) /\ ((r_s.child[r_first]) = r_second))
                        \/
                        (r_result = r_second)
                        /\
                        ((r_s.child[r_second]) = r_first)))
              end }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  
  let insert (l_s : state) (r_s : state) (pi11 : PreRefperm.t) (l_self : reference) (l_k : int) (l_t : int) (r_self : reference) (r_k : int) (r_t : int) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi11 }
    requires { pqueueR l_s r_s pi11 }
    requires { (l_t = r_t) }
    requires { (l_k = r_k) }
    requires { PreRefperm.idRef pi11 l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { pi11,
      l_s.alloct,
      l_s.child,
      l_s.head,
      l_s.key,
      l_s.prev,
      l_s.rep,
      l_s.sibling,
      l_s.size,
      l_s.tag,
      r_s.alloct,
      r_s.child,
      r_s.head,
      r_s.key,
      r_s.prev,
      r_s.rep,
      r_s.sibling,
      r_s.size,
      r_s.tag }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi11 }
    
    ensures { pqueueR l_s r_s pi11 }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let rep12 = l_s.rep[l_self] in
                    forall n : reference.
                      (isAllocated l_s n)
                        ->
                        (hasNodeType l_s n)
                        ->
                        (Rgn.mem n rep12)
                        ->
                        (n <> l_result)
                        ->
                        (let ot = old (l_s.tag[n]) in
                         let ok = old (l_s.key[n]) in
                         ((l_s.tag[n]) = ot) /\ ((l_s.key[n]) = ok))) /\
                     (let rep13 = r_s.rep[r_self] in
                      forall n : reference.
                        (isAllocated r_s n)
                          ->
                          (hasNodeType r_s n)
                          ->
                          (Rgn.mem n rep13)
                          ->
                          (n <> r_result)
                          ->
                          (let ot = old (r_s.tag[n]) in
                           let ok = old (r_s.key[n]) in
                           ((r_s.tag[n]) = ot) /\ ((r_s.key[n]) = ok))))
              end }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi11 l_result r_result
              end }
    
    ensures { match result with
              | (l_result, r_result) -> (((l_s.tag[l_result]) = l_t) /\ ((r_s.tag[r_result]) = r_t))
              end }
    
    ensures { match result with
              | (l_result, r_result) -> (((l_s.key[l_result]) = l_k) /\ ((r_s.key[r_result]) = r_k))
              end }
    
    ensures { ((let osz = old (l_s.size[l_self]) in
                (l_s.size[l_self])
                =
                osz
                +
                1) /\
                 (let osz = old (r_s.size[r_self]) in
                  (r_s.size[r_self])
                  =
                  osz
                  +
                  1)) }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let orep = old (l_s.rep[l_self]) in
                    (l_s.rep[l_self])
                    =
                    (Rgn.union orep (l_result.singleton))) /\
                     (let orep = old (r_s.rep[r_self]) in
                      (r_s.rep[r_self])
                      =
                      (Rgn.union orep (r_result.singleton))))
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let rep14 = l_s.rep[l_self] in
                    Rgn.mem l_result rep14) /\ (let rep15 = r_s.rep[r_self] in
                                                Rgn.mem r_result rep15))
              end }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  = label INIT in
      let r_result = ref null in
      let l_result = ref null in
      let l_self = ref l_self in
      let l_k = ref l_k in
      let l_t = ref l_t in
      let r_self = ref r_self in
      let r_k = ref r_k in
      let r_t = ref r_t in
      assert { coupling0 l_s r_s pi11 (! l_self) (! r_self) };
      (let l_sntl = ref null in
       let r_sntl = ref null in
       (r_sntl := ([@expl:sntl := self.sntl] (r_s.sntl[! r_self])));
       (l_result := ([@expl:result := new Node] (l_s.mk_Node)));
       (r_result := ([@expl:result := new Node] (r_s.mk_Node)));
       ([@expl:Node(result,k,t)] (PqueueL.init_Node l_s (! l_result) (! l_k) (! l_t)));
       ([@expl:Node(result,k,t)] (PqueueR.init_Node r_s (! r_result) (! r_k) (! r_t)));
       ([@expl:result.sibling := sntl] (set_sibling r_s (! r_result) (! r_sntl)));
       ([@expl:result.child := sntl] (set_child r_s (! r_result) (! r_sntl)));
       ([@expl:result.prev := sntl] (set_prev r_s (! r_result) (! r_sntl)));
       (PreRefperm.updateRefperm pi11 (! l_result) (! r_result));
       assert { PreRefperm.idRef pi11 (! l_result) (! r_result) };
       assert {
         (((l_s.sibling[! l_result]) = null) /\ ((l_s.child[! l_result]) = null) /\ ((l_s.prev[! l_result]) = null))
           /\
           ((r_s.sibling[! r_result]) = (! r_sntl))
           /\
           ((r_s.child[! r_result]) = (! r_sntl))
           /\
           ((r_s.prev[! r_result]) = (! r_sntl)) };
       (let ghost l_rep = ref emptyRgn in
        let ghost r_rep = ref emptyRgn in
        (l_rep := ([@expl:rep := self.rep] (l_s.rep[! l_self])));
        (r_rep := ([@expl:rep := self.rep] (r_s.rep[! r_self])));
        ([@expl:self.rep := rep union {result}] (set_rep l_s (! l_self) (Rgn.union (! l_rep) ((! l_result).singleton))));
        ([@expl:self.rep := rep union {result}] (set_rep r_s (! r_self) (Rgn.union (! r_rep) ((! r_result).singleton))));
        (let l_hd = ref null in
         let r_hd = ref null in
         (l_hd := ([@expl:hd := self.head] (l_s.head[! l_self])));
         (r_hd := ([@expl:hd := self.head] (r_s.head[! r_self])));
         assert { ((l_s.head[! l_self]) = null) <-> ((r_s.head[! r_self]) = (! r_sntl)) };
         ([@expl:guard agreement] assert { (((! l_hd) = null) = ((! r_hd) = (! r_sntl))) });
         (if ((! l_hd) =. null) then
            (([@expl:self.head := result] (set_head l_s (! l_self) (! l_result)));
             ([@expl:self.head := result] (set_head r_s (! r_self) (! r_result)));
             assert { let l_hd = l_s.head[! l_self] in
                      let r_hd = r_s.head[! r_self] in
                      PreRefperm.idRef pi11 l_hd r_hd };
             assert {
               forall l_pq : reference, r_pq : reference.
                 (isAllocated l_s l_pq)
                   ->
                   (hasPqueueType l_s l_pq)
                   ->
                   (Rgn.mem l_pq l_s.pool)
                   ->
                   (isAllocated r_s r_pq)
                   ->
                   (hasPqueueType r_s r_pq)
                   ->
                   (Rgn.mem r_pq r_s.pool)
                   ->
                   (PreRefperm.idRef pi11 l_pq r_pq)
                   ->
                   (let l_hd = l_s.head[l_pq] in
                    let r_hd = r_s.head[r_pq] in
                    (PreRefperm.idRef pi11 l_hd r_hd) \/ (l_hd = null) /\ ((r_s.sntl[r_pq]) = r_hd)) };
             assert { coupling0 l_s r_s pi11 (! l_self) (! r_self) })
          else
            (assert { coupling0 l_s r_s pi11 (! l_self) (! r_self) };
             (let l_tmp = ref null in
              let r_tmp = ref null in
              assume {
                ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) /\ ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) };
              (match link l_s r_s pi11 (! l_self) (! l_hd) (! l_result) (! r_self) (! r_hd) (! r_result) with
               | (l_link_res, r_link_res) ->
                   (l_tmp := ([@expl:tmp := link(self,hd,result)] l_link_res));
                   (r_tmp := ([@expl:tmp := link(self,hd,result)] r_link_res))
               end);
              ([@expl:self.head := tmp] (set_head l_s (! l_self) (! l_tmp)));
              ([@expl:self.head := tmp] (set_head r_s (! r_self) (! r_tmp))))));
         (let l_sz = ref 0 in
          let r_sz = ref 0 in
          (l_sz := ([@expl:sz := self.size] (l_s.size[! l_self])));
          (r_sz := ([@expl:sz := self.size] (r_s.size[! r_self])));
          assert { ((! l_sz) = (! r_sz)) };
          ([@expl:self.size := sz + 1] (set_size l_s (! l_self) ((! l_sz) + 1)));
          ([@expl:self.size := sz + 1] (set_size r_s (! r_self) ((! r_sz) + 1)));
          assume {
            ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) /\ ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) };
          ((! l_result), (! r_result))))))
  
  val combine (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (l_handle: reference) (r_self: reference) (r_handle: reference) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasNodeType l_s l_handle }
    requires { (l_handle <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { hasNodeType r_s r_handle }
    requires { (r_handle <> null) }
    requires { okRefperm l_s r_s pi }
    requires { pqueueR l_s r_s pi }
    requires { PreRefperm.idRef pi l_handle r_handle }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((not ((l_s.size[l_self]) = 0)) /\ (not ((r_s.size[r_self]) = 0))) }
    requires { ((let rep16 = l_s.rep[l_self] in
                 Rgn.mem l_handle rep16) /\ (let rep17 = r_s.rep[r_self] in
                                             Rgn.mem r_handle rep17)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.child, l_s.prev, l_s.sibling, l_s.alloct, r_s.child, r_s.prev, r_s.sibling, r_s.alloct }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi l_result r_result
              end }
    
    ensures { pqueueR l_s r_s pi }
    
    ensures { ((let ohd = old (l_s.head[l_self]) in
                (l_s.head[l_self])
                =
                ohd) /\
                 (let ohd = old (r_s.head[r_self]) in
                  (r_s.head[r_self])
                  =
                  ohd)) }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let rep18 = l_s.rep[l_self] in
                    Rgn.mem l_result rep18) /\ (let rep19 = r_s.rep[r_self] in
                                                Rgn.mem r_result rep19))
              end }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  
  let deleteMin (l_s : state) (r_s : state) (pi20 : PreRefperm.t) (l_self : reference) (r_self : reference) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi20 }
    requires { pqueueR l_s r_s pi20 }
    requires { PreRefperm.idRef pi20 l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((not ((l_s.size[l_self]) = 0)) /\ (not ((r_s.size[r_self]) = 0))) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.alloct,
      l_s.child,
      l_s.head,
      l_s.length,
      l_s.prev,
      l_s.sibling,
      l_s.size,
