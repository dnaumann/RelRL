  lemma boundary_frames_invariant_PqueueL:
    forall s : state, t7 : state, pi : PreRefperm.t.
      (okRefperm s t7 pi)
        ->
        (PreRefperm.identity pi s.alloct.M.domain t7.alloct.M.domain)
        ->
        (PreRefperm.idRgn pi s.pool t7.pool)
        ->
        (agree_allfields s t7 pi (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (s.pqueueI)
        ->
        (t7.pqueueI)
end

