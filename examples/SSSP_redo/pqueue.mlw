  val initDistances (l_s: state) (r_s: state) (pi12: PreRefperm.t) (l_d: reference) (l_k: int) (r_d: reference) (r_k: int) : 
    (unit, unit)
    requires { hasDistArrayType l_s l_d }
    requires { (l_d <> null) }
    requires { hasDistArrayType r_s r_d }
    requires { (r_d <> null) }
    requires { okRefperm l_s r_s pi12 }
    requires { ((agree_dSlots l_s r_s pi12 (Rgn.diff (l_d.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_dSlots r_s l_s (pi12.PreRefperm.invert) (Rgn.diff (r_d.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((agree_dLength l_s r_s pi12 (Rgn.diff (l_d.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_dLength
                     r_s
                     l_s
                     (pi12.PreRefperm.invert)
                     (Rgn.diff (r_d.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { ((l_k >= 0) /\ (r_k >= 0)) }
    writes { l_s.dSlots, r_s.dSlots }
    ensures { [@expl:wr {d}`dSlots] (wr_frame_dSlots (old l_s) l_s (l_d.singleton)) }
    
    ensures { [@expl:wr {d}`dSlots] (wr_frame_dSlots (old r_s) r_s (r_d.singleton)) }
    
    ensures { okRefperm l_s r_s pi12 }
    
    ensures { let l_s_alloc14 = old l_s.alloct.M.domain in
              let r_s_alloc14 = old r_s.alloct.M.domain in
              let l_d15 = old (l_d.singleton) in
              let r_d15 = old (r_d.singleton) in
              ((agree_dLength
                  l_s
                  r_s
                  pi12
                  (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_dLength
                    r_s
                    l_s
                    (pi12.PreRefperm.invert)
                    (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_key
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_key
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_length
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_length
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_size
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_size
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_tag
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_tag
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_rep
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_rep
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_child
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_child
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_head
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_head
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_prev
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_prev
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_sibling
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_sibling
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_sntl
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_sntl
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_dSlots
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc14) l_d15) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_dSlots
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff
                          (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc14) r_d15)
                          (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
                /\
                ((agree_slots
                    l_s
                    r_s
                    pi12
                    (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc14) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                   (agree_slots
                      r_s
                      l_s
                      (pi12.PreRefperm.invert)
                      (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc14) (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { ((let len = l_s.dLength[l_d] in
                forall i : int. (0 <= i) -> (i < len) -> ((A.get (l_s.dSlots[l_d]) i) = l_k)) /\
                 (let len = r_s.dLength[r_d] in
                  forall i : int. (0 <= i) -> (i < len) -> ((A.get (r_s.dSlots[r_d]) i) = r_k))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
end

module PQUEUE_REL_biinterface
  use prelude.Prelude
  use State
  use PqueueL
  use PqueueR
  
  predicate coupling0 (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_pq: reference) (r_pq: reference) =
    (okRefperm l_s r_s pi)
      ->
      (hasPqueueType l_s l_pq)
      ->
      (hasPqueueType r_s r_pq)
      ->
      ((l_pq <> null) /\ (r_pq <> null))
      ->
      (PreRefperm.idRef pi l_pq r_pq)
      ->
      (let l_sntl = l_s.sntl[l_pq] in
       let r_sntl = r_s.sntl[r_pq] in
       let l_rep = l_s.rep[l_pq] in
       let r_rep = r_s.rep[r_pq] in
       let l_hd = l_s.head[l_pq] in
       let r_hd = r_s.head[r_pq] in
       let l_sz = l_s.size[l_pq] in
       let r_sz = r_s.size[r_pq] in
       (l_sz = r_sz)
         /\
         ((PreRefperm.idRef pi l_hd r_hd) \/ (l_hd = null) /\ (r_hd = r_sntl))
         /\
         (PreRefperm.idRgn pi (rgnSubK l_rep l_s.alloct Node) (rgnSubK r_rep r_s.alloct Node))
         /\
         (forall l_n : reference, r_n : reference.
            (isAllocated l_s l_n)
              ->
              (hasNodeType l_s l_n)
              ->
              (Rgn.mem l_n l_rep)
              ->
              (isAllocated r_s r_n)
              ->
              (hasNodeType r_s r_n)
              ->
              (Rgn.mem r_n r_rep)
              ->
              (PreRefperm.idRef pi l_n r_n)
              ->
              (let l_k = l_s.key[l_n] in
               let r_k = r_s.key[r_n] in
               let l_t = l_s.tag[l_n] in
               let r_t = r_s.tag[r_n] in
               let l_pre = l_s.prev[l_n] in
               let r_pre = r_s.prev[r_n] in
               let l_sib = l_s.sibling[l_n] in
               let r_sib = r_s.sibling[r_n] in
               let l_chl = l_s.child[l_n] in
               let r_chl = r_s.child[r_n] in
               (l_k = r_k)
                 /\
                 (l_t = r_t)
                 /\
                 (((PreRefperm.idRef pi l_pre r_pre) /\ (l_pre <> null) /\ (r_pre <> r_sntl)) \/ (l_pre = null) /\ (r_pre = r_sntl))
                 /\
                 (((PreRefperm.idRef pi l_sib r_sib) /\ (l_sib <> null) /\ (r_sib <> r_sntl)) \/ (l_sib = null) /\ (r_sib = r_sntl))
                 /\
                 ((PreRefperm.idRef pi l_chl r_chl) /\ (l_chl <> null) /\ (r_chl <> r_sntl))
                 \/
                 (l_chl = null)
                 /\
                 (r_chl = r_sntl))))
  
  val isEmpty (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (r_self: reference) : 
    (bool, bool)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { (true /\ true) }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((agree_size l_s r_s pi (l_self.singleton)) /\ (agree_size r_s l_s (pi.PreRefperm.invert) (r_self.singleton))) }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { (true /\ true) }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
  
  val findMin (l_s: state) (r_s: state) (pi13: PreRefperm.t) (l_self: reference) (r_self: reference) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi13 }
    requires { (true /\ true) }
    requires { PreRefperm.idRef pi13 l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((let sz = l_s.size[l_self] in
                 sz
                 >
                 0) /\ (let sz = r_s.size[r_self] in
                        sz
                        >
                        0)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { okRefperm l_s r_s pi13 }
    
    ensures { (true /\ true) }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi13 l_result r_result
              end }
    
    ensures { match result with
              | (l_result, r_result) -> ((let hd = l_s.head[l_self] in
                                          l_result
                                          =
                                          hd) /\ (let hd = r_s.head[r_self] in
                                                  r_result
                                                  =
                                                  hd))
              end }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields l_s r_s pi13 (Rgn.diff l_s.alloct.M.domain l_s_alloc)) /\
                 (agree_allfields r_s l_s (pi13.PreRefperm.invert) (Rgn.diff r_s.alloct.M.domain r_s_alloc))) }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  
  val insert (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (l_k: int) (l_t: int) (r_self: reference) (r_k: int) (r_t: int) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { (true /\ true) }
    requires { (l_t = r_t) }
    requires { (l_k = r_k) }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.slots,
      l_s.dSlots,
      l_s.sntl,
      l_s.sibling,
      l_s.prev,
      l_s.head,
      l_s.child,
      l_s.rep,
      l_s.tag,
      l_s.size,
      l_s.length,
      l_s.key,
      l_s.dLength,
      l_s.alloct,
      r_s.slots,
      r_s.dSlots,
      r_s.sntl,
      r_s.sibling,
      r_s.prev,
      r_s.head,
      r_s.child,
      r_s.rep,
      r_s.tag,
      r_s.size,
      r_s.length,
      r_s.key,
      r_s.dLength,
      r_s.alloct }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`sntl] (wr_frame_sntl (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`sntl] (wr_frame_sntl (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { (true /\ true) }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let rep14 = l_s.rep[l_self] in
                    forall n : reference.
                      (isAllocated l_s n)
                        ->
                        (hasNodeType l_s n)
                        ->
                        (Rgn.mem n rep14)
                        ->
                        (n <> l_result)
                        ->
                        (let ot = old (l_s.tag[n]) in
                         let ok = old (l_s.key[n]) in
                         ((l_s.tag[n]) = ot) /\ ((l_s.key[n]) = ok))) /\
                     (let rep15 = r_s.rep[r_self] in
                      forall n : reference.
                        (isAllocated r_s n)
                          ->
                          (hasNodeType r_s n)
                          ->
                          (Rgn.mem n rep15)
                          ->
                          (n <> r_result)
                          ->
                          (let ot = old (r_s.tag[n]) in
                           let ok = old (r_s.key[n]) in
                           ((r_s.tag[n]) = ot) /\ ((r_s.key[n]) = ok))))
              end }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi l_result r_result
              end }
    
    ensures { match result with
              | (l_result, r_result) -> (((l_s.tag[l_result]) = l_t) /\ ((r_s.tag[r_result]) = r_t))
              end }
    
    ensures { match result with
              | (l_result, r_result) -> (((l_s.key[l_result]) = l_k) /\ ((r_s.key[r_result]) = r_k))
              end }
    
    ensures { ((let osz = old (l_s.size[l_self]) in
                (l_s.size[l_self])
                =
                osz
                +
                1) /\
                 (let osz = old (r_s.size[r_self]) in
                  (r_s.size[r_self])
                  =
                  osz
                  +
                  1)) }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let orep = old (l_s.rep[l_self]) in
                    (l_s.rep[l_self])
                    =
                    (Rgn.union orep (l_result.singleton))) /\
                     (let orep = old (r_s.rep[r_self]) in
                      (r_s.rep[r_self])
                      =
                      (Rgn.union orep (r_result.singleton))))
              end }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let rep16 = l_s.rep[l_self] in
                    Rgn.mem l_result rep16) /\ (let rep17 = r_s.rep[r_self] in
                                                Rgn.mem r_result rep17))
              end }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  
  val deleteMin (l_s: state) (r_s: state) (pi18: PreRefperm.t) (l_self: reference) (r_self: reference) : 
    (reference, reference)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi18 }
    requires { (true /\ true) }
    requires { PreRefperm.idRef pi18 l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((not ((l_s.size[l_self]) = 0)) /\ (not ((r_s.size[r_self]) = 0))) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.slots,
      l_s.dSlots,
      l_s.sntl,
      l_s.sibling,
      l_s.prev,
      l_s.head,
      l_s.child,
      l_s.rep,
      l_s.tag,
      l_s.size,
      l_s.length,
      l_s.key,
      l_s.dLength,
      l_s.alloct,
      r_s.slots,
      r_s.dSlots,
      r_s.sntl,
      r_s.sibling,
      r_s.prev,
      r_s.head,
      r_s.child,
      r_s.rep,
      r_s.tag,
      r_s.size,
      r_s.length,
      r_s.key,
      r_s.dLength,
      r_s.alloct }
    ensures { match result with
              | (l_result, _) -> hasNodeType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasNodeType r_s r_result
              end }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`sntl] (wr_frame_sntl (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`sntl] (wr_frame_sntl (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi18 }
    
    ensures { (true /\ true) }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { ((let rep19 = l_s.rep[l_self] in
                forall n : reference.
                  (isAllocated l_s n)
                    ->
                    (hasNodeType l_s n)
                    ->
                    (Rgn.mem n rep19)
                    ->
                    (let otag = old (l_s.tag[n]) in
                     let okey = old (l_s.key[n]) in
                     ((l_s.tag[n]) = otag) /\ ((l_s.key[n]) = okey))) /\
                 (let rep20 = r_s.rep[r_self] in
                  forall n : reference.
                    (isAllocated r_s n)
                      ->
                      (hasNodeType r_s n)
                      ->
                      (Rgn.mem n rep20)
                      ->
                      (let otag = old (r_s.tag[n]) in
                       let okey = old (r_s.key[n]) in
                       ((r_s.tag[n]) = otag) /\ ((r_s.key[n]) = okey)))) }
    
    ensures { ((let orep = old (l_s.rep[l_self]) in
                (l_s.rep[l_self])
                =
                orep) /\
                 (let orep = old (r_s.rep[r_self]) in
                  (r_s.rep[r_self])
                  =
                  orep)) }
    
    ensures { ((let osz = old (l_s.size[l_self]) in
                (l_s.size[l_self])
                =
                osz
                -
                1) /\
                 (let osz = old (r_s.size[r_self]) in
                  (r_s.size[r_self])
                  =
                  osz
                  -
                  1)) }
    
    ensures { match result with
              | (l_result, r_result) -> PreRefperm.idRef pi18 l_result r_result
              end }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  
  val decreaseKey (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (l_handle: reference) (l_k: int) (r_self: reference) (r_handle: reference) (r_k: int) : 
    (unit, unit)
    requires { hasPqueueType l_s l_self }
    requires { (l_self <> null) }
    requires { hasNodeType l_s l_handle }
    requires { (l_handle <> null) }
    requires { hasPqueueType r_s r_self }
    requires { (r_self <> null) }
    requires { hasNodeType r_s r_handle }
    requires { (r_handle <> null) }
    requires { okRefperm l_s r_s pi }
    requires { (true /\ true) }
    requires { (l_k = r_k) }
    requires { PreRefperm.idRef pi l_handle r_handle }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    requires { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    requires { ((let sz = l_s.size[l_self] in
                 sz
                 >
                 0) /\ (let sz = r_s.size[r_self] in
                        sz
                        >
                        0)) }
    requires { ((let key21 = l_s.key[l_handle] in
                 l_k
                 <=
                 key21) /\ (let key22 = r_s.key[r_handle] in
                            r_k
                            <=
                            key22)) }
    requires { ((let rep23 = l_s.rep[l_self] in
                 Rgn.mem l_handle rep23) /\ (let rep24 = r_s.rep[r_self] in
                                             Rgn.mem r_handle rep24)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.slots,
      l_s.dSlots,
      l_s.sntl,
      l_s.sibling,
      l_s.prev,
      l_s.head,
      l_s.child,
      l_s.rep,
      l_s.tag,
      l_s.size,
      l_s.length,
      l_s.key,
      l_s.dLength,
      r_s.slots,
      r_s.dSlots,
      r_s.sntl,
      r_s.sibling,
      r_s.prev,
      r_s.head,
      r_s.child,
      r_s.rep,
      r_s.tag,
      r_s.size,
      r_s.length,
      r_s.key,
      r_s.dLength }
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`sntl] (wr_frame_sntl (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`dSlots] (wr_frame_dSlots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`sntl] (wr_frame_sntl (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`sibling] (wr_frame_sibling (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`prev] (wr_frame_prev (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`child] (wr_frame_child (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`tag] (wr_frame_tag (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`key] (wr_frame_key (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`dLength] (wr_frame_dLength (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { (true /\ true) }
    
    ensures { ((l_s.PqueueL.pqueueI) /\ (r_s.PqueueR.pqueueI)) }
    
    ensures { ((l_s.PqueueL.PQUEUE.pqueuePub) /\ (r_s.PqueueR.PQUEUE.pqueuePub)) }
    
    ensures { (((l_s.key[l_handle]) = l_k) /\ ((r_s.key[r_handle]) = r_k)) }
    
    ensures { ((let bsnap_r14 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r14 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r14 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r14 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
end

