module MAIN
  use prelude.Prelude
  use State
end

module SumAB
  use prelude.Prelude
  use State
  use B
  
  let sum (s : state) (n : int) : int
    requires { n > 0 }
    ensures { result = (B.count s.hmap 0 n) }
    diverges
  = label INIT in
      let result = ref 0 in
      let n = ref n in
      let i = ref 0 in
      let v = ref 0 in
      (result := ([@expl:result := 0] 0));
      (i := ([@expl:i := 0] 0));
      while ((! i) < (div (! n) 2)) do
        invariant { alloc_does_not_shrink (old s) s }
        invariant { (0 <= (! i)) /\ ((! i) <= (div (! n) 2)) }
        invariant { (! result) = (B.count s.hmap 0 (! i)) }
        (v := ([@expl:v := getfnval(i,hmap)] (B.getfnval (! i) s.hmap)));
        (if ((! v) = 1) then (result := ([@expl:result := result + 1] ((! result) + 1)))
         else ());
        (i := ([@expl:i := i + 1] ((! i) + 1)))
      done;
      (i := ([@expl:i := n / 2] (div (! n) 2)));
      while ((! i) < (! n)) do
        invariant { alloc_does_not_shrink (old s) s }
        invariant { ((div (! n) 2) <= (! i)) /\ ((! i) <= (! n)) }
        invariant { (! result) = (B.count s.hmap 0 (div (! n) 2)) + (B.count s.hmap (div (! n) 2) (! i)) }
        (v := ([@expl:v := getfnval(i,hmap)] (B.getfnval (! i) s.hmap)));
        (if ((! v) = 1) then (result := ([@expl:result := result + 1] ((! result) + 1)))
         else ());
        (i := ([@expl:i := i + 1] ((! i) + 1)))
      done;
      (! result)
end

module SumBA
  use prelude.Prelude
  use State
  use B
  
  let sum (s : state) (n : int) : int
    requires { n > 0 }
    ensures { result = (B.count s.hmap 0 n) }
    diverges
  = label INIT in
      let result = ref 0 in
      let n = ref n in
      let i = ref 0 in
      let v = ref 0 in
      (result := ([@expl:result := 0] 0));
      (i := ([@expl:i := n / 2] (div (! n) 2)));
      while ((! i) < (! n)) do
        invariant { alloc_does_not_shrink (old s) s }
        invariant { ((div (! n) 2) <= (! i)) /\ ((! i) <= (! n)) }
        invariant { (! result) = (B.count s.hmap (div (! n) 2) (! i)) }
        (v := ([@expl:v := getfnval(i,hmap)] (B.getfnval (! i) s.hmap)));
        (if ((! v) = 1) then (result := ([@expl:result := result + 1] ((! result) + 1)))
         else ());
        (i := ([@expl:i := i + 1] ((! i) + 1)))
      done;
      (i := ([@expl:i := 0] 0));
      while ((! i) < (div (! n) 2)) do
        invariant { alloc_does_not_shrink (old s) s }
        invariant { (0 <= (! i)) /\ ((! i) <= (div (! n) 2)) }
        invariant { (! result) = (B.count s.hmap 0 (! i)) + (B.count s.hmap (div (! n) 2) (! n)) }
        (v := ([@expl:v := getfnval(i,hmap)] (B.getfnval (! i) s.hmap)));
        (if ((! v) = 1) then (result := ([@expl:result := result + 1] ((! result) + 1)))
         else ());
        (i := ([@expl:i := i + 1] ((! i) + 1)))
      done;
      (! result)
end

module SumCommutes
  use prelude.Prelude
  use State
  use SumAB
  use SumBA
  
  let sum (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_n : int) (r_n : int) : 
    (int, int)
    requires { okRefperm l_s r_s pi }
    requires { forall l_i : int, r_i : int.
                 (((0 <= l_i) /\ (l_i < l_n)) /\ ((0 <= r_i) /\ (r_i < r_n)))
                   ->
                   ((SumAB.B.getfnval l_i l_s.hmap) = (SumBA.B.getfnval r_i r_s.hmap))
    }
    requires { ((l_n > 0) /\ (r_n > 0)) }
    requires { (l_n = r_n) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    diverges
  = label INIT in
      let r_result = ref 0 in
      let l_result = ref 0 in
      let l_n = ref l_n in
      let r_n = ref r_n in
      let l_i = ref 0 in
      let r_i = ref 0 in
      let l_v = ref 0 in
      let r_v = ref 0 in
      (l_result := ([@expl:result := 0] 0));
      (r_result := ([@expl:result := 0] 0));
      (l_i := ([@expl:i := 0] 0));
      (r_i := ([@expl:i := n / 2] (div (! r_n) 2)));
      while ((! l_i) < (div (! l_n) 2))  || ((! r_i) < (! r_n)) do
        invariant { okRefperm l_s r_s pi }
        invariant { (0 <= (! l_i)) /\ ((! l_i) <= (div (! l_n) 2)) }
        invariant { ((div (! r_n) 2) <= (! r_i)) /\ ((! r_i) <= (! r_n)) }
        invariant { (! l_result) = (SumAB.B.count l_s.hmap 0 (! l_i)) }
        invariant { (! r_result) = (SumBA.B.count r_s.hmap (div (! r_n) 2) (! r_i)) }
        invariant {
          [@expl:alignment condition]
          ((((! l_i) < (div (! l_n) 2)) /\ true) \/
             ((((! r_i) < (! r_n)) /\ true) \/
                ((((! l_i) < (div (! l_n) 2)) /\ ((! r_i) < (! r_n))) \/
                   ((not ((! l_i) < (div (! l_n) 2))) /\ (not ((! r_i) < (! r_n))))))) }
        if ([@expl:Left step] (((! l_i) < (div (! l_n) 2))  && true)) then
          ((l_v := ([@expl:v := getfnval(i,hmap)] (SumAB.B.getfnval (! l_i) l_s.hmap)));
           (if ((! l_v) = 1) then (l_result := ([@expl:result := result + 1] ((! l_result) + 1)))
            else ());
           (l_i := ([@expl:i := i + 1] ((! l_i) + 1))))
        else
          (if ([@expl:Right step] (((! r_i) < (! r_n))  && true)) then
             ((r_v := ([@expl:v := getfnval(i,hmap)] (SumBA.B.getfnval (! r_i) r_s.hmap)));
              (if ((! r_v) = 1) then (r_result := ([@expl:result := result + 1] ((! r_result) + 1)))
               else ());
              (r_i := ([@expl:i := i + 1] ((! r_i) + 1))))
           else
             ((l_v := ([@expl:v := getfnval(i,hmap)] (SumAB.B.getfnval (! l_i) l_s.hmap)));
              (r_v := ([@expl:v := getfnval(i,hmap)] (SumBA.B.getfnval (! r_i) r_s.hmap)));
              ([@expl:guard agreement] assert { (((! l_v) = 1) = ((! r_v) = 1)) });
              (if ((! l_v) = 1) then
                 ((l_result := ([@expl:result := result + 1] ((! l_result) + 1)));
                  (r_result := ([@expl:result := result + 1] ((! r_result) + 1))))
               else ());
              (l_i := ([@expl:i := i + 1] ((! l_i) + 1)));
              (r_i := ([@expl:i := i + 1] ((! r_i) + 1)))))
      done;
      (l_i := ([@expl:i := n / 2] (div (! l_n) 2)));
      (r_i := ([@expl:i := 0] 0));
      while ((! l_i) < (! l_n))  || ((! r_i) < (div (! r_n) 2)) do
        invariant { okRefperm l_s r_s pi }
        invariant { ((div (! l_n) 2) <= (! l_i)) /\ ((! l_i) <= (! l_n)) }
        invariant { (0 <= (! r_i)) /\ ((! r_i) <= (div (! r_n) 2)) }
        invariant { (! l_result) = (SumAB.B.count l_s.hmap 0 (div (! l_n) 2)) + (SumAB.B.count l_s.hmap (div (! l_n) 2) (! l_i)) }
        invariant { (! r_result) = (SumBA.B.count r_s.hmap (div (! r_n) 2) (! r_n)) + (SumBA.B.count r_s.hmap 0 (! r_i)) }
        invariant {
          [@expl:alignment condition]
          ((((! l_i) < (! l_n)) /\ true) \/
             ((((! r_i) < (div (! r_n) 2)) /\ true) \/
                ((((! l_i) < (! l_n)) /\ ((! r_i) < (div (! r_n) 2))) \/
                   ((not ((! l_i) < (! l_n))) /\ (not ((! r_i) < (div (! r_n) 2))))))) }
        if ([@expl:Left step] (((! l_i) < (! l_n))  && true)) then
          ((l_v := ([@expl:v := getfnval(i,hmap)] (SumAB.B.getfnval (! l_i) l_s.hmap)));
           (if ((! l_v) = 1) then (l_result := ([@expl:result := result + 1] ((! l_result) + 1)))
            else ());
           (l_i := ([@expl:i := i + 1] ((! l_i) + 1))))
        else
          (if ([@expl:Right step] (((! r_i) < (div (! r_n) 2))  && true)) then
             ((r_v := ([@expl:v := getfnval(i,hmap)] (SumBA.B.getfnval (! r_i) r_s.hmap)));
              (if ((! r_v) = 1) then (r_result := ([@expl:result := result + 1] ((! r_result) + 1)))
               else ());
              (r_i := ([@expl:i := i + 1] ((! r_i) + 1))))
           else
             ((l_v := ([@expl:v := getfnval(i,hmap)] (SumAB.B.getfnval (! l_i) l_s.hmap)));
              (r_v := ([@expl:v := getfnval(i,hmap)] (SumBA.B.getfnval (! r_i) r_s.hmap)));
              ([@expl:guard agreement] assert { (((! l_v) = 1) = ((! r_v) = 1)) });
              (if ((! l_v) = 1) then
                 ((l_result := ([@expl:result := result + 1] ((! l_result) + 1)));
                  (r_result := ([@expl:result := result + 1] ((! r_result) + 1))))
               else ());
              (l_i := ([@expl:i := i + 1] ((! l_i) + 1)));
              (r_i := ([@expl:i := i + 1] ((! r_i) + 1)))))
      done;
      assert { (((! l_result) = (SumAB.B.count l_s.hmap 0 (! l_n))) /\ ((! r_result) = (SumBA.B.count r_s.hmap 0 (! r_n)))) };
      ((! l_result), (! r_result))
end

module SumCommutes_Seq
  use prelude.Prelude
  use State
  use SumAB
  use SumBA
  
  let sum (l_s : state) (r_s : state) (pi1 : PreRefperm.t) (l_n : int) (r_n : int) : 
    (int, int)
    requires { okRefperm l_s r_s pi1 }
    requires { forall l_i : int, r_i : int.
                 (((0 <= l_i) /\ (l_i < l_n)) /\ ((0 <= r_i) /\ (r_i < r_n)))
                   ->
                   ((SumAB.B.getfnval l_i l_s.hmap) = (SumBA.B.getfnval r_i r_s.hmap))
    }
    requires { ((l_n > 0) /\ (r_n > 0)) }
    requires { (l_n = r_n) }
    ensures { okRefperm l_s r_s pi1 }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    diverges
  = label INIT in
      let r_result = ref 0 in
      let l_result = ref 0 in
      let l_n = ref l_n in
      let r_n = ref r_n in
      let l_i = ref 0 in
      let r_i = ref 0 in
      let l_v = ref 0 in
      let r_v = ref 0 in
      (l_result := ([@expl:result := 0] 0));
      (r_result := ([@expl:result := 0] 0));
      (l_i := ([@expl:i := 0] 0));
      while ((! l_i) < (div (! l_n) 2)) do
        invariant { alloc_does_not_shrink (old l_s) l_s }
        invariant { (0 <= (! l_i)) /\ ((! l_i) <= (div (! l_n) 2)) }
        invariant { (! l_result) = (SumAB.B.count l_s.hmap 0 (! l_i)) }
        (l_v := ([@expl:v := getfnval(i,hmap)] (SumAB.B.getfnval (! l_i) l_s.hmap)));
        (if ((! l_v) = 1) then (l_result := ([@expl:result := result + 1] ((! l_result) + 1)))
         else ());
        (l_i := ([@expl:i := i + 1] ((! l_i) + 1)))
      done;
      (l_i := ([@expl:i := n / 2] (div (! l_n) 2)));
      while ((! l_i) < (! l_n)) do
        invariant { alloc_does_not_shrink (old l_s) l_s }
        invariant { ((div (! l_n) 2) <= (! l_i)) /\ ((! l_i) <= (! l_n)) }
        invariant { (! l_result) = (SumAB.B.count l_s.hmap 0 (div (! l_n) 2)) + (SumAB.B.count l_s.hmap (div (! l_n) 2) (! l_i)) }
        (l_v := ([@expl:v := getfnval(i,hmap)] (SumAB.B.getfnval (! l_i) l_s.hmap)));
        (if ((! l_v) = 1) then (l_result := ([@expl:result := result + 1] ((! l_result) + 1)))
         else ());
        (l_i := ([@expl:i := i + 1] ((! l_i) + 1)))
      done;
      (r_i := ([@expl:i := n / 2] (div (! r_n) 2)));
      while ((! r_i) < (! r_n)) do
        invariant { okRefperm l_s r_s pi1 }
        invariant { ((div (! r_n) 2) <= (! r_i)) /\ ((! r_i) <= (! r_n)) }
        invariant { (! r_result) = (SumBA.B.count r_s.hmap (div (! r_n) 2) (! r_i)) }
        invariant { (! l_result) = (SumAB.B.count l_s.hmap 0 (div (! l_n) 2)) + (SumAB.B.count l_s.hmap (div (! l_n) 2) (! l_i)) }
        (r_v := ([@expl:v := getfnval(i,hmap)] (SumBA.B.getfnval (! r_i) r_s.hmap)));
        (if ((! r_v) = 1) then (r_result := ([@expl:result := result + 1] ((! r_result) + 1)))
         else ());
        (r_i := ([@expl:i := i + 1] ((! r_i) + 1)))
      done;
      (r_i := ([@expl:i := 0] 0));
      while ((! r_i) < (div (! r_n) 2)) do
        invariant { okRefperm l_s r_s pi1 }
        invariant { (! l_result) = (SumAB.B.count l_s.hmap 0 (div (! l_n) 2)) + (SumAB.B.count l_s.hmap (div (! l_n) 2) (! l_i)) }
        invariant { (0 <= (! r_i)) /\ ((! r_i) <= (div (! r_n) 2)) }
        invariant { (! r_result) = (SumBA.B.count r_s.hmap (div (! r_n) 2) (! r_n)) + (SumBA.B.count r_s.hmap 0 (! r_i)) }
        (r_v := ([@expl:v := getfnval(i,hmap)] (SumBA.B.getfnval (! r_i) r_s.hmap)));
        (if ((! r_v) = 1) then (r_result := ([@expl:result := result + 1] ((! r_result) + 1)))
         else ());
        (r_i := ([@expl:i := i + 1] ((! r_i) + 1)))
      done;
      assert { (((! l_result) = (SumAB.B.count l_s.hmap 0 (! l_n))) /\ ((! r_result) = (SumBA.B.count r_s.hmap 0 (! r_n)))) };
      ((! l_result), (! r_result))
end

module SumCommutes_Seq_biinterface
  use prelude.Prelude
  use State
  use SumAB
  use SumBA
  
  val sum (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_n: int) (r_n: int) : 
    (int, int)
    requires { okRefperm l_s r_s pi }
    requires { forall l_i : int, r_i : int.
                 (((0 <= l_i) /\ (l_i < l_n)) /\ ((0 <= r_i) /\ (r_i < r_n)))
                   ->
                   ((SumAB.B.getfnval l_i l_s.hmap) = (SumBA.B.getfnval r_i r_s.hmap))
    }
    requires { ((l_n > 0) /\ (r_n > 0)) }
    requires { (l_n = r_n) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
end

