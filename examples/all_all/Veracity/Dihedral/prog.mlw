module State
  use prelude.Prelude
  use prelude.PreRefperm
  use dihedral_theory.Dihedral_Theory
  
  type reftype = 
      | IntArray
  
  type state = private {
              mutable ghost alloct : M.t reftype;
              mutable length : M.t int;
              mutable slots : M.t (A.array int);
              mutable s2 : bool;
              mutable s1 : bool;
              mutable r2 : int;
              mutable r1 : int;
              mutable n : int;
              mutable a : reference
              }
    invariant { not (M.mem null alloct) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = IntArray) ->
              (((M.mem p length) /\ (M.mem p slots)) /\ (((length[p]) >= 0) /\ ((length[p]) = ((slots[p]).A.length)))))) }
    invariant { not (M.mem null length) }
    invariant { not (M.mem null slots) }
    by
      { alloct = (().M.create) ;
        length = (().M.create) ;
        slots = (().M.create) ;
        s2 = (any bool) ;
        s1 = (any bool) ;
        r2 = (any int) ;
        r1 = (any int) ;
        n = (any int) ;
        a = (any reference) }
  
  predicate isAllocated (s: state) (p: reference) = M.mem p s.alloct
  
  predicate isValidRgn (s: state) (r: rgn) = forall q : reference. ((Rgn.mem q r) -> ((q = null) \/ (M.mem q s.alloct)))
  
  predicate typeofRgn (s: state) (r: rgn) (types: L.list reftype) =
    forall p : reference. ((Rgn.mem p r) -> ((p = null) \/ ((M.mem p s.alloct) /\ (L.mem (s.alloct[p]) types))))
  
  predicate hasIntArrayType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = IntArray)))
  
  predicate okRefperm (sl: state) (sr: state) (pi: PreRefperm.t) =
    ((forall p : reference. ((M.mem p pi.lor) -> (M.mem p sl.alloct))) /\
       ((forall q : reference. ((M.mem q pi.rol) -> (M.mem q sr.alloct))) /\
          (forall p : reference, q : reference. ((M.mem p pi.lor) -> (((pi.lor[p]) = q) -> ((sl.alloct[p]) = (sr.alloct[q])))))))
  
  val mk_IntArray (s: state) : reference
    writes { s.alloct, s.length, s.slots }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result IntArray (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasIntArrayType s result }
    
    ensures { (s.length = (M.add result 0 (old s.length))) }
    
    ensures { (s.slots = (M.add result (A.make 0 0) (old s.slots))) }
  
  val set_s2 (s: state) (v: bool) : unit
    writes { s.s2 }
    ensures { (s.s2 = v) }
  
  val set_s1 (s: state) (v: bool) : unit
    writes { s.s1 }
    ensures { (s.s1 = v) }
  
  val set_r2 (s: state) (v: int) : unit
    writes { s.r2 }
    ensures { (s.r2 = v) }
  
  val set_r1 (s: state) (v: int) : unit
    writes { s.r1 }
    ensures { (s.r1 = v) }
  
  val set_n (s: state) (v: int) : unit
    writes { s.n }
    ensures { (s.n = v) }
  
  val set_a (s: state) (v: reference) : unit
    requires { hasIntArrayType s v }
    writes { s.a }
    ensures { (s.a = v) }
  
  val set_length (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasIntArrayType s o }
    writes { s.length }
    ensures { (s.length = (M.add o v (old s.length))) }
  
  val set_slots (s: state) (o: reference) (v: A.array int) : unit
    requires { (o <> null) }
    requires { hasIntArrayType s o }
    writes { s.slots }
    ensures { (s.slots = (M.add o v (old s.slots))) }
  
  function img_slots : state -> (rgn -> rgn)
  
  axiom img_slots_ax: forall s : state, r : rgn. ((img_slots s r) = emptyRgn)
  
  function img_length : state -> (rgn -> rgn)
  
  axiom img_length_ax: forall s : state, r : rgn. ((img_length s r) = emptyRgn)
  
  predicate alloc_does_not_shrink (pre: state) (post: state) =
    forall p : reference. ((M.mem p pre.alloct) -> ((M.mem p post.alloct) /\ ((pre.alloct[p]) = (post.alloct[p]))))
  
  predicate wr_frame_length (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = IntArray) -> ((not (Rgn.mem p r)) -> ((pre.length[p]) = (post.length[p])))))
  
  predicate wr_frame_slots (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = IntArray) -> ((not (Rgn.mem p r)) -> ((pre.slots[p]) = (post.slots[p])))))
  
  predicate agree_slots (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasIntArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.slots[o]) = (sr.slots[pi.lor[o]])))))))))
  
  predicate agree_length (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasIntArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.length[o]) = (sr.length[pi.lor[o]])))))))))
  
  predicate agree_allfields (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) = (agree_length sl sr pi w) /\ (agree_slots sl sr pi w)
end

module DIHEDRAL
  use prelude.Prelude
  use State
  use export dihedral_theory.Dihedral_Theory
  
  val main (s: state) : unit
    requires { [@expl:globals type invariant] (hasIntArrayType s s.a) }
    requires { (s.a <> null) /\ ((s.length[s.a]) = s.n) }
    requires { s.n > 1 }
    requires { (0 <= s.r1) /\ (s.r1 < s.n) }
    requires { (0 <= s.r2) /\ (s.r2 < s.n) }
    requires { forall i : int. ((0 <= i) /\ (i < s.n)) -> ((A.get (s.slots[s.a]) i) = i) }
    requires { forall i : int. ((0 <= i) /\ (i < s.n)) -> (let v = A.get (s.slots[s.a]) i in
                                                           (0 <= v) /\ (v < s.n)) }
    requires { ((s.s1 = false) /\ (s.s2 = false))
                 \/
                 ((s.s1 = true) /\ (s.s2 = false) /\ (s.r2 = 0) \/ ((mod s.n 2) = 0) /\ (s.r2 = (div s.n 2)))
                 \/
                 ((s.s1 = false) /\ (s.s2 = true) /\ (s.r1 = 0) \/ ((mod s.n 2) = 0) /\ (s.r1 = (div s.n 2)))
                 \/
                 (s.s1 = true)
                 /\
                 (s.s2 = true)
                 /\
                 (s.r1 = s.r2)
    }
    writes { s.slots }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {a}`slots] (wr_frame_slots (old s) s (s.a.singleton)) }
    
    ensures { forall i : int. ((0 <= i) /\ (i < s.n)) -> (let v = A.get (s.slots[s.a]) i in
                                                          (0 <= v) /\ (v < s.n)) }
end

module M0
  use prelude.Prelude
  use State
  use DIHEDRAL
  
  val main (s: state) : unit
    requires { [@expl:globals type invariant] (hasIntArrayType s s.a) }
    requires { (s.a <> null) /\ ((s.length[s.a]) = s.n) }
    requires { s.n > 1 }
    requires { (0 <= s.r1) /\ (s.r1 < s.n) }
    requires { (0 <= s.r2) /\ (s.r2 < s.n) }
    requires { forall i : int. ((0 <= i) /\ (i < s.n)) -> ((A.get (s.slots[s.a]) i) = i) }
    requires { forall i : int. ((0 <= i) /\ (i < s.n)) -> (let v = A.get (s.slots[s.a]) i in
                                                           (0 <= v) /\ (v < s.n)) }
    requires { ((s.s1 = false) /\ (s.s2 = false))
                 \/
                 ((s.s1 = true) /\ (s.s2 = false) /\ (s.r2 = 0) \/ ((mod s.n 2) = 0) /\ (s.r2 = (div s.n 2)))
                 \/
                 ((s.s1 = false) /\ (s.s2 = true) /\ (s.r1 = 0) \/ ((mod s.n 2) = 0) /\ (s.r1 = (div s.n 2)))
