module State
  use prelude.Prelude
  use prelude.PreRefperm
  use stack_theory.Stack_theory
  
  type reftype = 
      | Cell
      | CellArray
      | Node
      | Stack
  
  type state = private {
              mutable ghost alloct : M.t reftype;
              mutable head : M.t reference;
              mutable ghost rep : M.t rgn;
              mutable size : M.t int;
              mutable ghost contents : M.t intList;
              mutable top : M.t int;
              mutable arr : M.t reference;
              mutable car : M.t reference;
              mutable cdr : M.t reference;
              mutable slots : M.t (A.array reference);
              mutable length : M.t int;
              mutable cell_value : M.t int;
              mutable ghost cell_rep : M.t rgn;
              mutable maxSize : int;
              mutable ghost pool : rgn
              }
    invariant { not (M.mem null alloct) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = Cell) ->
              (((M.mem p cell_value) /\ (M.mem p cell_rep)) /\
                 (forall q : reference. ((Rgn.mem q (cell_rep[p])) -> ((q = null) \/ (M.mem q alloct))))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = CellArray) ->
              (((M.mem p slots) /\ (M.mem p length)) /\
                 (((length[p]) >= 0)
                    /\
                    ((length[p]) = ((slots[p]).A.length))
                    /\
                    (let arr1 = slots[p] in
                     forall i : int.
                       ((0 <= i) ->
                          ((i < (arr1.A.length)) ->
                             (let v = A.get arr1 i in
                              ((v = null) \/ ((M.mem v alloct) /\ ((alloct[v]) = Cell))))))))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = Node) ->
              (((M.mem p car) /\ (M.mem p cdr)) /\
                 ((((car[p]) = null) \/ ((M.mem (car[p]) alloct) /\ ((alloct[car[p]]) = Cell)))
                    /\
                    (((cdr[p]) = null) \/ ((M.mem (cdr[p]) alloct) /\ ((alloct[cdr[p]]) = Node))))))) }
    invariant {
      forall p : reference.
        ((M.mem p alloct) ->
           (((alloct[p]) = Stack) ->
              (((M.mem p head) /\ (M.mem p rep) /\ (M.mem p size) /\ (M.mem p contents) /\ (M.mem p top) /\ (M.mem p arr)) /\
                 ((((head[p]) = null) \/ ((M.mem (head[p]) alloct) /\ ((alloct[head[p]]) = Node)))
                    /\
                    (((arr[p]) = null) \/ ((M.mem (arr[p]) alloct) /\ ((alloct[arr[p]]) = CellArray)))
                    /\
                    (forall q : reference. ((Rgn.mem q (rep[p])) -> ((q = null) \/ (M.mem q alloct)))))))) }
    invariant { forall q : reference. ((Rgn.mem q pool) -> ((q = null) \/ (M.mem q alloct))) }
    invariant { not (M.mem null head) }
    invariant { not (M.mem null rep) }
    invariant { not (M.mem null size) }
    invariant { not (M.mem null contents) }
    invariant { not (M.mem null top) }
    invariant { not (M.mem null arr) }
    invariant { not (M.mem null car) }
    invariant { not (M.mem null cdr) }
    invariant { not (M.mem null slots) }
    invariant { not (M.mem null length) }
    invariant { not (M.mem null cell_value) }
    invariant { not (M.mem null cell_rep) }
    by
      { alloct = (().M.create) ;
        head = (().M.create) ;
        rep = (().M.create) ;
        size = (().M.create) ;
        contents = (().M.create) ;
        top = (().M.create) ;
        arr = (().M.create) ;
        car = (().M.create) ;
        cdr = (().M.create) ;
        slots = (().M.create) ;
        length = (().M.create) ;
        cell_value = (().M.create) ;
        cell_rep = (().M.create) ;
        maxSize = (any int) ;
        pool = emptyRgn }
  
  predicate isAllocated (s: state) (p: reference) = M.mem p s.alloct
  
  predicate isValidRgn (s: state) (r: rgn) = forall q : reference. ((Rgn.mem q r) -> ((q = null) \/ (M.mem q s.alloct)))
  
  predicate typeofRgn (s: state) (r: rgn) (types: L.list reftype) =
    forall p : reference. ((Rgn.mem p r) -> ((p = null) \/ ((M.mem p s.alloct) /\ (L.mem (s.alloct[p]) types))))
  
  predicate hasCellType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Cell)))
  
  predicate hasCellArrayType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = CellArray)))
  
  predicate hasNodeType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Node)))
  
  predicate hasStackType (s: state) (p: reference) = ((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Stack)))
  
  predicate okRefperm (sl: state) (sr: state) (pi: PreRefperm.t) =
    ((forall p : reference. ((M.mem p pi.lor) -> (M.mem p sl.alloct))) /\
       ((forall q : reference. ((M.mem q pi.rol) -> (M.mem q sr.alloct))) /\
          (forall p : reference, q : reference. ((M.mem p pi.lor) -> (((pi.lor[p]) = q) -> ((sl.alloct[p]) = (sr.alloct[q])))))))
  
  val mk_Cell (s: state) : reference
    writes { s.alloct, s.cell_value, s.cell_rep }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result Cell (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasCellType s result }
    
    ensures { (s.cell_value = (M.add result 0 (old s.cell_value))) }
    
    ensures { (s.cell_rep = (M.add result emptyRgn (old s.cell_rep))) }
  
  val mk_CellArray (s: state) : reference
    writes { s.alloct, s.slots, s.length }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result CellArray (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasCellArrayType s result }
    
    ensures { (s.slots = (M.add result (A.make 0 null) (old s.slots))) }
    
    ensures { (s.length = (M.add result 0 (old s.length))) }
  
  val mk_Node (s: state) : reference
    writes { s.alloct, s.car, s.cdr }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result Node (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasNodeType s result }
    
    ensures { (s.car = (M.add result null (old s.car))) }
    
    ensures { (s.cdr = (M.add result null (old s.cdr))) }
  
  val mk_Stack (s: state) : reference
    writes { s.alloct, s.head, s.rep, s.size, s.contents, s.top, s.arr }
    ensures { not (M.mem result (old s.alloct)) }
    
    ensures { (s.alloct = (M.add result Stack (old s.alloct))) }
    
    ensures { forall p : reference. ((M.mem p (old s.alloct)) -> ((M.mem p s.alloct) /\ (((old s.alloct)[p]) = (s.alloct[p])))) }
    
    ensures { (result <> null) }
    
    ensures { hasStackType s result }
    
    ensures { (s.head = (M.add result null (old s.head))) }
    
    ensures { (s.rep = (M.add result emptyRgn (old s.rep))) }
    
    ensures { (s.size = (M.add result 0 (old s.size))) }
    
    ensures { (s.contents = (M.add result nil (old s.contents))) }
    
    ensures { (s.top = (M.add result 0 (old s.top))) }
    
    ensures { (s.arr = (M.add result null (old s.arr))) }
  
  val set_maxSize (s: state) (v: int) : unit
    writes { s.maxSize }
    ensures { (s.maxSize = v) }
  
  val set_pool (s: state) (ghost v: rgn) : unit
    requires { isValidRgn s v }
    writes { s.pool }
    ensures { (s.pool = v) }
  
  val set_head (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasStackType s o }
    requires { hasNodeType s v }
    writes { s.head }
    ensures { (s.head = (M.add o v (old s.head))) }
  
  val set_rep (s: state) (o: reference) (ghost v: rgn) : unit
    requires { (o <> null) }
    requires { hasStackType s o }
    requires { isValidRgn s v }
    writes { s.rep }
    ensures { (s.rep = (M.add o v (old s.rep))) }
  
  val set_size (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasStackType s o }
    writes { s.size }
    ensures { (s.size = (M.add o v (old s.size))) }
  
  val set_contents (s: state) (o: reference) (ghost v: intList) : unit
    requires { (o <> null) }
    requires { hasStackType s o }
    writes { s.contents }
    ensures { (s.contents = (M.add o v (old s.contents))) }
  
  val set_top (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasStackType s o }
    writes { s.top }
    ensures { (s.top = (M.add o v (old s.top))) }
  
  val set_arr (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasStackType s o }
    requires { hasCellArrayType s v }
    writes { s.arr }
    ensures { (s.arr = (M.add o v (old s.arr))) }
  
  val set_car (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    requires { hasCellType s v }
    writes { s.car }
    ensures { (s.car = (M.add o v (old s.car))) }
  
  val set_cdr (s: state) (o: reference) (v: reference) : unit
    requires { (o <> null) }
    requires { hasNodeType s o }
    requires { hasNodeType s v }
    writes { s.cdr }
    ensures { (s.cdr = (M.add o v (old s.cdr))) }
  
  val set_slots (s: state) (o: reference) (v: A.array reference) : unit
    requires { (o <> null) }
    requires { hasCellArrayType s o }
    writes { s.slots }
    ensures { (s.slots = (M.add o v (old s.slots))) }
  
  val set_length (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasCellArrayType s o }
    writes { s.length }
    ensures { (s.length = (M.add o v (old s.length))) }
  
  val set_cell_value (s: state) (o: reference) (v: int) : unit
    requires { (o <> null) }
    requires { hasCellType s o }
    writes { s.cell_value }
    ensures { (s.cell_value = (M.add o v (old s.cell_value))) }
  
  val set_cell_rep (s: state) (o: reference) (ghost v: rgn) : unit
    requires { (o <> null) }
    requires { hasCellType s o }
    requires { isValidRgn s v }
    writes { s.cell_rep }
    ensures { (s.cell_rep = (M.add o v (old s.cell_rep))) }
  
  function img_top : state -> (rgn -> rgn)
  
  axiom img_top_ax: forall s : state, r : rgn. ((img_top s r) = emptyRgn)
  
  function img_slots : state -> (rgn -> rgn)
  
  axiom img_slots_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_slots s r)) <->
         (((p = null) \/ ((M.mem p s.alloct) /\ ((s.alloct[p]) = Cell))) /\
            (exists arr2 : reference.
               ((M.mem arr2 s.alloct) /\
                  (((s.alloct[arr2]) = CellArray) /\
                     ((Rgn.mem arr2 r) /\
                        (exists i : int. ((0 <= i) /\ ((i < ((s.slots[arr2]).A.length)) /\ ((A.get (s.slots[arr2]) i) = p))))))))))
  
  function img_size : state -> (rgn -> rgn)
  
  axiom img_size_ax: forall s : state, r : rgn. ((img_size s r) = emptyRgn)
  
  function img_rep : state -> (rgn -> rgn)
  
  axiom img_rep_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_rep s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Stack) /\ ((Rgn.mem q r) /\ (Rgn.mem p (s.rep[q])))))))
  
  function img_length : state -> (rgn -> rgn)
  
  axiom img_length_ax: forall s : state, r : rgn. ((img_length s r) = emptyRgn)
  
  function img_head : state -> (rgn -> rgn)
  
  axiom img_head_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_head s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Stack) /\ ((Rgn.mem q r) /\ (p = (s.head[q])))))))
  
  function img_contents : state -> (rgn -> rgn)
  
  axiom img_contents_ax: forall s : state, r : rgn. ((img_contents s r) = emptyRgn)
  
  function img_cell_value : state -> (rgn -> rgn)
  
  axiom img_cell_value_ax: forall s : state, r : rgn. ((img_cell_value s r) = emptyRgn)
  
  function img_cell_rep : state -> (rgn -> rgn)
  
  axiom img_cell_rep_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_cell_rep s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Cell) /\ ((Rgn.mem q r) /\ (Rgn.mem p (s.cell_rep[q])))))))
  
  function img_cdr : state -> (rgn -> rgn)
  
  axiom img_cdr_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_cdr s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Node) /\ ((Rgn.mem q r) /\ (p = (s.cdr[q])))))))
  
  function img_car : state -> (rgn -> rgn)
  
  axiom img_car_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_car s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Node) /\ ((Rgn.mem q r) /\ (p = (s.car[q])))))))
  
  function img_arr : state -> (rgn -> rgn)
  
  axiom img_arr_ax:
    forall s : state, r : rgn, p : reference.
      ((Rgn.mem p (img_arr s r)) <->
         (exists q : reference. ((M.mem q s.alloct) /\ (((s.alloct[q]) = Stack) /\ ((Rgn.mem q r) /\ (p = (s.arr[q])))))))
  
  predicate alloc_does_not_shrink (pre: state) (post: state) =
    forall p : reference. ((M.mem p pre.alloct) -> ((M.mem p post.alloct) /\ ((pre.alloct[p]) = (post.alloct[p]))))
  
  predicate wr_frame_cell_value (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Cell) -> ((not (Rgn.mem p r)) -> ((pre.cell_value[p]) = (post.cell_value[p])))))
  
  predicate wr_frame_cell_rep (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Cell) -> ((not (Rgn.mem p r)) -> ((pre.cell_rep[p]) = (post.cell_rep[p])))))
  
  predicate wr_frame_slots (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = CellArray) -> ((not (Rgn.mem p r)) -> ((pre.slots[p]) = (post.slots[p])))))
  
  predicate wr_frame_length (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = CellArray) -> ((not (Rgn.mem p r)) -> ((pre.length[p]) = (post.length[p])))))
  
  predicate wr_frame_car (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.car[p]) = (post.car[p])))))
  
  predicate wr_frame_cdr (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Node) -> ((not (Rgn.mem p r)) -> ((pre.cdr[p]) = (post.cdr[p])))))
  
  predicate wr_frame_head (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Stack) -> ((not (Rgn.mem p r)) -> ((pre.head[p]) = (post.head[p])))))
  
  predicate wr_frame_rep (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Stack) -> ((not (Rgn.mem p r)) -> ((pre.rep[p]) = (post.rep[p])))))
  
  predicate wr_frame_size (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Stack) -> ((not (Rgn.mem p r)) -> ((pre.size[p]) = (post.size[p])))))
  
  predicate wr_frame_contents (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Stack) -> ((not (Rgn.mem p r)) -> ((pre.contents[p]) = (post.contents[p])))))
  
  predicate wr_frame_top (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Stack) -> ((not (Rgn.mem p r)) -> ((pre.top[p]) = (post.top[p])))))
  
  predicate wr_frame_arr (pre: state) (post: state) (r: rgn) =
    forall p : reference.
      ((M.mem p pre.alloct) -> (((post.alloct[p]) = Stack) -> ((not (Rgn.mem p r)) -> ((pre.arr[p]) = (post.arr[p])))))
  
  predicate agree_top (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasStackType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.top[o]) = (sr.top[pi.lor[o]])))))))))
  
  predicate agree_slots (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasCellArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.slots[o]) = (sr.slots[pi.lor[o]])))))))))
  
  predicate agree_size (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasStackType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.size[o]) = (sr.size[pi.lor[o]])))))))))
  
  predicate agree_rep (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasStackType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRgn pi (sl.rep[o]) (sr.rep[pi.lor[o]])))))))))
  
  predicate agree_length (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasCellArrayType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.length[o]) = (sr.length[pi.lor[o]])))))))))
  
  predicate agree_head (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasStackType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.head[o]) (sr.head[pi.lor[o]])))))))))
  
  predicate agree_contents (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasStackType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.contents[o]) = (sr.contents[pi.lor[o]])))))))))
  
  predicate agree_cell_value (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasCellType sl o) ->
                ((Rgn.mem o w) -> ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] ((sl.cell_value[o]) = (sr.cell_value[pi.lor[o]])))))))))
  
  predicate agree_cell_rep (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasCellType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRgn pi (sl.cell_rep[o]) (sr.cell_rep[pi.lor[o]])))))))))
  
  predicate agree_cdr (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.cdr[o]) (sr.cdr[pi.lor[o]])))))))))
  
  predicate agree_car (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasNodeType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.car[o]) (sr.car[pi.lor[o]])))))))))
  
  predicate agree_arr (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    ((okRefperm sl sr pi) /\
       (forall o : reference.
          ((isAllocated sl o) ->
             ((hasStackType sl o) ->
                ((Rgn.mem o w) ->
                   ((M.mem o pi.lor) /\ ([@expl:sl(o) ~ sr(pi(o))] (PreRefperm.idRef pi (sl.arr[o]) (sr.arr[pi.lor[o]])))))))))
  
  predicate agree_allfields (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn) =
    (agree_cell_value sl sr pi w)
      /\
      (agree_cell_rep sl sr pi w)
      /\
      (agree_slots sl sr pi w)
      /\
      (agree_length sl sr pi w)
      /\
      (agree_car sl sr pi w)
      /\
      (agree_cdr sl sr pi w)
      /\
      (agree_head sl sr pi w)
      /\
      (agree_rep sl sr pi w)
      /\
      (agree_size sl sr pi w)
      /\
      (agree_contents sl sr pi w)
      /\
      (agree_top sl sr pi w)
      /\
      (agree_arr sl sr pi w)
end

module CELL
  use prelude.Prelude
  use State
  
  val init_Cell (s: state) (self: reference) (k: int) : unit
    requires { hasCellType s self }
    requires { (self <> null) }
    writes { s.cell_value, s.cell_rep }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`cell_value] (wr_frame_cell_value (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`cell_rep] (wr_frame_cell_rep (old s) s (self.singleton)) }
    
    ensures { (s.cell_value[self]) = k }
    
    ensures { (s.cell_rep[self]) = (self.singleton) }
end

module STACK
  use prelude.Prelude
  use State
  use CELL
  use export stack_theory.Stack_theory
  
  predicate stackPub (s: state) =
    (s.maxSize > 0)
      /\
      (typeofRgn s s.pool (L.Cons Stack (L.Cons Cell L.Nil)))
      /\
      (forall s1 : reference.
         (isAllocated s s1)
           ->
           (hasStackType s s1)
           ->
           (Rgn.mem s1 s.pool)
           ->
           (let sz = s.size[s1] in
            let xs = s.contents[s1] in
            (sz = (xs.listLength)) /\ (0 <= sz) /\ (sz <= s.maxSize)))
      /\
      (forall s2 : reference, t : reference.
         (isAllocated s s2)
           ->
           (hasStackType s s2)
           ->
           (Rgn.mem s2 s.pool)
           ->
           (isAllocated s t)
           ->
           (hasStackType s t)
           ->
           (Rgn.mem t s.pool)
           ->
           (let srep = s.rep[s2] in
            let trep = s.rep[t] in
            (s2 <> t) -> (srep \# trep)))
  
  val init_Stack (s: state) (self: reference) : unit
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { not (Rgn.mem self s.pool) }
    requires { s.stackPub }
    writes { s.head, s.rep, s.size, s.contents, s.top, s.arr, s.alloct, s.pool }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {self}`head] (wr_frame_head (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`size] (wr_frame_size (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`contents] (wr_frame_contents (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`top] (wr_frame_top (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`arr] (wr_frame_arr (old s) s (self.singleton)) }
    
    ensures { let bsnap_r37 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r37 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.size[self]) = 0 }
    
    ensures { (s.contents[self]) = nil }
    
    ensures { let opool = old s.pool in
              s.pool
              =
              (Rgn.union opool (self.singleton)) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff (s.rep[self]) (null.singleton)) (Rgn.diff s.alloct.M.domain oa) }
    
    ensures { s.stackPub }
  
  val isEmpty (s: state) (self: reference) : bool
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.stackPub }
    ensures { let bsnap_r37 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r37 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { result <-> ((s.size[self]) = 0) }
    
    ensures { s.stackPub }
  
  val push (s: state) (self: reference) (k: int) : unit
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               <
               s.maxSize }
    requires { s.stackPub }
    writes { s.contents, s.slots, s.head, s.cdr, s.arr, s.car, s.rep, s.cell_rep, s.top, s.size, s.length, s.cell_value, s.alloct }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cdr] (wr_frame_cdr (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`arr] (wr_frame_arr (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`car] (wr_frame_car (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_rep] (wr_frame_cell_rep (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`cell_value] (wr_frame_cell_value (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r37 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r37 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              +
              1 }
    
    ensures { let xs = old (s.contents[self]) in
              (s.contents[self])
              =
              (cons k xs) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff s.alloct.M.domain oa) (s.rep[self]) }
    
    ensures { let oa = old s.alloct.M.domain in
              let orep = old (s.rep[self]) in
              Rgn.subset (s.rep[self]) (Rgn.union orep (Rgn.diff s.alloct.M.domain oa)) }
    
    ensures { s.stackPub }
  
  val pop (s: state) (self: reference) : reference
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.stackPub }
    writes { s.contents, s.slots, s.head, s.cdr, s.arr, s.car, s.rep, s.cell_rep, s.top, s.size, s.length, s.cell_value }
    ensures { (result <> null) }
    
    ensures { hasCellType s result }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cdr] (wr_frame_cdr (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`arr] (wr_frame_arr (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`car] (wr_frame_car (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self}`rep union {result})`cell_rep]
              (wr_frame_cell_rep (old s) s (Rgn.union (s.rep[self]) (result.singleton))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self}`rep union {result})`cell_value]
              (wr_frame_cell_value (old s) s (Rgn.union (s.rep[self]) (result.singleton))) }
    
    ensures { let bsnap_r37 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r37 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              -
              1 }
    
    ensures { let oxs = old (s.contents[self]) in
              let t = oxs.hd in
              (s.cell_value[result])
              =
              t }
    
    ensures { let ostk = old (s.contents[self]) in
              (s.contents[self])
              =
              (ostk.tl) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    
    ensures { let rep2 = old (s.rep[self]) in
              (s.rep[self])
              =
              rep2 }
    
    ensures { s.stackPub }
  
  val getMaxSize (s: state) : int
    requires { s.stackPub }
    ensures { let bsnap_r37 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r37 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { result = s.maxSize }
    
    ensures { s.stackPub }
  
  val getCellValue (s: state) (c: reference) : int
    requires { hasCellType s c }
    requires { (c <> null) }
    requires { s.stackPub }
    ensures { let bsnap_r37 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r37 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.cell_value[c]) = result }
    
    ensures { s.stackPub }
end

module ArrayStack
  use prelude.Prelude
  use State
  use STACK
  
  predicate arrayStackPriv (s: state) =
    (forall s1 : reference.
       (isAllocated s s1)
         ->
         (hasStackType s s1)
         ->
         (Rgn.mem s1 s.pool)
         ->
         (let arr2 = s.arr[s1] in
          let stk = s.contents[s1] in
          let siz = s.size[s1] in
          let top3 = s.top[s1] in
          let rep4 = s.rep[s1] in
          (typeofRgn s rep4 (L.Cons CellArray (L.Cons Cell L.Nil)))
            /\
            (arr2 <> null)
            /\
            ((s.length[arr2]) = s.maxSize)
            /\
            (Rgn.mem arr2 rep4)
            /\
            (forall i : int. ((0 <= i) /\ (i <= top3)) -> (let c = A.get (s.slots[arr2]) i in
                                                           (c <> null) /\ (Rgn.mem c rep4)))
            /\
            (siz = (stk.STACK.listLength))
            /\
            (siz = top3 + 1)
            /\
            (forall i : int.
               ((0 <= i) /\ (i <= top3))
                 ->
                 (let c = A.get (s.slots[arr2]) i in
                  let v = s.cell_value[c] in
                  v
                  =
                  (STACK.listNth (top3 - i) stk)))))
      /\
      (s.STACK.stackPub)
  
  let init_Stack (s : state) (self : reference) : unit
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { not (Rgn.mem self s.pool) }
    requires { s.STACK.stackPub }
    requires { s.arrayStackPriv }
    writes { s.alloct, s.arr, s.contents, s.length, s.pool, s.rep, s.size, s.slots, s.top }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr {}`slots] (wr_frame_slots (old s) s emptyRgn) }
    
    ensures { [@expl:wr {}`length] (wr_frame_length (old s) s emptyRgn) }
    
    ensures { [@expl:wr {self}`arr] (wr_frame_arr (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`top] (wr_frame_top (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`contents] (wr_frame_contents (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`size] (wr_frame_size (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old s) s (self.singleton)) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.size[self]) = 0 }
    
    ensures { (s.contents[self]) = STACK.nil }
    
    ensures { let opool = old s.pool in
              s.pool
              =
              (Rgn.union opool (self.singleton)) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff (s.rep[self]) (null.singleton)) (Rgn.diff s.alloct.M.domain oa) }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.arrayStackPriv }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let arr1 = ref null in
      assert { hasCellArrayType s (! arr1) };
      (let ghost rep2 = ref emptyRgn in
       assert { isValidRgn s (! rep2) };
       ([@expl:self.rep := {}] (set_rep s (! self) emptyRgn));
       ([@expl:self.contents := nil] (set_contents s (! self) STACK.nil));
       ([@expl:self.size := 0] (set_size s (! self) 0));
       ([@expl:self.top := - 1] (set_top s (! self) (0 - 1)));
       (arr1 := ([@expl:arr := new(CellArray){maxSize}] (s.mk_CellArray)));
       ([@expl:arr := new(CellArray){maxSize}] (set_length s (! arr1) s.maxSize));
       ([@expl:arr := new(CellArray){maxSize}] (set_slots s (! arr1) (A.make s.maxSize null)));
       ([@expl:self.arr := arr] (set_arr s (! self) (! arr1)));
       assert {
         (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
       (rep2 := ([@expl:rep := self.rep] (s.rep[! self])));
       ([@expl:self.rep := rep union {arr}] (set_rep s (! self) (Rgn.union (! rep2) ((! arr1).singleton))));
       (set_pool s ([@expl:pool := pool union {self}] (Rgn.union s.pool ((! self).singleton))));
       (! result))
  
  let isEmpty (s : state) (self : reference) : bool
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.STACK.stackPub }
    requires { s.arrayStackPriv }
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { result <-> ((s.size[self]) = 0) }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.arrayStackPriv }
  = label INIT in
      let result = ref false in
      let self = ref self in
      let sz = ref 0 in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (sz := ([@expl:sz := self.size] (s.size[! self])));
      (result := ([@expl:result := sz = 0] ((! sz) = 0)));
      (! result)
  
  let push (s : state) (self : reference) (k : int) : unit
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               <
               s.maxSize }
    requires { s.STACK.stackPub }
    requires { s.arrayStackPriv }
    writes { s.alloct, s.arr, s.cell_rep, s.cell_value, s.contents, s.rep, s.size, s.slots, s.top }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`arr] (wr_frame_arr (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_rep] (wr_frame_cell_rep (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_value] (wr_frame_cell_value (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              +
              1 }
    
    ensures { let xs = old (s.contents[self]) in
              (s.contents[self])
              =
              (STACK.cons k xs) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff s.alloct.M.domain oa) (s.rep[self]) }
    
    ensures { let oa = old s.alloct.M.domain in
              let orep = old (s.rep[self]) in
              Rgn.subset (s.rep[self]) (Rgn.union orep (Rgn.diff s.alloct.M.domain oa)) }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.arrayStackPriv }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let k = ref k in
      let a = ref null in
      assert { hasCellArrayType s (! a) };
      (let t = ref 0 in
       let v = ref null in
       assert { hasCellType s (! v) };
       (let sz = ref 0 in
        let ghost rep1 = ref emptyRgn in
        assert { isValidRgn s (! rep1) };
        (let ghost contents2 = ref (any intList) in
         assert {
           (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
             \/
             ((! self) = null) };
         (a := ([@expl:a := self.arr] (s.arr[! self])));
         assert {
           (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
             \/
             ((! self) = null) };
         (t := ([@expl:t := self.top] (s.top[! self])));
         ([@expl:self.top := t + 1] (set_top s (! self) ((! t) + 1)));
         (v := ([@expl:v := new Cell] (s.mk_Cell)));
         ([@expl:v.cell_value := k] (set_cell_value s (! v) (! k)));
         ([@expl:v.cell_rep := {v}] (set_cell_rep s (! v) ((! v).singleton)));
         (set_slots s (! a) ([@expl:a.{t + 1} := v] (A.set (s.slots[! a]) ((! t) + 1) (! v))));
         ([@expl:self.arr := a] (set_arr s (! self) (! a)));
         assert {
           (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
             \/
             ((! self) = null) };
         (sz := ([@expl:sz := self.size] (s.size[! self])));
         ([@expl:self.size := sz + 1] (set_size s (! self) ((! sz) + 1)));
         assert {
           (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
             \/
             ((! self) = null) };
         (rep1 := ([@expl:rep := self.rep] (s.rep[! self])));
         ([@expl:self.rep := rep union {v}] (set_rep s (! self) (Rgn.union (! rep1) ((! v).singleton))));
         assert {
           (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
             \/
             (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
             \/
             ((! self) = null) };
         (contents2 := ([@expl:contents := self.contents] (s.contents[! self])));
         ([@expl:self.contents := cons(k,contents)] (set_contents s (! self) (STACK.cons (! k) (! contents2))));
         assert {
           let top3 = s.top[! self] in
           forall i : int.
             ((0 <= i) /\ (i <= top3))
               ->
               (let stk = s.contents[! self] in
                let arr4 = s.arr[! self] in
                let box = A.get (s.slots[arr4]) i in
                (s.cell_value[box])
                =
                (STACK.listNth (top3 - i) stk)) };
         (! result))))
  
  let pop (s : state) (self : reference) : reference
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.STACK.stackPub }
    requires { s.arrayStackPriv }
    writes { s.contents, s.size, s.top }
    ensures { (result <> null) }
    
    ensures { hasCellType s result }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              -
              1 }
    
    ensures { let oxs = old (s.contents[self]) in
              let t = oxs.STACK.hd in
              (s.cell_value[result])
              =
              t }
    
    ensures { let ostk = old (s.contents[self]) in
              (s.contents[self])
              =
              (ostk.STACK.tl) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    
    ensures { let rep2 = old (s.rep[self]) in
              (s.rep[self])
              =
              rep2 }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.arrayStackPriv }
  = label INIT in
      let result = ref null in
      let self = ref self in
      let a = ref null in
      assert { hasCellArrayType s (! a) };
      (let t = ref 0 in
       let sz = ref 0 in
       let ghost contents3 = ref (any intList) in
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (a := ([@expl:a := self.arr] (s.arr[! self])));
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (t := ([@expl:t := self.top] (s.top[! self])));
       assert {
         (Rgn.mem (! a) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
           \/
           (not (Rgn.mem (! a) (s.alloct.M.domain at INIT)))
           \/
           ((! a) = null) };
       (result := ([@expl:result := a.{t}] (A.get (s.slots[! a]) (! t))));
       ([@expl:self.top := t - 1] (set_top s (! self) ((! t) - 1)));
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (sz := ([@expl:sz := self.size] (s.size[! self])));
       ([@expl:self.size := sz - 1] (set_size s (! self) ((! sz) - 1)));
       assert {
         (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
           \/
           (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
           \/
           ((! self) = null) };
       (contents3 := ([@expl:contents := self.contents] (s.contents[! self])));
       ([@expl:self.contents := tl(contents)] (set_contents s (! self) ((! contents3).STACK.tl)));
       (! result))
  
  let getMaxSize (s : state) : int
    requires { s.STACK.stackPub }
    requires { s.arrayStackPriv }
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { result = s.maxSize }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.arrayStackPriv }
  = label INIT in let result = ref 0 in (result := ([@expl:result := maxSize] s.maxSize)); (! result)
  
  let getCellValue (s : state) (c : reference) : int
    requires { hasCellType s c }
    requires { (c <> null) }
    requires { s.STACK.stackPub }
    requires { s.arrayStackPriv }
    ensures { let bsnap_r1 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r1 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.cell_value[c]) = result }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.arrayStackPriv }
  = label INIT in
      let result = ref 0 in
      let c = ref c in
      assert { (Rgn.mem (! c) (((! c).singleton) at INIT)) \/ (not (Rgn.mem (! c) (s.alloct.M.domain at INIT))) \/ ((! c) = null) };
      (result := ([@expl:result := c.cell_value] (s.cell_value[! c])));
      (! result)
  
  lemma boundary_frames_invariant_ArrayStack:
    forall s : state, t : state, pi : PreRefperm.t.
      (okRefperm s t pi)
        ->
        (PreRefperm.identity pi s.alloct.M.domain t.alloct.M.domain)
        ->
        (s.maxSize = t.maxSize)
        ->
        (PreRefperm.idRgn pi s.pool t.pool)
        ->
        (agree_allfields s t pi (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (s.arrayStackPriv)
        ->
        (t.arrayStackPriv)
end

module CLIENT
  use prelude.Prelude
  use State
end

module Client1
  use prelude.Prelude
  use State
  use CLIENT
  use ArrayStack
  
  let prog (s : state) (n : int) : int
    requires { (s.maxSize > n) /\ (n >= 0) }
    requires { s.pool = emptyRgn }
    writes { s.alloct, s.arr, s.cell_rep, s.cell_value, s.contents, s.head, s.length, s.pool, s.rep, s.size, s.slots, s.top }
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr (pool union pool`rep)`contents] (wr_frame_contents (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`slots] (wr_frame_slots (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`arr] (wr_frame_arr (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`rep] (wr_frame_rep (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_rep] (wr_frame_cell_rep (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`top] (wr_frame_top (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`size] (wr_frame_size (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`length] (wr_frame_length (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_value] (wr_frame_cell_value (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    diverges
  = label INIT in
      let result = ref 0 in
      let n = ref n in
      let stk = ref null in
      assert { hasStackType s (! stk) };
      (let i = ref 0 in
       let c1 = ref null in
       assert { hasCellType s (! c1) };
       (stk := ([@expl:stk := new Stack] (s.mk_Stack)));
       assert {
         (Rgn.mem (! stk) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
           \/
           (not (Rgn.mem (! stk) (s.alloct.M.domain at INIT)))
           \/
           ((! stk) = null) };
       ([@expl:Stack(stk)] (ArrayStack.init_Stack s (! stk)));
       assert { Rgn.mem (! stk) s.pool };
       while ((! i) < (! n)) do
         invariant { [@expl:locals type invariant] ((hasCellType s (! c1)) /\ (hasStackType s (! stk))) }
         invariant { alloc_does_not_shrink (old s) s }
         invariant {
           [@expl:wr ({stk} union {stk}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr {stk}`rep`slots] (wr_frame_slots (old s) s (s.rep[! stk])) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`arr] (wr_frame_arr (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr {stk}`rep`cell_rep] (wr_frame_cell_rep (old s) s (s.rep[! stk])) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`top] (wr_frame_top (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr {stk}`rep`cell_value] (wr_frame_cell_value (old s) s (s.rep[! stk])) }
         invariant { (0 <= (! i)) /\ ((! i) <= (! n)) }
         invariant { (Rgn.mem (! stk) s.pool) /\ (0 <= (! n)) /\ ((! n) < s.maxSize) }
         invariant { let sz = s.size[! stk] in
                     sz
                     =
                     (! i) }
         invariant { (s.ArrayStack.STACK.stackPub) /\ (s.ArrayStack.arrayStackPriv) }
         invariant {
           let oa = old s.alloct.M.domain in
           Rgn.subset (Rgn.diff (Rgn.union ((! stk).singleton) (s.rep[! stk])) (null.singleton)) (Rgn.diff s.alloct.M.domain oa) }
         assert {
           Rgn.subset
              (Rgn.diff (Rgn.union ((! stk).singleton) (s.rep[! stk])) (null.singleton))
              (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
         ([@expl:push(stk,i)] (ArrayStack.push s (! stk) (! i)));
         (i := ([@expl:i := i + 1] ((! i) + 1)))
       done;
       (i := ([@expl:i := 0] 0));
       while ((! i) < (! n)) do
         invariant { [@expl:locals type invariant] ((hasCellType s (! c1)) /\ (hasStackType s (! stk))) }
         invariant { alloc_does_not_shrink (old s) s }
         invariant {
           [@expl:wr ({stk} union {stk}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`top] (wr_frame_top (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { (0 <= (! i)) /\ ((! i) <= (! n)) }
         invariant { (Rgn.mem (! stk) s.pool) /\ (0 <= (! n)) /\ ((! n) < s.maxSize) }
         invariant { let sz = s.size[! stk] in
                     sz
                     =
                     (! n)
                     -
                     (! i) }
         invariant { (s.ArrayStack.STACK.stackPub) /\ (s.ArrayStack.arrayStackPriv) }
         invariant { ((! c1) = null) \/ (let rep2 = s.rep[! stk] in
                                         Rgn.mem (! c1) rep2) }
         invariant {
           let oa = s.alloct.M.domain at INIT in
           Rgn.subset (Rgn.diff (Rgn.union ((! stk).singleton) (s.rep[! stk])) (null.singleton)) (Rgn.diff s.alloct.M.domain oa) }
         assert {
           Rgn.subset
              (Rgn.diff (Rgn.union ((! stk).singleton) (Rgn.union (s.rep[! stk]) ((! c1).singleton))) (null.singleton))
              (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
         (c1 := ([@expl:c := pop(stk)] (ArrayStack.pop s (! stk))));
         (let v = ref 0 in
          assert {
            (Rgn.mem (! c1) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
              \/
              (not (Rgn.mem (! c1) (s.alloct.M.domain at INIT)))
              \/
              ((! c1) = null) };
          (v := ([@expl:v := getCellValue(c)] (ArrayStack.getCellValue s (! c1))));
          (result := ([@expl:result := result + v] ((! result) + (! v))));
          (i := ([@expl:i := i + 1] ((! i) + 1))))
       done;
       (! result))
end

module ListStack
  use prelude.Prelude
  use State
  use STACK
  
  predicate stackRep (s: state) (xs: intList) (n: reference) = (hasNodeType s n) -> true
  
  predicate listStackPriv (s: state) =
    (s.STACK.stackPub)
      /\
      (forall s1 : reference.
         (isAllocated s s1)
           ->
           (hasStackType s s1)
           ->
           (Rgn.mem s1 s.pool)
           ->
           (let rep2 = s.rep[s1] in
            let head3 = s.head[s1] in
            let stk = s.contents[s1] in
            (Rgn.mem null rep2)
              /\
              (Rgn.mem head3 rep2)
              /\
              (Rgn.subset (img_cdr s rep2) rep2)
              /\
              (forall n : reference. (isAllocated s n) -> (hasNodeType s n) -> (Rgn.mem n rep2) -> (let c = s.car[n] in
                                                                    Rgn.mem c rep2))
              /\
              (stackRep s stk head3)))
  
  let init_Stack (s : state) (self : reference) : unit
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { not (Rgn.mem self s.pool) }
    requires { s.STACK.stackPub }
    requires { s.listStackPriv }
    writes { s.contents, s.head, s.pool, s.rep, s.size }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`contents] (wr_frame_contents (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`size] (wr_frame_size (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`head] (wr_frame_head (old s) s (self.singleton)) }
    
    ensures { let bsnap_r13 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r13 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.size[self]) = 0 }
    
    ensures { (s.contents[self]) = STACK.nil }
    
    ensures { let opool = old s.pool in
              s.pool
              =
              (Rgn.union opool (self.singleton)) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff (s.rep[self]) (null.singleton)) (Rgn.diff s.alloct.M.domain oa) }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.listStackPriv }
  = label INIT in
      let result = ref () in
      let self = ref self in
      ([@expl:self.rep := {null}] (set_rep s (! self) (null.singleton)));
      ([@expl:self.head := null] (set_head s (! self) null));
      ([@expl:self.contents := nil] (set_contents s (! self) STACK.nil));
      ([@expl:self.size := 0] (set_size s (! self) 0));
      (set_pool s ([@expl:pool := pool union {self}] (Rgn.union s.pool ((! self).singleton))));
      (! result)
  
  let isEmpty (s : state) (self : reference) : bool
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { s.STACK.stackPub }
    requires { s.listStackPriv }
    ensures { let bsnap_r13 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r13 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { result <-> ((s.size[self]) = 0) }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.listStackPriv }
  = label INIT in
      let result = ref false in
      let self = ref self in
      let sz = ref 0 in
      assert {
        (Rgn.mem (! self) (((! self).singleton) at INIT)) \/ (not (Rgn.mem (! self) (s.alloct.M.domain at INIT))) \/ ((! self) = null) };
      (sz := ([@expl:sz := self.size] (s.size[! self])));
      (result := ([@expl:result := sz = 0] ((! sz) = 0)));
      (! result)
  
  let push (s : state) (self : reference) (k : int) : unit
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               <
               s.maxSize }
    requires { s.STACK.stackPub }
    requires { s.listStackPriv }
    writes { s.alloct, s.car, s.cdr, s.cell_rep, s.cell_value, s.contents, s.head, s.rep, s.size }
    ensures { (result = ()) }
    
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cdr] (wr_frame_cdr (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr {self}`rep`car] (wr_frame_car (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_rep] (wr_frame_cell_rep (old s) s (s.rep[self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_value] (wr_frame_cell_value (old s) s (s.rep[self])) }
    
    ensures { let bsnap_r13 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r13 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              +
              1 }
    
    ensures { let xs = old (s.contents[self]) in
              (s.contents[self])
              =
              (STACK.cons k xs) }
    
    ensures { let oa = old s.alloct.M.domain in
              Rgn.subset (Rgn.diff s.alloct.M.domain oa) (s.rep[self]) }
    
    ensures { let oa = old s.alloct.M.domain in
              let orep = old (s.rep[self]) in
              Rgn.subset (s.rep[self]) (Rgn.union orep (Rgn.diff s.alloct.M.domain oa)) }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.listStackPriv }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let k = ref k in
      let v = ref null in
      assert { hasCellType s (! v) };
      (let n = ref null in
       assert { hasNodeType s (! n) };
       (let tmp = ref null in
        assert { hasNodeType s (! tmp) };
        (let sz = ref 0 in
         let ghost rep1 = ref emptyRgn in
         assert { isValidRgn s (! rep1) };
         (let ghost contents2 = ref (any intList) in
          (v := ([@expl:v := new Cell] (s.mk_Cell)));
          assert { not (Rgn.mem (! v) (Rgn.union s.pool (img_rep s s.pool))) };
          assert {
            (Rgn.mem (! v) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
              \/
              (not (Rgn.mem (! v) (s.alloct.M.domain at INIT)))
              \/
              ((! v) = null) };
          ([@expl:Cell(v,k)] (STACK.CELL.init_Cell s (! v) (! k)));
          (n := ([@expl:n := new Node] (s.mk_Node)));
          ([@expl:n.car := v] (set_car s (! n) (! v)));
          assert {
            (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
              \/
              (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
              \/
              ((! self) = null) };
          (tmp := ([@expl:tmp := self.head] (s.head[! self])));
          assert { let rep3 = s.rep[! self] in
                   Rgn.mem (! tmp) rep3 };
          ([@expl:n.cdr := tmp] (set_cdr s (! n) (! tmp)));
          assert {
            let rep4 = s.rep[! self] in
            forall n5 : reference.
              (isAllocated s n5) -> (hasNodeType s n5) -> (Rgn.mem n5 rep4) -> (let c = s.car[n5] in
                                                                    Rgn.mem c rep4) };
          ([@expl:self.head := n] (set_head s (! self) (! n)));
          assert {
            (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
              \/
              (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
              \/
              ((! self) = null) };
          (sz := ([@expl:sz := self.size] (s.size[! self])));
          ([@expl:self.size := sz + 1] (set_size s (! self) ((! sz) + 1)));
          assert {
            (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
              \/
              (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
              \/
              ((! self) = null) };
          (rep1 := ([@expl:rep := self.rep] (s.rep[! self])));
          ([@expl:self.rep := rep union {v} union {n}]
           (set_rep s (! self) (Rgn.union (Rgn.union (! rep1) ((! v).singleton)) ((! n).singleton))));
          assert { let h = s.head[! self] in
                   let n6 = s.cdr[h] in
                   let rep7 = s.rep[! self] in
                   Rgn.mem n6 rep7 };
          assert { let rep8 = s.rep[! self] in
                   Rgn.subset (img_cdr s rep8) rep8 };
          assert { let h = s.head[! self] in
                   let c = s.cdr[h] in
                   let rep9 = s.rep[! self] in
                   Rgn.mem c rep9 };
          assert {
            let rep10 = s.rep[! self] in
            forall n11 : reference.
              (isAllocated s n11) -> (hasNodeType s n11) -> (Rgn.mem n11 rep10) -> (let c = s.car[n11] in
                                                                    Rgn.mem c rep10) };
          assert {
            (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (s.rep[! self])) at INIT))
              \/
              (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
              \/
              ((! self) = null) };
          (contents2 := ([@expl:contents := self.contents] (s.contents[! self])));
          ([@expl:self.contents := cons(k,contents)] (set_contents s (! self) (STACK.cons (! k) (! contents2))));
          assert { let h = s.head[! self] in
                   let stk = s.contents[! self] in
                   stackRep s stk h };
          (! result)))))
  
  let pop (s : state) (self : reference) : reference
    requires { hasStackType s self }
    requires { (self <> null) }
    requires { Rgn.mem self s.pool }
    requires { let sz = s.size[self] in
               sz
               >
               0 }
    requires { s.STACK.stackPub }
    requires { s.listStackPriv }
    writes { s.contents, s.head, s.size }
    ensures { (result <> null) }
    
    ensures { hasCellType s result }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union (self.singleton) (s.rep[self]))) }
    
    ensures { let bsnap_r13 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r13 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { let osz = old (s.size[self]) in
              (s.size[self])
              =
              osz
              -
              1 }
    
    ensures { let oxs = old (s.contents[self]) in
              let t = oxs.STACK.hd in
              (s.cell_value[result])
              =
              t }
    
    ensures { let ostk = old (s.contents[self]) in
              (s.contents[self])
              =
              (ostk.STACK.tl) }
    
    ensures { let rep1 = s.rep[self] in
              Rgn.mem result rep1 }
    
    ensures { let rep2 = old (s.rep[self]) in
              (s.rep[self])
              =
              rep2 }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.listStackPriv }
  = label INIT in
      let result = ref null in
      let self = ref self in
      let tmp = ref null in
      assert { hasNodeType s (! tmp) };
      (let nxt = ref null in
       assert { hasNodeType s (! nxt) };
       (let sz = ref 0 in
        let ghost contents3 = ref (any intList) in
        assert { let stk = s.contents[! self] in
                 exists h : int, t : intList. stk = (STACK.cons h t) };
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (tmp := ([@expl:tmp := self.head] (s.head[! self])));
        assert { (! tmp) <> null };
        assert {
          (Rgn.mem (! tmp) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
            \/
            (not (Rgn.mem (! tmp) (s.alloct.M.domain at INIT)))
            \/
            ((! tmp) = null) };
        (result := ([@expl:result := tmp.car] (s.car[! tmp])));
        assert {
          (Rgn.mem (! tmp) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
            \/
            (not (Rgn.mem (! tmp) (s.alloct.M.domain at INIT)))
            \/
            ((! tmp) = null) };
        (nxt := ([@expl:nxt := tmp.cdr] (s.cdr[! tmp])));
        ([@expl:self.head := nxt] (set_head s (! self) (! nxt)));
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (sz := ([@expl:sz := self.size] (s.size[! self])));
        ([@expl:self.size := sz - 1] (set_size s (! self) ((! sz) - 1)));
        assert {
          (Rgn.mem (! self) ((Rgn.union ((! self).singleton) (Rgn.union (s.rep[! self]) ((! result).singleton))) at INIT))
            \/
            (not (Rgn.mem (! self) (s.alloct.M.domain at INIT)))
            \/
            ((! self) = null) };
        (contents3 := ([@expl:contents := self.contents] (s.contents[! self])));
        ([@expl:self.contents := tl(contents)] (set_contents s (! self) ((! contents3).STACK.tl)));
        (! result)))
  
  let getMaxSize (s : state) : int
    requires { s.STACK.stackPub }
    requires { s.listStackPriv }
    ensures { let bsnap_r13 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r13 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { result = s.maxSize }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.listStackPriv }
  = label INIT in let result = ref 0 in (result := ([@expl:result := maxSize] s.maxSize)); (! result)
  
  let getCellValue (s : state) (c : reference) : int
    requires { hasCellType s c }
    requires { (c <> null) }
    requires { s.STACK.stackPub }
    requires { s.listStackPriv }
    ensures { let bsnap_r13 = old (Rgn.union s.pool (img_rep s s.pool)) in
              Rgn.subset bsnap_r13 (Rgn.union s.pool (img_rep s s.pool)) }
    
    ensures { (s.cell_value[c]) = result }
    
    ensures { s.STACK.stackPub }
    
    ensures { s.listStackPriv }
  = label INIT in
      let result = ref 0 in
      let c = ref c in
      assert { (Rgn.mem (! c) (((! c).singleton) at INIT)) \/ (not (Rgn.mem (! c) (s.alloct.M.domain at INIT))) \/ ((! c) = null) };
      (result := ([@expl:result := c.cell_value] (s.cell_value[! c])));
      (! result)
  
  lemma boundary_frames_invariant_ListStack:
    forall s : state, t : state, pi : PreRefperm.t.
      (okRefperm s t pi)
        ->
        (PreRefperm.identity pi s.alloct.M.domain t.alloct.M.domain)
        ->
        (s.maxSize = t.maxSize)
        ->
        (PreRefperm.idRgn pi s.pool t.pool)
        ->
        (agree_allfields s t pi (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (s.listStackPriv)
        ->
        (t.listStackPriv)
end

module Client2
  use prelude.Prelude
  use State
  use CLIENT
  use ListStack
  
  let prog (s : state) (n : int) : int
    requires { (s.maxSize > n) /\ (n >= 0) }
    requires { s.pool = emptyRgn }
    writes { s.alloct, s.arr, s.car, s.cdr, s.cell_rep, s.cell_value, s.contents, s.head, s.pool, s.rep, s.size, s.top }
    ensures { alloc_does_not_shrink (old s) s }
    
    ensures { [@expl:wr (pool union pool`rep)`contents] (wr_frame_contents (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cdr] (wr_frame_cdr (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`arr] (wr_frame_arr (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`car] (wr_frame_car (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`rep] (wr_frame_rep (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_rep] (wr_frame_cell_rep (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`top] (wr_frame_top (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`size] (wr_frame_size (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_value] (wr_frame_cell_value (old s) s (Rgn.union s.pool (img_rep s s.pool))) }
    diverges
  = label INIT in
      let result = ref 0 in
      let n = ref n in
      let stk = ref null in
      assert { hasStackType s (! stk) };
      (let i = ref 0 in
       let c1 = ref null in
       assert { hasCellType s (! c1) };
       (stk := ([@expl:stk := new Stack] (s.mk_Stack)));
       assert {
         (Rgn.mem (! stk) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
           \/
           (not (Rgn.mem (! stk) (s.alloct.M.domain at INIT)))
           \/
           ((! stk) = null) };
       ([@expl:Stack(stk)] (ListStack.init_Stack s (! stk)));
       while ((! i) < (! n)) do
         invariant { [@expl:locals type invariant] ((hasCellType s (! c1)) /\ (hasStackType s (! stk))) }
         invariant { alloc_does_not_shrink (old s) s }
         invariant {
           [@expl:wr ({stk} union {stk}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`head] (wr_frame_head (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr {stk}`rep`cdr] (wr_frame_cdr (old s) s (s.rep[! stk])) }
         invariant { [@expl:wr {stk}`rep`car] (wr_frame_car (old s) s (s.rep[! stk])) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`rep] (wr_frame_rep (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr {stk}`rep`cell_rep] (wr_frame_cell_rep (old s) s (s.rep[! stk])) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr {stk}`rep`cell_value] (wr_frame_cell_value (old s) s (s.rep[! stk])) }
         invariant { (0 <= (! i)) /\ ((! i) <= (! n)) }
         invariant { (Rgn.mem (! stk) s.pool) /\ (0 <= (! n)) /\ ((! n) < s.maxSize) }
         invariant { let sz = s.size[! stk] in
                     sz
                     =
                     (! i) }
         invariant { (s.ListStack.STACK.stackPub) /\ (s.ListStack.listStackPriv) }
         invariant {
           let oa = old s.alloct.M.domain in
           Rgn.subset (Rgn.diff (Rgn.union ((! stk).singleton) (s.rep[! stk])) (null.singleton)) (Rgn.diff s.alloct.M.domain oa) }
         assert {
           Rgn.subset
              (Rgn.diff (Rgn.union ((! stk).singleton) (s.rep[! stk])) (null.singleton))
              (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
         ([@expl:push(stk,i)] (ListStack.push s (! stk) (! i)));
         (i := ([@expl:i := i + 1] ((! i) + 1)))
       done;
       (i := ([@expl:i := 0] 0));
       while ((! i) < (! n)) do
         invariant { [@expl:locals type invariant] ((hasCellType s (! c1)) /\ (hasStackType s (! stk))) }
         invariant { alloc_does_not_shrink (old s) s }
         invariant {
           [@expl:wr ({stk} union {stk}`rep)`contents] (wr_frame_contents (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`head] (wr_frame_head (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old s) s (Rgn.union ((! stk).singleton) (s.rep[! stk]))) }
         invariant { (0 <= (! i)) /\ ((! i) <= (! n)) }
         invariant { (Rgn.mem (! stk) s.pool) /\ (0 <= (! n)) /\ ((! n) < s.maxSize) }
         invariant { let sz = s.size[! stk] in
                     sz
                     =
                     (! n)
                     -
                     (! i) }
         invariant { (s.ListStack.STACK.stackPub) /\ (s.ListStack.listStackPriv) }
         invariant { ((! c1) = null) \/ (let rep2 = s.rep[! stk] in
                                         Rgn.mem (! c1) rep2) }
         invariant {
           let oa = s.alloct.M.domain at INIT in
           Rgn.subset (Rgn.diff (Rgn.union ((! stk).singleton) (s.rep[! stk])) (null.singleton)) (Rgn.diff s.alloct.M.domain oa) }
         assert {
           Rgn.subset
              (Rgn.diff (Rgn.union ((! stk).singleton) (Rgn.union (s.rep[! stk]) ((! c1).singleton))) (null.singleton))
              (Rgn.union ((Rgn.union s.pool (img_rep s s.pool)) at INIT) (Rgn.diff s.alloct.M.domain (s.alloct.M.domain at INIT))) };
         (c1 := ([@expl:c := pop(stk)] (ListStack.pop s (! stk))));
         (let v = ref 0 in
          assert {
            (Rgn.mem (! c1) ((Rgn.union s.pool (img_rep s s.pool)) at INIT))
              \/
              (not (Rgn.mem (! c1) (s.alloct.M.domain at INIT)))
              \/
              ((! c1) = null) };
          (v := ([@expl:v := getCellValue(c)] (ListStack.getCellValue s (! c1))));
          (result := ([@expl:result := result + v] ((! result) + (! v))));
          (i := ([@expl:i := i + 1] ((! i) + 1))))
       done;
       (! result))
end

module REL_STACK_biinterface
  use prelude.Prelude
  use State
  use ArrayStack
  use ListStack
  use export stack_theory.Stack_theory
  
  val init_Stack (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (r_self: reference) : 
    (unit, unit)
    requires { hasStackType l_s l_self }
    requires { (l_self <> null) }
    requires { hasStackType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { (true /\ true) }
    requires { ((agree_allfields l_s r_s pi (Rgn.diff (l_self.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_allfields
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (r_self.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    requires { ((not (Rgn.mem l_self l_s.pool)) /\ (not (Rgn.mem r_self r_s.pool))) }
    writes { l_s.head,
      l_s.rep,
      l_s.size,
      l_s.contents,
      l_s.top,
      l_s.arr,
      l_s.alloct,
      l_s.pool,
      r_s.head,
      r_s.rep,
      r_s.size,
      r_s.contents,
      r_s.top,
      r_s.arr,
      r_s.alloct,
      r_s.pool }
    ensures { [@expl:wr {self}`head] (wr_frame_head (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`size] (wr_frame_size (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`contents] (wr_frame_contents (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`top] (wr_frame_top (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`arr] (wr_frame_arr (old l_s) l_s (l_self.singleton)) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr {self}`head] (wr_frame_head (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`size] (wr_frame_size (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`contents] (wr_frame_contents (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`top] (wr_frame_top (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`arr] (wr_frame_arr (old r_s) r_s (r_self.singleton)) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { (true /\ true) }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              let l_self0 = old (l_self.singleton) in
              let r_self0 = old (r_self.singleton) in
              ((agree_allfields
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc) l_self0) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_allfields
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc) r_self0) (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { ((let oa = old l_s.alloct.M.domain in
                Rgn.subset (Rgn.diff (l_s.rep[l_self]) (null.singleton)) (Rgn.diff l_s.alloct.M.domain oa)) /\
                 (let oa = old r_s.alloct.M.domain in
                  Rgn.subset (Rgn.diff (r_s.rep[r_self]) (null.singleton)) (Rgn.diff r_s.alloct.M.domain oa))) }
    
    ensures { ((let opool = old l_s.pool in
                l_s.pool
                =
                (Rgn.union opool (l_self.singleton))) /\
                 (let opool = old r_s.pool in
                  r_s.pool
                  =
                  (Rgn.union opool (r_self.singleton)))) }
    
    ensures { (((l_s.contents[l_self]) = ArrayStack.STACK.nil) /\ ((r_s.contents[r_self]) = ListStack.STACK.nil)) }
    
    ensures { (((l_s.size[l_self]) = 0) /\ ((r_s.size[r_self]) = 0)) }
    
    ensures { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    
    ensures { ((let bsnap_r25 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r25 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r25 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r25 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
  
  val isEmpty (l_s: state) (r_s: state) (pi3: PreRefperm.t) (l_self: reference) (r_self: reference) : 
    (bool, bool)
    requires { hasStackType l_s l_self }
    requires { (l_self <> null) }
    requires { hasStackType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi3 }
    requires { (true /\ true) }
    requires { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    requires { PreRefperm.idRef pi3 l_self r_self }
    requires { ((agree_allfields l_s r_s pi3 (l_self.singleton)) /\
                  (agree_allfields r_s l_s (pi3.PreRefperm.invert) (r_self.singleton)))
    }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { okRefperm l_s r_s pi3 }
    
    ensures { (true /\ true) }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields
                  l_s
                  r_s
                  pi3
                  (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_allfields
                    r_s
                    l_s
                    (pi3.PreRefperm.invert)
                    (Rgn.diff (Rgn.diff r_s.alloct.M.domain r_s_alloc) (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result <-> ((l_s.size[l_self]) = 0)) /\ (r_result <-> ((r_s.size[r_self]) = 0)))
              end }
    
    ensures { ((let bsnap_r25 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r25 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r25 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r25 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
  
  val push (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_self: reference) (l_k: int) (r_self: reference) (r_k: int) : 
    (unit, unit)
    requires { hasStackType l_s l_self }
    requires { (l_self <> null) }
    requires { hasStackType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { (true /\ true) }
    requires { ((agree_allfields
                   l_s
                   r_s
                   pi
                   (Rgn.diff (Rgn.union (l_self.singleton) (l_s.rep[l_self])) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_allfields
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (Rgn.union (r_self.singleton) (r_s.rep[r_self])) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { (PreRefperm.idRef pi l_self r_self) /\ (l_k = r_k) }
    requires { ((let sz = l_s.size[l_self] in
                 sz
                 <
                 l_s.maxSize) /\ (let sz = r_s.size[r_self] in
                                  sz
                                  <
                                  r_s.maxSize)) }
    requires { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.contents,
      l_s.slots,
      l_s.head,
      l_s.cdr,
      l_s.arr,
      l_s.car,
      l_s.rep,
      l_s.cell_rep,
      l_s.top,
      l_s.size,
      l_s.length,
      l_s.cell_value,
      l_s.alloct,
      r_s.contents,
      r_s.slots,
      r_s.head,
      r_s.cdr,
      r_s.arr,
      r_s.car,
      r_s.rep,
      r_s.cell_rep,
      r_s.top,
      r_s.size,
      r_s.length,
      r_s.cell_value,
      r_s.alloct }
    ensures { [@expl:wr ({self} union {self}`rep)`contents]
              (wr_frame_contents (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`cdr] (wr_frame_cdr (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`arr] (wr_frame_arr (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`car] (wr_frame_car (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_rep] (wr_frame_cell_rep (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`cell_value] (wr_frame_cell_value (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents]
              (wr_frame_contents (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`cdr] (wr_frame_cdr (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`arr] (wr_frame_arr (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`car] (wr_frame_car (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_rep] (wr_frame_cell_rep (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`cell_value] (wr_frame_cell_value (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { (true /\ true) }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              let l_snap_r1 = old (Rgn.union (l_self.singleton) (l_s.rep[l_self])) in
              let r_snap_r1 = old (Rgn.union (r_self.singleton) (r_s.rep[r_self])) in
              ((agree_allfields
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc) l_snap_r1) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_allfields
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff
                        (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc) r_snap_r1)
                        (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { ((let oa = old l_s.alloct.M.domain in
                let orep = old (l_s.rep[l_self]) in
                Rgn.subset (l_s.rep[l_self]) (Rgn.union orep (Rgn.diff l_s.alloct.M.domain oa))) /\
                 (let oa = old r_s.alloct.M.domain in
                  let orep = old (r_s.rep[r_self]) in
                  Rgn.subset (r_s.rep[r_self]) (Rgn.union orep (Rgn.diff r_s.alloct.M.domain oa)))) }
    
    ensures { ((let oa = old l_s.alloct.M.domain in
                Rgn.subset (Rgn.diff l_s.alloct.M.domain oa) (l_s.rep[l_self])) /\
                 (let oa = old r_s.alloct.M.domain in
                  Rgn.subset (Rgn.diff r_s.alloct.M.domain oa) (r_s.rep[r_self]))) }
    
    ensures { ((let xs = old (l_s.contents[l_self]) in
                (l_s.contents[l_self])
                =
                (ArrayStack.STACK.cons l_k xs)) /\
                 (let xs = old (r_s.contents[r_self]) in
                  (r_s.contents[r_self])
                  =
                  (ListStack.STACK.cons r_k xs))) }
    
    ensures { ((let osz = old (l_s.size[l_self]) in
                (l_s.size[l_self])
                =
                osz
                +
                1) /\
                 (let osz = old (r_s.size[r_self]) in
                  (r_s.size[r_self])
                  =
                  osz
                  +
                  1)) }
    
    ensures { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    
    ensures { ((let bsnap_r25 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r25 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r25 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r25 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
  
  val pop (l_s: state) (r_s: state) (pi4: PreRefperm.t) (l_self: reference) (r_self: reference) : 
    (reference, reference)
    requires { hasStackType l_s l_self }
    requires { (l_self <> null) }
    requires { hasStackType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi4 }
    requires { (true /\ true) }
    requires { ((agree_allfields
                   l_s
                   r_s
                   pi4
                   (Rgn.diff (Rgn.union (l_self.singleton) (l_s.rep[l_self])) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_allfields
                     r_s
                     l_s
                     (pi4.PreRefperm.invert)
                     (Rgn.diff (Rgn.union (r_self.singleton) (r_s.rep[r_self])) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { PreRefperm.idRef pi4 l_self r_self }
    requires { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    requires { ((let sz = l_s.size[l_self] in
                 sz
                 >
                 0) /\ (let sz = r_s.size[r_self] in
                        sz
                        >
                        0)) }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    writes { l_s.contents,
      l_s.slots,
      l_s.head,
      l_s.cdr,
      l_s.arr,
      l_s.car,
      l_s.rep,
      l_s.cell_rep,
      l_s.top,
      l_s.size,
      l_s.length,
      l_s.cell_value,
      r_s.contents,
      r_s.slots,
      r_s.head,
      r_s.cdr,
      r_s.arr,
      r_s.car,
      r_s.rep,
      r_s.cell_rep,
      r_s.top,
      r_s.size,
      r_s.length,
      r_s.cell_value }
    ensures { match result with
              | (l_result, _) -> hasCellType l_s l_result
              end }
    
    ensures { match result with
              | (_, r_result) -> hasCellType r_s r_result
              end }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents]
              (wr_frame_contents (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`cdr] (wr_frame_cdr (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`arr] (wr_frame_arr (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`car] (wr_frame_car (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_rep] (wr_frame_cell_rep (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union (l_self.singleton) (l_s.rep[l_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr {self}`rep`cell_value] (wr_frame_cell_value (old l_s) l_s (l_s.rep[l_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`contents]
              (wr_frame_contents (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`slots] (wr_frame_slots (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`cdr] (wr_frame_cdr (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`arr] (wr_frame_arr (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`car] (wr_frame_car (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`cell_rep] (wr_frame_cell_rep (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`top] (wr_frame_top (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr ({self} union {self}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union (r_self.singleton) (r_s.rep[r_self]))) }
    
    ensures { [@expl:wr {self}`rep`length] (wr_frame_length (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { [@expl:wr {self}`rep`cell_value] (wr_frame_cell_value (old r_s) r_s (r_s.rep[r_self])) }
    
    ensures { okRefperm l_s r_s pi4 }
    
    ensures { (true /\ true) }
    
    ensures { match result with
              | (l_result, r_result) ->
                  let l_r = l_result in
                  let r_r = r_result in
                  let l_c = l_s.cell_value[l_r] in
                  let r_c = r_s.cell_value[r_r] in
                  (l_c = r_c)
              end }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              let l_snap_r1 = old (Rgn.union (l_self.singleton) (l_s.rep[l_self])) in
              let r_snap_r1 = old (Rgn.union (r_self.singleton) (r_s.rep[r_self])) in
              ((agree_allfields
                  l_s
                  r_s
                  pi4
                  (Rgn.diff (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc) l_snap_r1) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_allfields
                    r_s
                    l_s
                    (pi4.PreRefperm.invert)
                    (Rgn.diff
                        (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc) r_snap_r1)
                        (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    
    ensures { ((let rep5 = old (l_s.rep[l_self]) in
                (l_s.rep[l_self])
                =
                rep5) /\
                 (let rep6 = old (r_s.rep[r_self]) in
                  (r_s.rep[r_self])
                  =
                  rep6)) }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let rep7 = l_s.rep[l_self] in
                    Rgn.mem l_result rep7) /\ (let rep8 = r_s.rep[r_self] in
                                               Rgn.mem r_result rep8))
              end }
    
    ensures { ((let ostk = old (l_s.contents[l_self]) in
                (l_s.contents[l_self])
                =
                (ostk.ArrayStack.STACK.tl)) /\
                 (let ostk = old (r_s.contents[r_self]) in
                  (r_s.contents[r_self])
                  =
                  (ostk.ListStack.STACK.tl))) }
    
    ensures { match result with
              | (l_result, r_result) ->
                  ((let oxs = old (l_s.contents[l_self]) in
                    let t = oxs.ArrayStack.STACK.hd in
                    (l_s.cell_value[l_result])
                    =
                    t) /\
                     (let oxs = old (r_s.contents[r_self]) in
                      let t = oxs.ListStack.STACK.hd in
                      (r_s.cell_value[r_result])
                      =
                      t))
              end }
    
    ensures { ((let osz = old (l_s.size[l_self]) in
                (l_s.size[l_self])
                =
                osz
                -
                1) /\
                 (let osz = old (r_s.size[r_self]) in
                  (r_s.size[r_self])
                  =
                  osz
                  -
                  1)) }
    
    ensures { ((let bsnap_r25 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r25 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r25 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r25 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((not (l_result = null)) /\ (not (r_result = null)))
              end }
  
  val getCellValue (l_s: state) (r_s: state) (pi: PreRefperm.t) (l_c: reference) (r_c: reference) : 
    (int, int)
    requires { hasCellType l_s l_c }
    requires { (l_c <> null) }
    requires { hasCellType r_s r_c }
    requires { (r_c <> null) }
    requires { okRefperm l_s r_s pi }
    requires { (true /\ true) }
    requires { let l_v = l_s.cell_value[l_c] in
               let r_v = r_s.cell_value[r_c] in
               (l_v = r_v) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { (true /\ true) }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    
    ensures { ((let bsnap_r25 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r25 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r25 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r25 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
end

module CLIENT_REL
  use prelude.Prelude
  use State
  use Client1
  use Client2
  use REL_STACK_biinterface
  
  let prog (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_n : int) (r_n : int) : 
    (int, int)
    requires { okRefperm l_s r_s pi }
    requires { ((l_s.pool = emptyRgn) /\ (r_s.pool = emptyRgn)) }
    requires { ((l_s.maxSize > l_n) /\ (r_s.maxSize > r_n)) /\ ((l_n >= 0) /\ (r_n >= 0)) /\ (l_n = r_n) }
    writes { pi,
      l_s.alloct,
      l_s.arr,
      l_s.car,
      l_s.cdr,
      l_s.cell_rep,
      l_s.cell_value,
      l_s.contents,
      l_s.head,
      l_s.length,
      l_s.pool,
      l_s.rep,
      l_s.size,
      l_s.slots,
      l_s.top,
      r_s.alloct,
      r_s.arr,
      r_s.car,
      r_s.cdr,
      r_s.cell_rep,
      r_s.cell_value,
      r_s.contents,
      r_s.head,
      r_s.length,
      r_s.pool,
      r_s.rep,
      r_s.size,
      r_s.slots,
      r_s.top }
    ensures { [@expl:wr (pool union pool`rep)`contents] (wr_frame_contents (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`slots] (wr_frame_slots (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cdr] (wr_frame_cdr (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`arr] (wr_frame_arr (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`car] (wr_frame_car (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_rep] (wr_frame_cell_rep (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`top] (wr_frame_top (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`length] (wr_frame_length (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_value]
              (wr_frame_cell_value (old l_s) l_s (Rgn.union l_s.pool (img_rep l_s l_s.pool))) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr (pool union pool`rep)`contents] (wr_frame_contents (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`slots] (wr_frame_slots (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cdr] (wr_frame_cdr (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`arr] (wr_frame_arr (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`car] (wr_frame_car (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_rep] (wr_frame_cell_rep (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`top] (wr_frame_top (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`length] (wr_frame_length (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { [@expl:wr (pool union pool`rep)`cell_value]
              (wr_frame_cell_value (old r_s) r_s (Rgn.union r_s.pool (img_rep r_s r_s.pool))) }
    
    ensures { alloc_does_not_shrink (old r_s) r_s }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    diverges
  = label INIT in
      let r_result = ref 0 in
      let l_result = ref 0 in
      let l_n = ref l_n in
      let r_n = ref r_n in
      let l_stk = ref null in
      let r_stk = ref null in
      let l_i = ref 0 in
      let r_i = ref 0 in
      let l_c = ref null in
      let r_c = ref null in
      (l_stk := ([@expl:stk := new Stack] (l_s.mk_Stack)));
      (r_stk := ([@expl:stk := new Stack] (r_s.mk_Stack)));
      (PreRefperm.updateRefperm pi (! l_stk) (! r_stk));
      (match [@expl:Stack(stk)] (REL_STACK_biinterface.init_Stack l_s r_s pi (! l_stk) (! r_stk)) with
       | _ -> ()
       end);
      while ((! l_i) < (! l_n)) do
        invariant { [@expl:locals type invariant left] ((hasCellType l_s (! l_c)) /\ (hasStackType l_s (! l_stk))) }
        invariant { [@expl:locals type invariant right] ((hasCellType r_s (! r_c)) /\ (hasStackType r_s (! r_stk))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`contents]
          (wr_frame_contents (old l_s) l_s (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk]))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk]))) }
        invariant { [@expl:wr {stk}`rep`cdr] (wr_frame_cdr (old l_s) l_s (l_s.rep[! l_stk])) }
        invariant { [@expl:wr {stk}`rep`car] (wr_frame_car (old l_s) l_s (l_s.rep[! l_stk])) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`rep] (wr_frame_rep (old l_s) l_s (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk]))) }
        invariant { [@expl:wr {stk}`rep`cell_rep] (wr_frame_cell_rep (old l_s) l_s (l_s.rep[! l_stk])) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk]))) }
        invariant { [@expl:wr {stk}`rep`cell_value] (wr_frame_cell_value (old l_s) l_s (l_s.rep[! l_stk])) }
        invariant { alloc_does_not_shrink (old l_s) l_s }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`contents]
          (wr_frame_contents (old r_s) r_s (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk]))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk]))) }
        invariant { [@expl:wr {stk}`rep`cdr] (wr_frame_cdr (old r_s) r_s (r_s.rep[! r_stk])) }
        invariant { [@expl:wr {stk}`rep`car] (wr_frame_car (old r_s) r_s (r_s.rep[! r_stk])) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`rep] (wr_frame_rep (old r_s) r_s (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk]))) }
        invariant { [@expl:wr {stk}`rep`cell_rep] (wr_frame_cell_rep (old r_s) r_s (r_s.rep[! r_stk])) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk]))) }
        invariant { [@expl:wr {stk}`rep`cell_value] (wr_frame_cell_value (old r_s) r_s (r_s.rep[! r_stk])) }
        invariant { alloc_does_not_shrink (old r_s) r_s }
        invariant { okRefperm l_s r_s pi }
        invariant {
          ((0 <= (! l_i)) /\ (0 <= (! r_i)))
            /\
            (((! l_i) <= (! l_n)) /\ ((! r_i) <= (! r_n)))
            /\
            ((Rgn.mem (! l_stk) l_s.pool) /\ (Rgn.mem (! r_stk) r_s.pool)) }
        invariant {
          ((! l_i) = (! r_i))
            /\
            ((! l_n) = (! r_n))
            /\
            ((0 <= (! l_n)) /\ (0 <= (! r_n)))
            /\
            (((! l_n) < l_s.maxSize) /\ ((! r_n) < r_s.maxSize)) }
        invariant { let l_xs = l_s.contents[! l_stk] in
                    let r_xs = r_s.contents[! r_stk] in
                    (l_xs = r_xs) }
        invariant { ((let sz = l_s.size[! l_stk] in
                      sz
                      =
                      (! l_i)) /\ (let sz = r_s.size[! r_stk] in
                                   sz
                                   =
                                   (! r_i))) }
        invariant { ((l_s.Client1.ArrayStack.STACK.stackPub) /\ (r_s.Client2.ListStack.STACK.stackPub)) }
        invariant {
          ((let oa = old l_s.alloct.M.domain in
            Rgn.subset
               (Rgn.diff (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk])) (null.singleton))
               (Rgn.diff l_s.alloct.M.domain oa)) /\
             (let oa = old r_s.alloct.M.domain in
              Rgn.subset
                 (Rgn.diff (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk])) (null.singleton))
                 (Rgn.diff r_s.alloct.M.domain oa))) }
        invariant { [@expl:lockstep] (((! l_i) < (! l_n)) = ((! r_i) < (! r_n))) }
        (match [@expl:push(stk,i)] (REL_STACK_biinterface.push l_s r_s pi (! l_stk) (! l_i) (! r_stk) (! r_i)) with
         | _ -> ()
         end);
        (l_i := ([@expl:i := i + 1] ((! l_i) + 1)));
        (r_i := ([@expl:i := i + 1] ((! r_i) + 1)))
      done;
      (l_i := ([@expl:i := 0] 0));
      (r_i := ([@expl:i := 0] 0));
      assert { ((! l_result) = (! r_result)) };
      while ((! l_i) < (! l_n)) do
        invariant { [@expl:locals type invariant left] ((hasCellType l_s (! l_c)) /\ (hasStackType l_s (! l_stk))) }
        invariant { [@expl:locals type invariant right] ((hasCellType r_s (! r_c)) /\ (hasStackType r_s (! r_stk))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`contents]
          (wr_frame_contents (old l_s) l_s (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk]))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`head] (wr_frame_head (old l_s) l_s (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk]))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old l_s) l_s (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk]))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`contents]
          (wr_frame_contents (old r_s) r_s (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk]))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`head] (wr_frame_head (old r_s) r_s (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk]))) }
        invariant {
          [@expl:wr ({stk} union {stk}`rep)`size] (wr_frame_size (old r_s) r_s (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk]))) }
        invariant { okRefperm l_s r_s pi }
        invariant { ((0 <= (! l_i)) /\ (0 <= (! r_i))) /\ (((! l_i) <= (! l_n)) /\ ((! r_i) <= (! r_n))) }
        invariant { ((! l_i) = (! r_i)) /\ ((! l_n) = (! r_n)) }
        invariant {
          ((Rgn.mem (! l_stk) l_s.pool) /\ (Rgn.mem (! r_stk) r_s.pool))
            /\
            ((0 <= (! l_n)) /\ (0 <= (! r_n)))
            /\
            (((! l_n) < l_s.maxSize) /\ ((! r_n) < r_s.maxSize)) }
        invariant { ((let sz = l_s.size[! l_stk] in
                      sz
                      =
                      (! l_n)
                      -
                      (! l_i)) /\ (let sz = r_s.size[! r_stk] in
                                   sz
                                   =
                                   (! r_n)
                                   -
                                   (! r_i))) }
        invariant {
          ((((! l_c) = null) \/ (let rep9 = l_s.rep[! l_stk] in
                                 Rgn.mem (! l_c) rep9)) /\
             (((! r_c) = null) \/ (let rep10 = r_s.rep[! r_stk] in
                                   Rgn.mem (! r_c) rep10))) }
        invariant { ((l_s.Client1.ArrayStack.STACK.stackPub) /\ (r_s.Client2.ListStack.STACK.stackPub)) }
        invariant { let l_xs = l_s.contents[! l_stk] in
                    let r_xs = r_s.contents[! r_stk] in
                    (l_xs = r_xs) }
        invariant { ((! l_result) = (! r_result)) }
        invariant {
          ((let oa = l_s.alloct.M.domain at INIT in
            Rgn.subset
               (Rgn.diff (Rgn.union ((! l_stk).singleton) (l_s.rep[! l_stk])) (null.singleton))
               (Rgn.diff l_s.alloct.M.domain oa)) /\
             (let oa = r_s.alloct.M.domain at INIT in
              Rgn.subset
                 (Rgn.diff (Rgn.union ((! r_stk).singleton) (r_s.rep[! r_stk])) (null.singleton))
                 (Rgn.diff r_s.alloct.M.domain oa))) }
        invariant { [@expl:lockstep] (((! l_i) < (! l_n)) = ((! r_i) < (! r_n))) }
        (match REL_STACK_biinterface.pop l_s r_s pi (! l_stk) (! r_stk) with
         | (l_pop_res, r_pop_res) -> (l_c := ([@expl:c := pop(stk)] l_pop_res)); (r_c := ([@expl:c := pop(stk)] r_pop_res))
         end);
        (let l_v = ref 0 in
         let r_v = ref 0 in
         (match REL_STACK_biinterface.getCellValue l_s r_s pi (! l_c) (! r_c) with
          | (l_getCellValue_res, r_getCellValue_res) ->
              (l_v := ([@expl:v := getCellValue(c)] l_getCellValue_res));
              (r_v := ([@expl:v := getCellValue(c)] r_getCellValue_res))
          end);
         (l_result := ([@expl:result := result + v] ((! l_result) + (! l_v))));
         (r_result := ([@expl:result := result + v] ((! r_result) + (! r_v))));
         (l_i := ([@expl:i := i + 1] ((! l_i) + 1)));
         (r_i := ([@expl:i := i + 1] ((! r_i) + 1))))
      done;
      ((! l_result), (! r_result))
end

module REL_STACK
  use prelude.Prelude
  use State
  use ArrayStack
  use ListStack
  use export stack_theory.Stack_theory
  
  predicate stackCoupling (l_s: state) (r_s: state) (pi: PreRefperm.t) =
    (okRefperm l_s r_s pi)
      ->
      ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub))
      /\
      (l_s.ArrayStack.arrayStackPriv)
      /\
      (r_s.ListStack.listStackPriv)
      /\
      (l_s.maxSize = r_s.maxSize)
      /\
      (PreRefperm.idRgn pi l_s.pool r_s.pool)
      /\
      (forall l_s11 : reference, r_s12 : reference.
         (isAllocated l_s l_s11)
           ->
           (hasStackType l_s l_s11)
           ->
           (Rgn.mem l_s11 l_s.pool)
           ->
           (isAllocated r_s r_s12)
           ->
           (hasStackType r_s r_s12)
           ->
           (Rgn.mem r_s12 r_s.pool)
           ->
           (PreRefperm.idRef pi l_s11 r_s12)
           ->
           (let l_stk = l_s.contents[l_s11] in
            let r_stk = r_s.contents[r_s12] in
            (l_stk = r_stk)))
  
  let init_Stack (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_self : reference) (r_self : reference) : 
    (unit, unit)
    requires { hasStackType l_s l_self }
    requires { (l_self <> null) }
    requires { hasStackType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi }
    requires { stackCoupling l_s r_s pi }
    requires { ((agree_allfields l_s r_s pi (Rgn.diff (l_self.singleton) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                  (agree_allfields
                     r_s
                     l_s
                     (pi.PreRefperm.invert)
                     (Rgn.diff (r_self.singleton) (Rgn.union r_s.pool (img_rep r_s r_s.pool)))))
    }
    requires { PreRefperm.idRef pi l_self r_self }
    requires { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    requires { ((not (Rgn.mem l_self l_s.pool)) /\ (not (Rgn.mem r_self r_s.pool))) }
    writes { l_s.alloct,
      l_s.arr,
      l_s.contents,
      l_s.length,
      l_s.pool,
      l_s.rep,
      l_s.size,
      l_s.slots,
      l_s.top,
      r_s.contents,
      r_s.head,
      r_s.pool,
      r_s.rep,
      r_s.size }
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`size] (wr_frame_size (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`contents] (wr_frame_contents (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`top] (wr_frame_top (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`arr] (wr_frame_arr (old l_s) l_s (l_self.singleton)) }
    
    ensures { alloc_does_not_shrink (old l_s) l_s }
    
    ensures { [@expl:wr {}`length] (wr_frame_length (old l_s) l_s emptyRgn) }
    
    ensures { [@expl:wr {}`slots] (wr_frame_slots (old l_s) l_s emptyRgn) }
    
    ensures { [@expl:wr {self}`head] (wr_frame_head (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`rep] (wr_frame_rep (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`size] (wr_frame_size (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`contents] (wr_frame_contents (old r_s) r_s (r_self.singleton)) }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { stackCoupling l_s r_s pi }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              let l_self0 = old (l_self.singleton) in
              let r_self0 = old (r_self.singleton) in
              ((agree_allfields
                  l_s
                  r_s
                  pi
                  (Rgn.diff (Rgn.union (Rgn.diff l_s.alloct.M.domain l_s_alloc) l_self0) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_allfields
                    r_s
                    l_s
                    (pi.PreRefperm.invert)
                    (Rgn.diff (Rgn.union (Rgn.diff r_s.alloct.M.domain r_s_alloc) r_self0) (Rgn.union r_s.pool (img_rep r_s r_s.pool))))) }
    
    ensures { ((let oa = old l_s.alloct.M.domain in
                Rgn.subset (Rgn.diff (l_s.rep[l_self]) (null.singleton)) (Rgn.diff l_s.alloct.M.domain oa)) /\
                 (let oa = old r_s.alloct.M.domain in
                  Rgn.subset (Rgn.diff (r_s.rep[r_self]) (null.singleton)) (Rgn.diff r_s.alloct.M.domain oa))) }
    
    ensures { ((let opool = old l_s.pool in
                l_s.pool
                =
                (Rgn.union opool (l_self.singleton))) /\
                 (let opool = old r_s.pool in
                  r_s.pool
                  =
                  (Rgn.union opool (r_self.singleton)))) }
    
    ensures { (((l_s.contents[l_self]) = ArrayStack.STACK.nil) /\ ((r_s.contents[r_self]) = ListStack.STACK.nil)) }
    
    ensures { (((l_s.size[l_self]) = 0) /\ ((r_s.size[r_self]) = 0)) }
    
    ensures { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    
    ensures { ((let bsnap_r25 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r25 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r25 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r25 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
  = label INIT in
      let r_result = ref () in
      let l_result = ref () in
      let l_self = ref l_self in
      let r_self = ref r_self in
      let l_arr = ref null in
      let ghost l_rep = ref emptyRgn in
      ([@expl:self.rep := {}] (set_rep l_s (! l_self) emptyRgn));
      ([@expl:self.rep := {null}] (set_rep r_s (! r_self) (null.singleton)));
      ([@expl:self.head := null] (set_head r_s (! r_self) null));
      ([@expl:self.contents := nil] (set_contents l_s (! l_self) ArrayStack.STACK.nil));
      ([@expl:self.contents := nil] (set_contents r_s (! r_self) ListStack.STACK.nil));
      assert { let l_stk = l_s.contents[! l_self] in
               let r_stk = r_s.contents[! r_self] in
               (l_stk = r_stk) };
      ([@expl:self.size := 0] (set_size l_s (! l_self) 0));
      ([@expl:self.size := 0] (set_size r_s (! r_self) 0));
      ([@expl:self.top := - 1] (set_top l_s (! l_self) (0 - 1)));
      (l_arr := ([@expl:arr := new(CellArray){maxSize}] (l_s.mk_CellArray)));
      ([@expl:arr := new(CellArray){maxSize}] (set_length l_s (! l_arr) l_s.maxSize));
      ([@expl:arr := new(CellArray){maxSize}] (set_slots l_s (! l_arr) (A.make l_s.maxSize null)));
      ([@expl:self.arr := arr] (set_arr l_s (! l_self) (! l_arr)));
      (l_rep := ([@expl:rep := self.rep] (l_s.rep[! l_self])));
      ([@expl:self.rep := rep union {arr}] (set_rep l_s (! l_self) (Rgn.union (! l_rep) ((! l_arr).singleton))));
      (set_pool l_s ([@expl:pool := pool union {self}] (Rgn.union l_s.pool ((! l_self).singleton))));
      (set_pool r_s ([@expl:pool := pool union {self}] (Rgn.union r_s.pool ((! r_self).singleton))));
      assume {
        ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub))
          /\
          (l_s.ArrayStack.arrayStackPriv)
          /\
          (r_s.ListStack.listStackPriv) };
      assume {
        ((let oa = old l_s.alloct.M.domain in
          Rgn.subset (Rgn.diff (l_s.rep[! l_self]) (null.singleton)) (Rgn.diff l_s.alloct.M.domain oa)) /\
           (let oa = old r_s.alloct.M.domain in
            Rgn.subset (Rgn.diff (r_s.rep[! r_self]) (null.singleton)) (Rgn.diff r_s.alloct.M.domain oa))) };
      ((! l_result), (! r_result))
  
  let isEmpty (l_s : state) (r_s : state) (pi13 : PreRefperm.t) (l_self : reference) (r_self : reference) : 
    (bool, bool)
    requires { hasStackType l_s l_self }
    requires { (l_self <> null) }
    requires { hasStackType r_s r_self }
    requires { (r_self <> null) }
    requires { okRefperm l_s r_s pi13 }
    requires { stackCoupling l_s r_s pi13 }
    requires { ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub)) }
    requires { PreRefperm.idRef pi13 l_self r_self }
    requires { ((agree_allfields l_s r_s pi13 (l_self.singleton)) /\
                  (agree_allfields r_s l_s (pi13.PreRefperm.invert) (r_self.singleton)))
    }
    requires { ((Rgn.mem l_self l_s.pool) /\ (Rgn.mem r_self r_s.pool)) }
    ensures { okRefperm l_s r_s pi13 }
    
    ensures { stackCoupling l_s r_s pi13 }
    
    ensures { let l_s_alloc = old l_s.alloct.M.domain in
              let r_s_alloc = old r_s.alloct.M.domain in
              ((agree_allfields
                  l_s
                  r_s
                  pi13
                  (Rgn.diff (Rgn.diff l_s.alloct.M.domain l_s_alloc) (Rgn.union l_s.pool (img_rep l_s l_s.pool)))) /\
                 (agree_allfields
                    r_s
                    l_s
                    (pi13.PreRefperm.invert)
