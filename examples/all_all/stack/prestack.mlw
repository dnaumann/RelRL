        ((l_s.ArrayStack.STACK.stackPub) /\ (r_s.ListStack.STACK.stackPub))
          /\
          (l_s.ArrayStack.arrayStackPriv)
          /\
          (r_s.ListStack.listStackPriv) };
      assume {
        ((let rep19 = l_s.rep[! l_self] in
          Rgn.mem (! l_result) rep19) /\
           (let rep20 = r_s.rep[! r_self] in
            Rgn.mem (! r_result) rep20)) };
      ((! l_result), (! r_result))
  
  let getCellValue (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_c : reference) (r_c : reference) : 
    (int, int)
    requires { hasCellType l_s l_c }
    requires { (l_c <> null) }
    requires { hasCellType r_s r_c }
    requires { (r_c <> null) }
    requires { okRefperm l_s r_s pi }
    requires { stackCoupling l_s r_s pi }
    requires { let l_v = l_s.cell_value[l_c] in
               let r_v = r_s.cell_value[r_c] in
               (l_v = r_v) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { stackCoupling l_s r_s pi }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
    
    ensures { ((let bsnap_r25 = old (Rgn.union l_s.pool (img_rep l_s l_s.pool)) in
                Rgn.subset bsnap_r25 (Rgn.union l_s.pool (img_rep l_s l_s.pool))) /\
                 (let bsnap_r25 = old (Rgn.union r_s.pool (img_rep r_s r_s.pool)) in
                  Rgn.subset bsnap_r25 (Rgn.union r_s.pool (img_rep r_s r_s.pool)))) }
  = label INIT in
      let r_result = ref 0 in
      let l_result = ref 0 in
      let l_c = ref l_c in
      let r_c = ref r_c in
      (l_result := ([@expl:result := c.cell_value] (l_s.cell_value[! l_c])));
      (r_result := ([@expl:result := c.cell_value] (r_s.cell_value[! r_c])));
      ((! l_result), (! r_result))
  
  lemma boundary_frames_coupling_REL_STACK:
    forall s : state, t : state, s' : state, t' : state, pi21 : PreRefperm.t, pi' : PreRefperm.t, rho : PreRefperm.t.
      (okRefperm s t pi21)
        ->
        (okRefperm s' t' pi')
        ->
        (PreRefperm.identity pi21 s.alloct.M.domain t.alloct.M.domain)
        ->
        (PreRefperm.identity pi' s'.alloct.M.domain t'.alloct.M.domain)
        ->
        (okRefperm s s' rho)
        ->
        (okRefperm t t' rho)
        ->
        (s.maxSize = t.maxSize)
        ->
        (PreRefperm.idRgn pi21 s.pool t.pool)
        ->
        (agree_allfields s t pi21 (Rgn.union s.pool (img_rep s s.pool)))
        ->
        (s'.maxSize = t'.maxSize)
        ->
        (PreRefperm.idRgn pi' s'.pool t'.pool)
        ->
        (agree_allfields s' t' pi' (Rgn.union s'.pool (img_rep s' s'.pool)))
        ->
        (stackCoupling s s' rho)
        ->
        (stackCoupling t t' rho)
  
  lemma stackCoupling_is_refperm_monotonic:
    forall s : state, t : state, pi22 : PreRefperm.t.
      ((okRefperm s t pi22) ->
         ((stackCoupling s t pi22) ->
            (forall rho : PreRefperm.t. ((okRefperm s t rho) -> ((PreRefperm.extends pi22 rho) -> (stackCoupling s t rho))))))
end

module CLIENT_REL_biinterface
  use prelude.Prelude
  use State
  use Client1
  use Client2
  use REL_STACK
end

module Cell
  use prelude.Prelude
  use State
  use CELL
  
  let init_Cell (s : state) (self : reference) (k : int) : unit
    requires { hasCellType s self }
    requires { (self <> null) }
    writes { s.cell_rep, s.cell_value }
    ensures { (result = ()) }
    
    ensures { [@expl:wr {self}`cell_rep] (wr_frame_cell_rep (old s) s (self.singleton)) }
    
    ensures { [@expl:wr {self}`cell_value] (wr_frame_cell_value (old s) s (self.singleton)) }
    
    ensures { (s.cell_value[self]) = k }
    
    ensures { (s.cell_rep[self]) = (self.singleton) }
  = label INIT in
      let result = ref () in
      let self = ref self in
      let k = ref k in
      ([@expl:self.cell_value := k] (set_cell_value s (! self) (! k)));
      ([@expl:self.cell_rep := {self}] (set_cell_rep s (! self) ((! self).singleton)));
      (! result)
end

module MAIN
  use prelude.Prelude
  use State
end

