module State
  use prelude.Prelude
  use prelude.PreRefperm
  
  type reftype = {  }
  
  type state = private { mutable ghost alloct : M.t reftype }
    invariant { not (M.mem null alloct) }
    by { alloct = (().M.create) }
  
  predicate isAllocated (s: state) (p: reference) = M.mem p s.alloct
  
  predicate isValidRgn (s: state) (r: rgn) =
    forall q : reference. ((Rgn.mem q r) -> ((q = null) \/ (M.mem q s.alloct)))
  
  predicate typeofRgn (s: state) (r: rgn) (types: L.list reftype) =
    forall p : reference.
      ((Rgn.mem p r) ->
         ((p = null) \/ ((M.mem p s.alloct) /\ (L.mem (s.alloct[p]) types))))
  
  predicate okRefperm (sl: state) (sr: state) (pi: PreRefperm.t) =
    ((forall p : reference. ((M.mem p pi.lor) -> (M.mem p sl.alloct))) /\
       ((forall q : reference. ((M.mem q pi.rol) -> (M.mem q sr.alloct))) /\
          (forall p : reference, q : reference.
             ((M.mem p pi.lor) ->
                (((pi.lor[p]) = q) -> ((sl.alloct[p]) = (sr.alloct[q])))))))
  
  predicate alloc_does_not_shrink (pre: state) (post: state) =
    forall p : reference.
      ((M.mem p pre.alloct) ->
         ((M.mem p post.alloct) /\ ((pre.alloct[p]) = (post.alloct[p]))))
  
  predicate agree_allfields (sl: state) (sr: state) (pi: PreRefperm.t) (w: rgn)
end

module I
  use prelude.Prelude
  use State
  
  val prog (s: state) : int
end

module A
  use prelude.Prelude
  use State
  use I
  
  val prog (s: state) : int
end

module FREL
  use prelude.Prelude
  use State
  use A
  
  let prog (l_s : state) (r_s : state) (pi : PreRefperm.t) (l_l : int) (l_b : int) (r_l : int) (r_b : int) : 
    (int, int)
    requires { okRefperm l_s r_s pi }
    requires { (l_b = r_b) }
    requires { (l_l = r_l) }
    ensures { okRefperm l_s r_s pi }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
  = label INIT in
      let r_result = ref 0 in
      let l_result = ref 0 in
      let l_l = ref l_l in
      let l_b = ref l_b in
      let r_l = ref r_l in
      let r_b = ref r_b in
      let l_h = ref 0 in
      let r_h = ref 0 in
      (l_h := ([@expl:havoc h] (any int)));
      (if ((! l_h) > 0) then
         (l_result := ([@expl:result := l + b] ((! l_l) + (! l_b))))
       else (l_result := ([@expl:result := l + b] ((! l_l) + (! l_b)))));
      assert { exists r_h : int. ((! l_h) = r_h) };
      (r_h := ([@expl:havoc h] (any int)));
      assume { ((! l_h) = (! r_h)) };
      (if ((! r_h) > 0) then
         (r_result := ([@expl:result := l + b] ((! r_l) + (! r_b))))
       else (r_result := ([@expl:result := l + b] ((! r_l) + (! r_b)))));
      ((! l_result), (! r_result))
end

module FREL_biinterface
  use prelude.Prelude
  use State
  use A
  
  val prog (l_s: state) (r_s: state) (pi1: PreRefperm.t) (l_l: int) (l_b: int) (r_l: int) (r_b: int) : 
    (int, int)
    requires { okRefperm l_s r_s pi1 }
    requires { (l_b = r_b) }
    requires { (l_l = r_l) }
    ensures { okRefperm l_s r_s pi1 }
    
    ensures { match result with
              | (l_result, r_result) -> (l_result = r_result)
              end }
end

module MAIN
  use prelude.Prelude
  use State
end

