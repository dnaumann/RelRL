              (wr_frame_sz (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`contents]
              (wr_frame_contents (old r_s) r_s (r_self.singleton)) }
    
    ensures { okRefperm l_s r_s pi }
    
    ensures { forall l_i : int, r_i : int.
