              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
  = label INIT in
      let r_result = ref () in
      let l_result = ref () in
      let l_self = ref l_self in
      let l_k = ref l_k in
      let r_self = ref r_self in
      let r_k = ref r_k in
