      ([@expl:self.contents := upd_list(k,v,temp_intlist)]
       (set_contents
          l_s
          (! l_self)
          (Map_Array.MAP.upd_list (! l_k) (! l_v) (! l_temp_intlist))));
      ([@expl:self.contents := upd_list(k,v,temp_intlist)]
       (set_contents
          r_s
          (! r_self)
