      let l_self = ref l_self in
      let l_sz = ref l_sz in
      let r_self = ref r_self in
      let r_sz = ref r_sz in
      ([@expl:self.data := make(sz,0)]
       (set_data l_s (! l_self) (A.make (! l_sz) 0)));
      ([@expl:self.data_fn := empty_fun]
       (set_data_fn r_s (! r_self) Map_Fun.empty_fun));
      ([@expl:self.contents := create_list(sz,0)]
       (set_contents l_s (! l_self) (Map_Array.MAP.create_list (! l_sz) 0)));
      ([@expl:self.contents := create_list(sz,0)]
       (set_contents r_s (! r_self) (Map_Fun.MAP.create_list (! r_sz) 0)));
      ([@expl:self.sz := sz] (set_sz l_s (! l_self) (! l_sz)));
      ([@expl:self.sz := sz] (set_sz r_s (! r_self) (! r_sz)));
      ((! l_result), (! r_result))
  
  let setval (l_s : state) (r_s : state) (pi4 : PreRefperm.t) (l_self : reference) (l_k : int) (l_v : int) (r_self : reference) (r_k : int) (r_v : int) : 
