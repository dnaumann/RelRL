      let l_v = ref l_v in
      let r_self = ref r_self in
      let r_k = ref r_k in
      let r_v = ref r_v in
      let l_temp_intarray = ref (A.make 0 0) in
      let r_temp_fn = ref (any int_fun) in
      let ghost l_temp_intlist = ref (any intList) in
      let ghost r_temp_intlist = ref (any intList) in
      (l_temp_intarray
         := ([@expl:temp_intarray := self.data] (l_s.data[! l_self])));
      (r_temp_fn := ([@expl:temp_fn := self.data_fn] (r_s.data_fn[! r_self])));
      ([@expl:self.data := set(temp_intarray,k,v)]
