    requires { Map_Array.map_array_priv l_s l_self }
    requires { ((Map_Array.MAP.map_inv l_s l_self) /\
                  (Map_Fun.MAP.map_inv r_s r_self))
    }
    requires { (l_k = r_k) }
    requires { ((let sz10 = l_s.sz[l_self] in
