      assert { exists r_v : int. ((! l_v) = r_v) };
      (r_v := ([@expl:havoc v] (any int)));
      assume { ((! l_v) = (! r_v)) };
      (match [@expl:setval(self,k,v)]
             (setval
                l_s
                r_s
                pi9
                (! l_self)
                (! l_k)
                (! l_v)
                (! r_self)
