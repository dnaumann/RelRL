                 (((0 <= l_i) /\ (l_i < l_x)) /\ ((0 <= r_i) /\ (r_i < r_x))))
                  ->
                  (let l_x = l_s.contents[l_self] in
                   let r_x = r_s.contents[r_self] in
                   let l_v = Map_Array.MAP.listNth l_i l_x in
                   let r_v = Map_Fun.MAP.listNth r_i r_x in
                   ((l_v = 0) /\ (r_v = 0))) }
    
    ensures { let l_x = l_s.sz[l_self] in
              let r_x = r_s.sz[r_self] in
              (l_x = r_x) }
    
    ensures { ((Map_Array.MAP.map_inv l_s l_self) /\
                 (Map_Fun.MAP.map_inv r_s r_self)) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
  = label INIT in
      let r_result = ref () in
