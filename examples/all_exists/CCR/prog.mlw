               (l_l = r_l)
    }
    requires { Map_Fun.map_fn_priv r_s r_self }
    requires { Map_Array.map_array_priv l_s l_self }
    requires { ((Map_Array.MAP.map_inv l_s l_self) /\
                  (Map_Fun.MAP.map_inv r_s r_self))
    }
    requires { (l_k = r_k) }
    requires { ((let sz18 = l_s.sz[l_self] in
                 (0 <= l_k) /\ (l_k < sz18)) /\
                  (let sz19 = r_s.sz[r_self] in
                   (0 <= r_k) /\ (r_k < sz19)))
    }
    writes { l_s.contents,
      l_s.data,
      l_s.data_fn,
      l_s.sz,
      r_s.contents,
      r_s.data,
      r_s.data_fn,
      r_s.sz }
    ensures { [@expl:wr {self}`data_fn]
              (wr_frame_data_fn (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`sz]
              (wr_frame_sz (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`contents]
              (wr_frame_contents (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`data]
              (wr_frame_data (old l_s) l_s (l_self.singleton)) }
    
    ensures { [@expl:wr {self}`data_fn]
              (wr_frame_data_fn (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`sz]
              (wr_frame_sz (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`contents]
              (wr_frame_contents (old r_s) r_s (r_self.singleton)) }
    
    ensures { [@expl:wr {self}`data]
              (wr_frame_data (old r_s) r_s (r_self.singleton)) }
    
    ensures { okRefperm l_s r_s pi17 }
    
    ensures { let l_l = l_s.contents[l_self] in
              let r_l = r_s.contents[r_self] in
              (l_l = r_l) }
    
    ensures { ((let old_sz = old (l_s.sz[l_self]) in
                (l_s.sz[l_self])
                =
                old_sz) /\
                 (let old_sz = old (r_s.sz[r_self]) in
                  (r_s.sz[r_self])
                  =
                  old_sz)) }
    
    ensures { match result with
              | (l_result, r_result) -> ((l_result = ()) /\ (r_result = ()))
              end }
end

